<%
  const currentSubdomain = store && store.subdomain ? `${store.subdomain}.${platformBrand && platformBrand.website ? platformBrand.website : 'aislecommerce.com'}` : 'store.aislecommerce.com';
  const sslStatus = (store && store.ssl_status ? store.ssl_status : 'pending').toLowerCase();
  const sslBadgeClass = sslStatus === 'issued' ? 'bg-emerald-50 text-emerald-700' : 'bg-amber-50 text-amber-700';
%>
<section class="space-y-8">
  <div>
    <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary">Infrastructure</p>
    <h1 class="section-title mt-2 text-3xl font-semibold tracking-tight text-slate-950">Domain Setup</h1>
    <p class="mt-3 max-w-2xl text-base leading-7 text-slate-600">Keep the default subdomain live while you point a branded domain and move SSL through verification.</p>
  </div>

  <div class="grid gap-8 xl:grid-cols-[0.95fr_1.05fr]">
    <section class="surface-card space-y-6 rounded-[2rem] p-6">
      <div class="rounded-3xl bg-slate-50 p-5">
        <p class="text-sm font-medium text-slate-500">Current subdomain</p>
        <p class="mt-2 text-2xl font-semibold text-slate-950"><%= currentSubdomain %></p>
      </div>

      <form action="/admin/domain" method="post" class="space-y-5">
        <div>
          <label for="customDomain" class="mb-1 block text-sm font-medium text-slate-700">Custom domain</label>
          <input id="customDomain" name="custom_domain" type="text" value="<%= store && store.custom_domain ? store.custom_domain : '' %>" class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="www.aisle-store.com">
          <%- include('../partials/form-error', { field: 'custom_domain' }) %>
        </div>
        <button type="submit" class="inline-flex items-center justify-center rounded-2xl bg-primary px-5 py-3 text-sm font-semibold text-white shadow-soft transition hover:bg-primary-dark">
          Save and verify
        </button>
      </form>
    </section>

    <aside class="space-y-6">
      <section class="surface-card rounded-[2rem] p-6">
        <div class="flex items-center justify-between gap-4">
          <div>
            <p class="text-sm font-medium text-slate-500">SSL status</p>
            <h2 class="section-title mt-2 text-2xl font-semibold text-slate-950">Certificate</h2>
          </div>
          <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] <%= sslBadgeClass %>"><%= sslStatus %></span>
        </div>
        <p class="mt-4 text-sm leading-6 text-slate-600">
          The certificate will move from pending to issued once DNS is set correctly and verification completes.
        </p>
      </section>

      <section class="surface-card rounded-[2rem] p-6">
        <p class="text-sm font-medium text-slate-500">DNS instructions</p>
        <div class="mt-5 rounded-3xl bg-slate-50 p-5">
          <p class="text-sm font-semibold text-slate-900">Add a CNAME record</p>
          <p class="mt-2 text-sm text-slate-600">Point the custom host to <span class="font-semibold text-slate-900">stores.<%= platformBrand && platformBrand.website ? platformBrand.website : 'aislecommerce.com' %></span>.</p>
          <div class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 text-sm text-slate-700">
            Host: <span class="font-semibold">@ or www</span><br>
            Type: <span class="font-semibold">CNAME</span><br>
            Value: <span class="font-semibold">stores.<%= platformBrand && platformBrand.website ? platformBrand.website : 'aislecommerce.com' %></span>
          </div>
        </div>
      </section>
    </aside>
  </div>
</section>
