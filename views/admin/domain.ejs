<%
  const currentSubdomain = store && store.subdomain ? `${store.subdomain}.yoursaas.com` : 'store.yoursaas.com';
  const sslStatus = (store && store.ssl_status ? store.ssl_status : 'pending').toLowerCase();
  const sslBadgeClass = sslStatus === 'issued' ? 'bg-emerald-50 text-emerald-600' : 'bg-amber-50 text-amber-600';
%>
<section class="space-y-8">
  <div>
    <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary">Infrastructure</p>
    <h1 class="mt-2 text-3xl font-semibold tracking-tight text-gray-900">Domain Setup</h1>
    <p class="mt-3 max-w-2xl text-base leading-7 text-gray-600">Keep your default subdomain live while you connect a branded custom domain and wait for SSL issuance.</p>
  </div>

  <div class="grid gap-8 xl:grid-cols-[0.95fr_1.05fr]">
    <section class="space-y-6 rounded-[2rem] border border-gray-200 bg-white p-6 shadow-sm">
      <div class="rounded-3xl bg-gray-50 p-5">
        <p class="text-sm font-medium text-gray-500">Current subdomain</p>
        <p class="mt-2 text-2xl font-semibold text-gray-900"><%= currentSubdomain %></p>
      </div>

      <form action="/admin/domain" method="post" class="space-y-5">
        <div>
          <label for="customDomain" class="mb-1 block text-sm font-medium text-gray-700">Custom Domain</label>
          <input id="customDomain" name="custom_domain" type="text" value="<%= store && store.custom_domain ? store.custom_domain : '' %>" class="w-full rounded-2xl border border-gray-300 px-4 py-3 text-gray-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="www.mystore.com">
          <%- include('../partials/form-error', { field: 'custom_domain' }) %>
        </div>
        <button type="submit" class="inline-flex items-center justify-center rounded-2xl bg-primary px-5 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-primary-dark">
          Save &amp; Verify
        </button>
      </form>
    </section>

    <aside class="space-y-6">
      <section class="rounded-[2rem] border border-gray-200 bg-white p-6 shadow-sm">
        <div class="flex items-center justify-between gap-4">
          <div>
            <p class="text-sm font-medium text-gray-500">SSL status</p>
            <h2 class="mt-2 text-2xl font-semibold text-gray-900">Certificate</h2>
          </div>
          <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] <%= sslBadgeClass %>"><%= sslStatus %></span>
        </div>
        <p class="mt-4 text-sm leading-6 text-gray-600">
          Your certificate will move from pending to issued once DNS is set correctly and the domain finishes verification.
        </p>
      </section>

      <section class="rounded-[2rem] border border-gray-200 bg-white p-6 shadow-sm">
        <p class="text-sm font-medium text-gray-500">DNS instructions</p>
        <div class="mt-5 rounded-3xl bg-gray-50 p-5">
          <p class="text-sm font-semibold text-gray-900">Add a CNAME record</p>
          <p class="mt-2 text-sm text-gray-600">Point your custom host to <span class="font-semibold text-gray-900">stores.yoursaas.com</span>.</p>
          <div class="mt-4 rounded-2xl border border-gray-200 bg-white p-4 text-sm text-gray-700">
            Host: <span class="font-semibold">@ or www</span><br>
            Type: <span class="font-semibold">CNAME</span><br>
            Value: <span class="font-semibold">stores.yoursaas.com</span>
          </div>
        </div>
      </section>
    </aside>
  </div>
</section>
