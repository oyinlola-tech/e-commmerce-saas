<section class="space-y-8">
  <div>
    <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary">Brand settings</p>
    <h1 class="mt-2 text-3xl font-semibold tracking-tight text-gray-900">Store Settings</h1>
    <p class="mt-3 max-w-2xl text-base leading-7 text-gray-600">Update the visible identity of this tenant so the storefront and admin feel clearly aligned to the brand.</p>
  </div>

  <form action="/admin/settings" method="post" class="grid gap-8 xl:grid-cols-[1fr_0.9fr]">
    <section class="space-y-6 rounded-[2rem] border border-gray-200 bg-white p-6 shadow-sm">
      <div>
        <label for="storeName" class="mb-1 block text-sm font-medium text-gray-700">Store Name</label>
        <input id="storeName" name="name" type="text" value="<%= store && store.name ? store.name : '' %>" class="w-full rounded-2xl border border-gray-300 px-4 py-3 text-gray-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="Northline Studio">
        <%- include('../partials/form-error', { field: 'name' }) %>
      </div>
      <div>
        <label for="logo" class="mb-1 block text-sm font-medium text-gray-700">Logo URL</label>
        <input id="logo" name="logo" type="url" value="<%= store && store.logo ? store.logo : '' %>" class="w-full rounded-2xl border border-gray-300 px-4 py-3 text-gray-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="https://example.com/logo.png">
        <%- include('../partials/form-error', { field: 'logo' }) %>
      </div>
      <div>
        <label for="themeColor" class="mb-1 block text-sm font-medium text-gray-700">Theme Colour</label>
        <div class="flex items-center gap-4 rounded-2xl border border-gray-300 bg-white px-4 py-3 shadow-sm">
          <input id="themeColor" name="theme_color" type="color" value="<%= store && store.theme_color ? store.theme_color : '#4F46E5' %>" class="h-12 w-16 rounded-xl border-0 bg-transparent p-0">
          <div>
            <p class="text-sm font-medium text-gray-900"><%= store && store.theme_color ? store.theme_color : '#4F46E5' %></p>
            <p class="mt-1 text-sm text-gray-500">Used for storefront buttons, links, badges, and focus states.</p>
          </div>
        </div>
        <%- include('../partials/form-error', { field: 'theme_color' }) %>
      </div>
    </section>

    <aside class="space-y-6">
      <section class="rounded-[2rem] border border-gray-200 bg-white p-6 shadow-sm">
        <p class="text-sm font-medium text-gray-500">Preview card</p>
        <div class="mt-5 rounded-[1.75rem] border border-gray-200 bg-gray-50 p-5">
          <div class="flex items-center gap-3">
            <% if (store && store.logo) { %>
              <img src="<%= store.logo %>" alt="<%= store.name %> logo" class="h-12 w-12 rounded-2xl object-cover">
            <% } else { %>
              <span class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-primary text-lg font-semibold text-white"><%= store && store.name ? store.name.charAt(0).toUpperCase() : 'S' %></span>
            <% } %>
            <div>
              <p class="text-base font-semibold text-gray-900"><%= store && store.name ? store.name : 'Your Store' %></p>
              <p class="text-sm text-gray-500"><%= store && store.subdomain ? `${store.subdomain}.yoursaas.com` : 'store.yoursaas.com' %></p>
            </div>
          </div>
          <div class="mt-5 rounded-2xl bg-white p-4">
            <button type="button" class="inline-flex w-full items-center justify-center rounded-2xl bg-primary px-4 py-3 text-sm font-semibold text-white shadow-sm">Primary storefront button</button>
          </div>
        </div>
      </section>

      <div class="rounded-[2rem] border border-gray-200 bg-white p-6 shadow-sm">
        <button type="submit" class="inline-flex w-full items-center justify-center rounded-2xl bg-primary px-5 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-primary-dark">
          Save
        </button>
      </div>
    </aside>
  </form>
</section>
