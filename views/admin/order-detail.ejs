<%
  const currency = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' });
  const orderData = order || {};
  const orderItems = Array.isArray(orderData.items) ? orderData.items : [];
%>
<section class="space-y-8">
  <div class="flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary">Order detail</p>
      <h1 class="mt-2 text-3xl font-semibold tracking-tight text-gray-900">Order #<%= orderData.id || '0000' %></h1>
      <p class="mt-3 max-w-2xl text-base leading-7 text-gray-600">Review customer information, purchased items, and update fulfillment status from a single screen.</p>
    </div>
    <a href="/admin/orders" class="inline-flex items-center justify-center rounded-2xl border border-gray-200 px-5 py-3 text-sm font-medium text-gray-700 transition hover:border-primary hover:text-primary">
      Back to Orders
    </a>
  </div>

  <div class="grid gap-8 xl:grid-cols-[0.95fr_1.05fr]">
    <aside class="space-y-6">
      <section class="rounded-[2rem] border border-gray-200 bg-white p-6 shadow-sm">
        <p class="text-sm font-medium text-gray-500">Customer information</p>
        <div class="mt-5 space-y-4 text-sm text-gray-600">
          <div>
            <p class="font-semibold text-gray-900"><%= orderData.customer && orderData.customer.name ? orderData.customer.name : 'Guest customer' %></p>
            <p class="mt-1"><%= orderData.customer && orderData.customer.email ? orderData.customer.email : 'No email provided' %></p>
          </div>
          <div class="rounded-2xl bg-gray-50 p-4">
            <p class="text-xs uppercase tracking-[0.2em] text-gray-400">Shipping address</p>
            <p class="mt-2 leading-6 text-gray-700"><%= orderData.customer && orderData.customer.address ? orderData.customer.address : 'Address pending at checkout' %></p>
          </div>
        </div>
      </section>

      <section class="rounded-[2rem] border border-gray-200 bg-white p-6 shadow-sm">
        <p class="text-sm font-medium text-gray-500">Update status</p>
        <form action="/admin/orders/<%= orderData.id %>/status" method="post" class="mt-5 space-y-4">
          <label for="status" class="block text-sm font-medium text-gray-700">Status</label>
          <select id="status" name="status" class="w-full rounded-2xl border border-gray-300 px-4 py-3 text-gray-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20">
            <% ['Pending', 'Shipped', 'Delivered'].forEach((status) => { %>
              <option value="<%= status.toLowerCase() %>" <%= (orderData.status || '').toLowerCase() === status.toLowerCase() ? 'selected' : '' %>><%= status %></option>
            <% }) %>
          </select>
          <button type="submit" class="inline-flex w-full items-center justify-center rounded-2xl bg-primary px-4 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-primary-dark">
            Update Status
          </button>
        </form>
      </section>
    </aside>

    <section class="rounded-[2rem] border border-gray-200 bg-white p-6 shadow-sm">
      <div class="flex items-center justify-between gap-4">
        <div>
          <p class="text-sm font-medium text-gray-500">Purchased items</p>
          <h2 class="mt-1 text-2xl font-semibold text-gray-900">Order summary</h2>
        </div>
        <span class="inline-flex rounded-full bg-primary-soft px-3 py-1 text-sm font-semibold text-primary"><%= orderItems.length %> items</span>
      </div>

      <% if (orderItems.length) { %>
        <div class="mt-6 space-y-4">
          <% orderItems.forEach((item) => { %>
            <article class="flex flex-col gap-4 rounded-3xl border border-gray-200 p-4 sm:flex-row sm:items-center sm:justify-between">
              <div class="flex items-center gap-4">
                <img src="<%= item.image || 'https://placehold.co/96x96?text=Item' %>" alt="<%= item.name %>" class="h-16 w-16 rounded-2xl object-cover">
                <div>
                  <h3 class="text-sm font-semibold text-gray-900"><%= item.name %></h3>
                  <p class="mt-1 text-sm text-gray-500">Qty <%= item.quantity || 1 %></p>
                </div>
              </div>
              <p class="text-base font-semibold text-gray-900"><%= currency.format((item.price || 0) * (item.quantity || 1)) %></p>
            </article>
          <% }) %>
        </div>
      <% } else { %>
        <div class="mt-6 rounded-3xl border border-dashed border-gray-300 bg-gray-50 px-6 py-12 text-center">
          <p class="text-lg font-semibold text-gray-900">No order items found</p>
          <p class="mt-2 text-sm leading-6 text-gray-500">The backend should attach line items to the `order.items` collection for this screen.</p>
        </div>
      <% } %>

      <div class="mt-8 border-t border-gray-200 pt-6">
        <div class="flex items-center justify-between text-sm text-gray-600">
          <span>Order date</span>
          <span><%= orderData.created_at ? new Date(orderData.created_at).toLocaleString() : 'Just now' %></span>
        </div>
        <div class="mt-4 flex items-center justify-between text-lg font-semibold text-gray-900">
          <span>Total</span>
          <span><%= currency.format(orderData.total || 0) %></span>
        </div>
      </div>
    </section>
  </div>
</section>
