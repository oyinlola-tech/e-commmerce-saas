<%
  const money = typeof formatMoney === 'function' ? formatMoney : ((value) => value);
  const metrics = {
    totalProducts: stats && typeof stats.totalProducts !== 'undefined' ? stats.totalProducts : (Array.isArray(products) ? products.length : 0),
    publishedProducts: stats && typeof stats.publishedProducts !== 'undefined' ? stats.publishedProducts : 0,
    totalOrders: stats && typeof stats.totalOrders !== 'undefined' ? stats.totalOrders : (Array.isArray(orders) ? orders.length : 0),
    revenue30d: stats && typeof stats.revenue30d !== 'undefined' ? stats.revenue30d : 0,
    customersCount: stats && typeof stats.customersCount !== 'undefined' ? stats.customersCount : 0,
    openSupportTickets: stats && typeof stats.openSupportTickets !== 'undefined' ? stats.openSupportTickets : 0
  };
  const recent = Array.isArray(recentOrders) ? recentOrders : (Array.isArray(orders) ? orders.slice(0, 5) : []);
  const queue = Array.isArray(supportQueue) ? supportQueue : [];
  const statusClass = (status) => {
    switch ((status || '').toLowerCase()) {
      case 'delivered':
        return 'bg-emerald-50 text-emerald-700';
      case 'shipped':
        return 'bg-sky-50 text-sky-700';
      default:
        return 'bg-amber-50 text-amber-700';
    }
  };
%>
<section class="space-y-8">
  <div class="surface-card rounded-[2rem] p-8">
    <div class="grid gap-8 xl:grid-cols-[1fr_0.9fr] xl:items-end">
      <div>
        <span class="eyebrow">Store Command</span>
        <h1 class="section-title mt-5 text-4xl font-semibold tracking-tight text-slate-950">Keep the storefront sharp, the orders moving, and the service promise intact.</h1>
        <p class="mt-4 max-w-2xl text-lg leading-8 text-slate-600">
          A single workspace for merchandising, fulfillment, customer context, and brand operations.
        </p>
      </div>
      <div class="grid gap-4 sm:grid-cols-2">
        <article class="metric-card rounded-3xl p-5">
          <p class="text-sm font-medium text-slate-500">Revenue (30 days)</p>
          <p class="metric-value mt-2 text-3xl font-semibold text-slate-950"><%= money(metrics.revenue30d || 0) %></p>
        </article>
        <article class="metric-card rounded-3xl p-5">
          <p class="text-sm font-medium text-slate-500">Customers</p>
          <p class="metric-value mt-2 text-3xl font-semibold text-slate-950"><%= metrics.customersCount || 0 %></p>
        </article>
      </div>
    </div>
  </div>

  <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
    <article class="metric-card rounded-3xl p-6">
      <p class="text-sm font-medium text-slate-500">Total products</p>
      <p class="metric-value mt-3 text-3xl font-semibold tracking-tight text-slate-950"><%= metrics.totalProducts %></p>
      <p class="mt-3 text-sm text-slate-500"><%= metrics.publishedProducts %> published and ready for customers.</p>
    </article>
    <article class="metric-card rounded-3xl p-6">
      <p class="text-sm font-medium text-slate-500">Total orders</p>
      <p class="metric-value mt-3 text-3xl font-semibold tracking-tight text-slate-950"><%= metrics.totalOrders %></p>
      <p class="mt-3 text-sm text-slate-500">Order flow visible from checkout through delivery.</p>
    </article>
    <article class="metric-card rounded-3xl p-6">
      <p class="text-sm font-medium text-slate-500">Open support tickets</p>
      <p class="metric-value mt-3 text-3xl font-semibold tracking-tight text-slate-950"><%= metrics.openSupportTickets %></p>
      <p class="mt-3 text-sm text-slate-500">Cases that still need action or customer closure.</p>
    </article>
    <article class="metric-card rounded-3xl p-6">
      <p class="text-sm font-medium text-slate-500">Markets served</p>
      <p class="metric-value mt-3 text-3xl font-semibold tracking-tight text-slate-950"><%= store && store.markets ? store.markets.length : 0 %></p>
      <p class="mt-3 text-sm text-slate-500">International readiness reflected in the storefront content and operations.</p>
    </article>
  </div>

  <div class="grid gap-8 xl:grid-cols-[1.08fr_0.92fr]">
    <section class="surface-card rounded-[2rem] p-6">
      <div class="flex items-center justify-between gap-4">
        <div>
          <p class="text-sm font-medium text-slate-500">Recent orders</p>
          <h2 class="section-title mt-1 text-2xl font-semibold text-slate-950">Latest customer activity</h2>
        </div>
        <a href="/admin/orders" class="text-sm font-semibold text-primary transition hover:underline">View all orders</a>
      </div>

      <% if (recent.length) { %>
        <div class="table-shell mt-6 overflow-x-auto rounded-[1.75rem]">
          <table class="min-w-full divide-y divide-slate-200">
            <thead class="bg-slate-50">
              <tr>
                <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Order</th>
                <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Customer</th>
                <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Date</th>
                <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Total</th>
                <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Status</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-200 bg-white">
              <% recent.forEach((entry) => { %>
                <tr class="transition hover:bg-slate-50">
                  <td class="whitespace-nowrap px-6 py-4 text-sm font-medium text-slate-900">#<%= entry.id %></td>
                  <td class="whitespace-nowrap px-6 py-4 text-sm text-slate-600"><%= entry.customer_name || (entry.customer && entry.customer.name) || 'Guest customer' %></td>
                  <td class="whitespace-nowrap px-6 py-4 text-sm text-slate-600"><%= entry.created_at ? new Date(entry.created_at).toLocaleDateString() : 'Today' %></td>
                  <td class="whitespace-nowrap px-6 py-4 text-sm text-slate-900"><%= money(entry.total || 0) %></td>
                  <td class="whitespace-nowrap px-6 py-4">
                    <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold <%= statusClass(entry.status) %>"><%= entry.status || 'Pending' %></span>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="mt-6 rounded-3xl border border-dashed border-slate-300 bg-slate-50 px-6 py-12 text-center">
          <p class="text-lg font-semibold text-slate-950">No recent orders yet</p>
          <p class="mt-2 text-sm leading-6 text-slate-500">Orders will appear here as soon as customers begin checking out.</p>
        </div>
      <% } %>
    </section>

    <div class="space-y-8">
      <section class="surface-card rounded-[2rem] p-6">
        <p class="text-sm font-medium text-slate-500">Store readiness</p>
        <h2 class="section-title mt-1 text-2xl font-semibold text-slate-950">Operational checklist</h2>
        <div class="mt-6 space-y-4">
          <div class="rounded-3xl border border-slate-200 bg-white p-5">
            <div class="flex items-center justify-between gap-4">
              <div>
                <p class="text-sm font-semibold text-slate-950">Domain status</p>
                <p class="mt-2 text-sm text-slate-500"><%= store && store.custom_domain ? store.custom_domain : `${store && store.subdomain ? store.subdomain : 'store'}.localhost` %></p>
              </div>
              <span class="inline-flex rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-700"><%= store && store.ssl_status ? store.ssl_status : 'issued' %></span>
            </div>
          </div>
          <div class="rounded-3xl border border-slate-200 bg-white p-5">
            <div class="flex items-center justify-between gap-4">
              <div>
                <p class="text-sm font-semibold text-slate-950">Catalog coverage</p>
                <p class="mt-2 text-sm text-slate-500"><%= metrics.totalProducts ? `${metrics.totalProducts} total products` : 'No products listed yet' %></p>
              </div>
              <a href="/admin/products" class="text-sm font-semibold text-primary transition hover:underline">Manage</a>
            </div>
          </div>
          <div class="rounded-3xl border border-slate-200 bg-white p-5">
            <div class="flex items-center justify-between gap-4">
              <div>
                <p class="text-sm font-semibold text-slate-950">Brand and service details</p>
                <p class="mt-2 text-sm text-slate-500">Keep messaging, support details, and operational promises aligned.</p>
              </div>
              <a href="/admin/settings" class="text-sm font-semibold text-primary transition hover:underline">Update</a>
            </div>
          </div>
        </div>
      </section>

      <section class="surface-card rounded-[2rem] p-6">
        <div class="flex items-center justify-between gap-4">
          <div>
            <p class="text-sm font-medium text-slate-500">Support visibility</p>
            <h2 class="section-title mt-1 text-2xl font-semibold text-slate-950">Active conversations</h2>
          </div>
          <a href="/platform-admin/support" class="text-sm font-semibold text-primary transition hover:underline">Open support ops</a>
        </div>
        <% if (queue.length) { %>
          <div class="mt-6 space-y-3">
            <% queue.forEach((conversation) => { %>
              <article class="rounded-3xl border border-slate-200 bg-white p-4">
                <p class="text-sm font-semibold text-slate-950"><%= conversation.subject %></p>
                <p class="mt-2 text-sm text-slate-500"><%= conversation.customer_name %> • <%= conversation.channel %></p>
              </article>
            <% }) %>
          </div>
        <% } else { %>
          <div class="mt-6 rounded-3xl border border-dashed border-slate-300 bg-slate-50 px-6 py-12 text-center">
            <p class="text-lg font-semibold text-slate-950">No active conversations</p>
            <p class="mt-2 text-sm leading-6 text-slate-500">Support queue visibility will appear here when customers reach out.</p>
          </div>
        <% } %>
      </section>
    </div>
  </div>
</section>
