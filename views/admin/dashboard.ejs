<%
  const currency = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' });
  const metrics = {
    totalProducts: stats && typeof stats.totalProducts !== 'undefined' ? stats.totalProducts : (Array.isArray(products) ? products.length : 0),
    totalOrders: stats && typeof stats.totalOrders !== 'undefined' ? stats.totalOrders : (Array.isArray(orders) ? orders.length : 0),
    revenue30d: stats && typeof stats.revenue30d !== 'undefined' ? stats.revenue30d : 0,
    customersCount: stats && typeof stats.customersCount !== 'undefined' ? stats.customersCount : 0
  };
  const recent = Array.isArray(recentOrders) ? recentOrders : (Array.isArray(orders) ? orders.slice(0, 5) : []);
  const statusClass = (status) => {
    switch ((status || '').toLowerCase()) {
      case 'delivered':
        return 'bg-emerald-50 text-emerald-600';
      case 'shipped':
        return 'bg-sky-50 text-sky-600';
      case 'pending':
      default:
        return 'bg-amber-50 text-amber-600';
    }
  };
%>
<section class="space-y-8">
  <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
    <article class="rounded-3xl border border-gray-200 bg-white p-6 shadow-sm">
      <p class="text-sm font-medium text-gray-500">Total products</p>
      <p class="mt-3 text-3xl font-semibold tracking-tight text-gray-900"><%= metrics.totalProducts %></p>
      <p class="mt-3 text-sm text-gray-500">Published and draft items across this store.</p>
    </article>
    <article class="rounded-3xl border border-gray-200 bg-white p-6 shadow-sm">
      <p class="text-sm font-medium text-gray-500">Total orders</p>
      <p class="mt-3 text-3xl font-semibold tracking-tight text-gray-900"><%= metrics.totalOrders %></p>
      <p class="mt-3 text-sm text-gray-500">All-time orders placed by your customers.</p>
    </article>
    <article class="rounded-3xl border border-gray-200 bg-white p-6 shadow-sm">
      <p class="text-sm font-medium text-gray-500">Revenue (30 days)</p>
      <p class="mt-3 text-3xl font-semibold tracking-tight text-gray-900"><%= currency.format(metrics.revenue30d || 0) %></p>
      <p class="mt-3 text-sm text-gray-500">Rolling monthly sales volume for quick tracking.</p>
    </article>
    <article class="rounded-3xl border border-gray-200 bg-white p-6 shadow-sm">
      <p class="text-sm font-medium text-gray-500">Customers</p>
      <p class="mt-3 text-3xl font-semibold tracking-tight text-gray-900"><%= metrics.customersCount %></p>
      <p class="mt-3 text-sm text-gray-500">Unique shoppers attached to this tenant.</p>
    </article>
  </div>

  <div class="grid gap-8 xl:grid-cols-[1.1fr_0.9fr]">
    <section class="rounded-[2rem] border border-gray-200 bg-white p-6 shadow-sm">
      <div class="flex items-center justify-between gap-4">
        <div>
          <p class="text-sm font-medium text-gray-500">Recent orders</p>
          <h2 class="mt-1 text-2xl font-semibold text-gray-900">Latest customer activity</h2>
        </div>
        <a href="/admin/orders" class="text-sm font-semibold text-primary transition hover:underline">View all orders</a>
      </div>

      <% if (recent.length) { %>
        <div class="mt-6 overflow-x-auto rounded-3xl border border-gray-200">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.2em] text-gray-500">Order</th>
                <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.2em] text-gray-500">Customer</th>
                <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.2em] text-gray-500">Date</th>
                <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.2em] text-gray-500">Total</th>
                <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.2em] text-gray-500">Status</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 bg-white">
              <% recent.forEach((entry) => { %>
                <tr class="transition hover:bg-gray-50">
                  <td class="whitespace-nowrap px-6 py-4 text-sm font-medium text-gray-900">#<%= entry.id %></td>
                  <td class="whitespace-nowrap px-6 py-4 text-sm text-gray-600"><%= entry.customer_name || (entry.customer && entry.customer.name) || 'Guest customer' %></td>
                  <td class="whitespace-nowrap px-6 py-4 text-sm text-gray-600"><%= entry.created_at ? new Date(entry.created_at).toLocaleDateString() : 'Today' %></td>
                  <td class="whitespace-nowrap px-6 py-4 text-sm text-gray-900"><%= currency.format(entry.total || 0) %></td>
                  <td class="whitespace-nowrap px-6 py-4">
                    <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold <%= statusClass(entry.status) %>"><%= entry.status || 'Pending' %></span>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="mt-6 rounded-3xl border border-dashed border-gray-300 bg-gray-50 px-6 py-12 text-center">
          <p class="text-lg font-semibold text-gray-900">No recent orders yet</p>
          <p class="mt-2 text-sm leading-6 text-gray-500">Orders will appear here once customers begin checking out from the storefront.</p>
        </div>
      <% } %>
    </section>

    <section class="rounded-[2rem] border border-gray-200 bg-white p-6 shadow-sm">
      <p class="text-sm font-medium text-gray-500">Store health</p>
      <h2 class="mt-1 text-2xl font-semibold text-gray-900">Quick operational checklist</h2>
      <div class="mt-6 space-y-4">
        <div class="rounded-3xl border border-gray-200 p-5">
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="text-sm font-semibold text-gray-900">Domain connected</p>
              <p class="mt-2 text-sm text-gray-500"><%= store && store.custom_domain ? store.custom_domain : `${store && store.subdomain ? store.subdomain : 'store'}.yoursaas.com` %></p>
            </div>
            <span class="inline-flex rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-600"><%= store && store.custom_domain ? 'Verified' : 'Subdomain only' %></span>
          </div>
        </div>
        <div class="rounded-3xl border border-gray-200 p-5">
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="text-sm font-semibold text-gray-900">Catalog readiness</p>
              <p class="mt-2 text-sm text-gray-500"><%= metrics.totalProducts ? `${metrics.totalProducts} products listed` : 'Add products to start selling' %></p>
            </div>
            <a href="/admin/products" class="text-sm font-semibold text-primary transition hover:underline">Manage</a>
          </div>
        </div>
        <div class="rounded-3xl border border-gray-200 p-5">
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="text-sm font-semibold text-gray-900">Brand styling</p>
              <p class="mt-2 text-sm text-gray-500">Theme color and logo can be updated at any time.</p>
            </div>
            <a href="/admin/settings" class="text-sm font-semibold text-primary transition hover:underline">Update</a>
          </div>
        </div>
      </div>
    </section>
  </div>
</section>
