<%
  const currency = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' });
  const productList = Array.isArray(products) ? products : [];
%>
<section class="space-y-8">
  <div class="flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary">Catalog</p>
      <h1 class="mt-2 text-3xl font-semibold tracking-tight text-gray-900">Products</h1>
      <p class="mt-3 max-w-2xl text-base leading-7 text-gray-600">Keep inventory, pricing, and publication status organized for this store in one place.</p>
    </div>
    <a href="/admin/products/new" class="inline-flex items-center justify-center rounded-2xl bg-primary px-5 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-primary-dark">
      Add Product
    </a>
  </div>

  <% if (productList.length) { %>
    <div class="overflow-x-auto rounded-[2rem] border border-gray-200 bg-white shadow-sm">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.2em] text-gray-500">Product</th>
            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.2em] text-gray-500">Price</th>
            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.2em] text-gray-500">Inventory</th>
            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.2em] text-gray-500">Status</th>
            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.2em] text-gray-500">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 bg-white">
          <% productList.forEach((product) => { %>
            <tr class="transition hover:bg-gray-50">
              <td class="px-6 py-4">
                <div class="flex items-center gap-4">
                  <img src="<%= product.image || 'https://placehold.co/96x96?text=Item' %>" alt="<%= product.name %>" class="h-14 w-14 rounded-2xl object-cover">
                  <div class="min-w-0">
                    <p class="truncate text-sm font-semibold text-gray-900"><%= product.name %></p>
                    <p class="mt-1 truncate text-sm text-gray-500"><%= product.sku || 'No SKU assigned' %></p>
                  </div>
                </div>
              </td>
              <td class="whitespace-nowrap px-6 py-4 text-sm text-gray-900">
                <div class="font-medium"><%= currency.format(product.price || 0) %></div>
                <% if (product.compare_at_price) { %>
                  <div class="text-xs text-gray-500 line-through"><%= currency.format(product.compare_at_price) %></div>
                <% } %>
              </td>
              <td class="whitespace-nowrap px-6 py-4 text-sm text-gray-600"><%= typeof product.inventory !== 'undefined' ? product.inventory : 0 %></td>
              <td class="whitespace-nowrap px-6 py-4">
                <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold <%= product.status === 'Published' || product.status === 'published' ? 'bg-emerald-50 text-emerald-600' : 'bg-gray-100 text-gray-600' %>">
                  <%= product.status || 'Draft' %>
                </span>
              </td>
              <td class="whitespace-nowrap px-6 py-4 text-sm">
                <div class="flex items-center gap-3">
                  <a href="/admin/products/<%= product.id %>/edit" class="font-semibold text-primary transition hover:underline">Edit</a>
                  <form action="/admin/products/<%= product.id %>/delete" method="post" class="inline">
                    <button type="submit" class="font-semibold text-red-500 transition hover:text-red-600">Delete</button>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } else { %>
    <div class="rounded-[2rem] border border-dashed border-gray-300 bg-white px-6 py-16 text-center shadow-sm">
      <span class="mx-auto inline-flex h-16 w-16 items-center justify-center rounded-3xl bg-primary-soft text-primary">
        <svg class="h-8 w-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
          <path d="M4.5 7.5h15v9.75A1.75 1.75 0 0 1 17.75 19H6.25A1.75 1.75 0 0 1 4.5 17.25V7.5Z" stroke-width="1.5" stroke-linejoin="round"></path>
          <path d="M8 7.5V6A1.5 1.5 0 0 1 9.5 4.5h5A1.5 1.5 0 0 1 16 6v1.5" stroke-width="1.5" stroke-linecap="round"></path>
        </svg>
      </span>
      <h2 class="mt-6 text-2xl font-semibold text-gray-900">No products yet</h2>
      <p class="mx-auto mt-3 max-w-xl text-base leading-7 text-gray-600">Add your first product to start shaping the storefront experience and make checkout possible.</p>
      <a href="/admin/products/new" class="mt-8 inline-flex items-center justify-center rounded-2xl bg-primary px-5 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-primary-dark">
        Add your first product
      </a>
    </div>
  <% } %>
</section>
