<%
  const editing = !!product;
  const productData = product || {};
  const formTarget = formAction || (editing ? `/admin/products/${productData.id}` : '/admin/products');
%>
<section class="space-y-8">
  <div class="flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary">Catalog</p>
      <h1 class="mt-2 text-3xl font-semibold tracking-tight text-gray-900"><%= editing ? 'Edit product' : 'Add product' %></h1>
      <p class="mt-3 max-w-2xl text-base leading-7 text-gray-600">Define product details clearly so the storefront and cart flows stay accurate across pricing, stock, and merchandising.</p>
    </div>
    <a href="/admin/products" class="inline-flex items-center justify-center rounded-2xl border border-gray-200 px-5 py-3 text-sm font-medium text-gray-700 transition hover:border-primary hover:text-primary">
      Cancel
    </a>
  </div>

  <form action="<%= formTarget %>" method="post" enctype="multipart/form-data" class="grid gap-8 xl:grid-cols-[1.15fr_0.85fr]">
    <% if (editing) { %>
      <input type="hidden" name="_method" value="PUT">
    <% } %>

    <div class="space-y-6 rounded-[2rem] border border-gray-200 bg-white p-6 shadow-sm">
      <div>
        <label for="name" class="mb-1 block text-sm font-medium text-gray-700">Name</label>
        <input id="name" name="name" type="text" value="<%= productData.name || '' %>" class="w-full rounded-2xl border border-gray-300 px-4 py-3 text-gray-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="Minimal Weekender Bag">
        <%- include('../partials/form-error', { field: 'name' }) %>
      </div>

      <div>
        <label for="description" class="mb-1 block text-sm font-medium text-gray-700">Description</label>
        <textarea id="description" name="description" rows="7" class="w-full rounded-2xl border border-gray-300 px-4 py-3 text-gray-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="Write a concise, shopper-friendly description..."><%= productData.description || '' %></textarea>
        <%- include('../partials/form-error', { field: 'description' }) %>
      </div>

      <div class="grid gap-5 sm:grid-cols-2">
        <div>
          <label for="price" class="mb-1 block text-sm font-medium text-gray-700">Price</label>
          <input id="price" name="price" type="number" min="0" step="0.01" value="<%= typeof productData.price !== 'undefined' ? productData.price : '' %>" class="w-full rounded-2xl border border-gray-300 px-4 py-3 text-gray-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="59.00">
          <%- include('../partials/form-error', { field: 'price' }) %>
        </div>
        <div>
          <label for="compareAtPrice" class="mb-1 block text-sm font-medium text-gray-700">Compare at Price</label>
          <input id="compareAtPrice" name="compare_at_price" type="number" min="0" step="0.01" value="<%= typeof productData.compare_at_price !== 'undefined' ? productData.compare_at_price : '' %>" class="w-full rounded-2xl border border-gray-300 px-4 py-3 text-gray-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="79.00">
          <%- include('../partials/form-error', { field: 'compare_at_price' }) %>
        </div>
        <div>
          <label for="sku" class="mb-1 block text-sm font-medium text-gray-700">SKU</label>
          <input id="sku" name="sku" type="text" value="<%= productData.sku || '' %>" class="w-full rounded-2xl border border-gray-300 px-4 py-3 text-gray-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="WKND-001">
          <%- include('../partials/form-error', { field: 'sku' }) %>
        </div>
        <div>
          <label for="inventory" class="mb-1 block text-sm font-medium text-gray-700">Inventory</label>
          <input id="inventory" name="inventory" type="number" min="0" step="1" value="<%= typeof productData.inventory !== 'undefined' ? productData.inventory : '' %>" class="w-full rounded-2xl border border-gray-300 px-4 py-3 text-gray-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="120">
          <%- include('../partials/form-error', { field: 'inventory' }) %>
        </div>
      </div>
    </div>

    <div class="space-y-6">
      <div class="rounded-[2rem] border border-gray-200 bg-white p-6 shadow-sm">
        <div class="flex items-start justify-between gap-4">
          <div>
            <h2 class="text-lg font-semibold text-gray-900">Media</h2>
            <p class="mt-2 text-sm leading-6 text-gray-500">This accepts files now, and the backend can later swap in an uploader or storage service.</p>
          </div>
        </div>
        <label for="images" class="mt-6 flex cursor-pointer flex-col items-center justify-center rounded-3xl border border-dashed border-gray-300 bg-gray-50 px-6 py-10 text-center transition hover:border-primary hover:bg-primary-soft">
          <svg class="h-10 w-10 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
            <path d="M12 16V8" stroke-width="1.5" stroke-linecap="round"></path>
            <path d="M9 11l3-3 3 3" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
            <rect x="4" y="4" width="16" height="16" rx="3" stroke-width="1.5"></rect>
          </svg>
          <span class="mt-4 text-sm font-semibold text-gray-900">Upload product images</span>
          <span class="mt-2 text-sm text-gray-500">PNG, JPG, or WEBP up to your backend upload limits</span>
          <input id="images" name="images" type="file" multiple class="sr-only">
        </label>
        <%- include('../partials/form-error', { field: 'images' }) %>
      </div>

      <div class="rounded-[2rem] border border-gray-200 bg-white p-6 shadow-sm">
        <div class="flex items-start justify-between gap-4">
          <div>
            <h2 class="text-lg font-semibold text-gray-900">Publication</h2>
            <p class="mt-2 text-sm leading-6 text-gray-500">Control whether the item is visible on the storefront immediately after saving.</p>
          </div>
          <label class="inline-flex cursor-pointer items-center gap-3 rounded-full bg-gray-100 px-4 py-2">
            <input name="status" type="checkbox" value="published" <%= productData.status === 'Published' || productData.status === 'published' || productData.status === true ? 'checked' : '' %> class="h-4 w-4 rounded border-gray-300 text-primary focus:ring-primary">
            <span class="text-sm font-medium text-gray-700">Published</span>
          </label>
        </div>
        <p class="mt-4 rounded-2xl bg-gray-50 px-4 py-3 text-sm text-gray-600">Draft products stay hidden until you are ready to publish them.</p>
      </div>

      <div class="flex flex-col gap-3 rounded-[2rem] border border-gray-200 bg-white p-6 shadow-sm sm:flex-row sm:justify-end">
        <a href="/admin/products" class="inline-flex items-center justify-center rounded-2xl border border-gray-200 px-4 py-3 text-sm font-medium text-gray-700 transition hover:border-primary hover:text-primary">
          Cancel
        </a>
        <button type="submit" class="inline-flex items-center justify-center rounded-2xl bg-primary px-5 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-primary-dark">
          Save
        </button>
      </div>
    </div>
  </form>
</section>
