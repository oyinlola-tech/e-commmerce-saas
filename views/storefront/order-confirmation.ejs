<%
  const currency = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' });
  const orderData = order || {};
  const confirmationItems = Array.isArray(orderData.items) ? orderData.items : [];
%>
<section class="mx-auto max-w-4xl px-4 py-12 sm:px-6 lg:px-8 lg:py-20">
  <div class="rounded-[2rem] border border-gray-200 bg-white p-8 shadow-soft sm:p-10">
    <div class="text-center">
      <span class="inline-flex h-16 w-16 items-center justify-center rounded-full bg-emerald-100 text-emerald-600">
        <svg class="h-8 w-8" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M16.704 5.29a1 1 0 010 1.42l-7.2 7.2a1 1 0 01-1.415 0l-3-3a1 1 0 111.414-1.42l2.293 2.294 6.493-6.494a1 1 0 011.415 0z" clip-rule="evenodd"></path>
        </svg>
      </span>
      <h1 class="mt-6 text-4xl font-semibold tracking-tight text-gray-900">Thank you, <%= customer && customer.name ? customer.name : 'Customer' %>!</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">Your order has been placed successfully and the store owner can now fulfill it from the admin dashboard.</p>
    </div>

    <div class="mt-10 grid gap-6 rounded-[2rem] bg-gray-50 p-6 sm:grid-cols-3">
      <div>
        <p class="text-sm font-medium text-gray-500">Order number</p>
        <p class="mt-2 text-lg font-semibold text-gray-900">#<%= orderData.id || '0000' %></p>
      </div>
      <div>
        <p class="text-sm font-medium text-gray-500">Estimated shipping</p>
        <p class="mt-2 text-lg font-semibold text-gray-900"><%= orderData.estimated_shipping || '3-5 business days' %></p>
      </div>
      <div>
        <p class="text-sm font-medium text-gray-500">Total</p>
        <p class="mt-2 text-lg font-semibold text-gray-900"><%= currency.format(orderData.total || 0) %></p>
      </div>
    </div>

    <div class="mt-10 space-y-4">
      <% confirmationItems.forEach((item) => { %>
        <article class="flex items-center gap-4 rounded-3xl border border-gray-200 p-4">
          <img src="<%= item.image || 'https://placehold.co/96x96?text=Item' %>" alt="<%= item.name %>" class="h-16 w-16 rounded-2xl object-cover">
          <div class="min-w-0 flex-1">
            <h2 class="truncate text-sm font-semibold text-gray-900"><%= item.name %></h2>
            <p class="mt-1 text-sm text-gray-500">Qty <%= item.quantity || 1 %></p>
          </div>
          <p class="text-sm font-semibold text-gray-900"><%= currency.format((item.price || 0) * (item.quantity || 1)) %></p>
        </article>
      <% }) %>
    </div>

    <div class="mt-10 flex flex-col gap-3 sm:flex-row sm:justify-center">
      <a href="/products" class="inline-flex items-center justify-center rounded-2xl border border-gray-200 px-5 py-3 text-sm font-medium text-gray-700 transition hover:border-primary hover:text-primary">
        Continue shopping
      </a>
      <a href="/" class="inline-flex items-center justify-center rounded-2xl bg-primary px-5 py-3 text-sm font-semibold text-white transition hover:bg-primary-dark">
        Back to home
      </a>
    </div>
  </div>
</section>
