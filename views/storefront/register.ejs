<section class="mx-auto flex max-w-7xl items-center justify-center px-4 py-12 sm:px-6 lg:px-8 lg:py-20">
  <div class="w-full max-w-lg rounded-[2rem] border border-gray-200 bg-white p-8 shadow-soft sm:p-10">
    <div class="text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary">Customer signup</p>
      <h1 class="mt-3 text-3xl font-semibold tracking-tight text-gray-900">Create your store account</h1>
      <p class="mt-3 text-base text-gray-600">Register on this store to save your details, track orders, and move through checkout faster next time.</p>
    </div>

    <form action="/register" method="post" class="mt-8 space-y-5">
      <div>
        <label for="name" class="mb-1 block text-sm font-medium text-gray-700">Name</label>
        <input id="name" name="name" type="text" value="<%= formData && formData.name ? formData.name : '' %>" class="w-full rounded-2xl border border-gray-300 px-4 py-3 text-gray-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="Jane Doe">
        <%- include('../partials/form-error', { field: 'name' }) %>
      </div>
      <div>
        <label for="email" class="mb-1 block text-sm font-medium text-gray-700">Email</label>
        <input id="email" name="email" type="email" value="<%= formData && formData.email ? formData.email : '' %>" class="w-full rounded-2xl border border-gray-300 px-4 py-3 text-gray-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="you@example.com">
        <%- include('../partials/form-error', { field: 'email' }) %>
      </div>
      <div class="grid gap-5 sm:grid-cols-2">
        <div>
          <label for="password" class="mb-1 block text-sm font-medium text-gray-700">Password</label>
          <input id="password" name="password" type="password" class="w-full rounded-2xl border border-gray-300 px-4 py-3 text-gray-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="Create a password">
          <%- include('../partials/form-error', { field: 'password' }) %>
        </div>
        <div>
          <label for="confirmPassword" class="mb-1 block text-sm font-medium text-gray-700">Confirm Password</label>
          <input id="confirmPassword" name="confirmPassword" type="password" class="w-full rounded-2xl border border-gray-300 px-4 py-3 text-gray-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="Confirm password">
          <%- include('../partials/form-error', { field: 'confirmPassword' }) %>
        </div>
      </div>
      <button type="submit" class="inline-flex w-full items-center justify-center rounded-2xl bg-primary px-4 py-3.5 text-base font-semibold text-white shadow-sm transition hover:bg-primary-dark">
        Register
      </button>
    </form>

    <p class="mt-6 text-center text-sm text-gray-600">
      Already have an account?
      <a href="/login" class="font-semibold text-primary transition hover:underline">Login</a>
    </p>
  </div>
</section>
