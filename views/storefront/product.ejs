<%
  const currency = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' });
  const productData = product || {};
  const gallery = Array.isArray(productData.images) && productData.images.length ? productData.images : [productData.image || 'https://placehold.co/900x900?text=Product'];
  const inStock = typeof productData.inventory === 'undefined' ? true : Number(productData.inventory) > 0;
%>
<section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
  <div class="grid gap-10 lg:grid-cols-[1fr_0.95fr]">
    <div class="space-y-4">
      <div class="overflow-hidden rounded-[2rem] border border-gray-200 bg-gray-100">
        <img src="<%= gallery[0] %>" alt="<%= productData.name %>" class="h-full w-full object-cover">
      </div>
      <div class="grid grid-cols-4 gap-3">
        <% gallery.slice(0, 4).forEach((image, index) => { %>
          <div class="overflow-hidden rounded-2xl border <%= index === 0 ? 'border-primary' : 'border-gray-200' %> bg-gray-100">
            <img src="<%= image %>" alt="<%= productData.name %> thumbnail <%= index + 1 %>" class="aspect-square h-full w-full object-cover">
          </div>
        <% }) %>
      </div>
    </div>

    <div class="space-y-8">
      <div class="space-y-4">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary">Product detail</p>
        <h1 class="text-4xl font-semibold tracking-tight text-gray-900"><%= productData.name || 'Untitled product' %></h1>
        <div class="flex items-center gap-3">
          <span class="text-3xl font-semibold text-gray-900"><%= currency.format(productData.price || 0) %></span>
          <% if (productData.compare_at_price) { %>
            <span class="text-lg text-gray-400 line-through"><%= currency.format(productData.compare_at_price) %></span>
          <% } %>
        </div>
        <p class="max-w-2xl text-base leading-8 text-gray-600"><%= productData.description || 'A well-crafted product page with enough detail to help shoppers move confidently to cart.' %></p>
      </div>

      <dl class="grid gap-4 sm:grid-cols-2">
        <div class="rounded-3xl border border-gray-200 bg-white p-5">
          <dt class="text-sm font-medium text-gray-500">SKU</dt>
          <dd class="mt-2 text-base font-semibold text-gray-900"><%= productData.sku || 'N/A' %></dd>
        </div>
        <div class="rounded-3xl border border-gray-200 bg-white p-5">
          <dt class="text-sm font-medium text-gray-500">Availability</dt>
          <dd class="mt-2">
            <span class="inline-flex rounded-full px-3 py-1 text-sm font-semibold <%= inStock ? 'bg-emerald-50 text-emerald-600' : 'bg-red-50 text-red-600' %>">
              <%= inStock ? 'In stock' : 'Out of stock' %>
            </span>
          </dd>
        </div>
      </dl>

      <div class="rounded-[2rem] border border-gray-200 bg-white p-6 shadow-sm">
        <div class="flex flex-col gap-5 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <p class="text-sm font-medium text-gray-500">Quantity</p>
            <div class="mt-3 inline-flex items-center rounded-full border border-gray-200 bg-white p-1">
              <button type="button" data-quantity-step="-1" data-quantity-target="#product-quantity" class="inline-flex h-11 w-11 items-center justify-center rounded-full text-gray-600 transition hover:bg-gray-100" aria-label="Decrease quantity">
                <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M4 10a1 1 0 011-1h10a1 1 0 110 2H5a1 1 0 01-1-1z" clip-rule="evenodd"></path></svg>
              </button>
              <input id="product-quantity" type="number" min="1" value="1" class="h-11 w-16 border-0 bg-transparent text-center text-base font-semibold text-gray-900 focus:outline-none focus:ring-0">
              <button type="button" data-quantity-step="1" data-quantity-target="#product-quantity" class="inline-flex h-11 w-11 items-center justify-center rounded-full text-gray-600 transition hover:bg-gray-100" aria-label="Increase quantity">
                <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M10 4a1 1 0 011 1v4h4a1 1 0 110 2h-4v4a1 1 0 11-2 0v-4H5a1 1 0 110-2h4V5a1 1 0 011-1z" clip-rule="evenodd"></path></svg>
              </button>
            </div>
          </div>
          <button type="button" data-add-to-cart="<%= productData.id %>" data-qty-target="#product-quantity" class="inline-flex items-center justify-center rounded-2xl bg-primary px-6 py-3.5 text-base font-semibold text-white shadow-sm transition hover:bg-primary-dark disabled:cursor-not-allowed disabled:opacity-50" <%= inStock ? '' : 'disabled' %>>
            <%= inStock ? 'Add to Cart' : 'Out of Stock' %>
          </button>
        </div>
        <% if (!inStock) { %>
          <p class="mt-4 text-sm text-red-500">This product is currently unavailable. Inventory updates will re-enable checkout automatically.</p>
        <% } %>
      </div>
    </div>
  </div>
</section>
