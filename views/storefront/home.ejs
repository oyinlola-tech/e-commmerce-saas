<%
  const currency = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' });
  const featured = Array.isArray(featuredProducts) ? featuredProducts : (Array.isArray(products) ? products.slice(0, 4) : []);
  const overview = stats || {};
%>
<section class="relative overflow-hidden">
  <div class="hero-orb hero-orb-primary left-0 top-4 h-64 w-64"></div>
  <div class="hero-orb hero-orb-sky right-0 top-10 h-72 w-72"></div>
  <div class="mx-auto grid max-w-7xl gap-12 px-4 py-14 sm:px-6 lg:grid-cols-[1.08fr_0.92fr] lg:px-8 lg:py-20">
    <div class="space-y-8">
      <span class="eyebrow">Curated for global customers</span>
      <div class="space-y-5">
        <h1 class="section-title max-w-4xl text-5xl font-semibold tracking-tight text-slate-950 sm:text-6xl">
          <%= store && store.name ? store.name : 'Aisle' %>
        </h1>
        <p class="max-w-2xl text-lg leading-8 text-slate-600">
          <%= store && store.tagline ? store.tagline : 'A premium storefront for modern essentials.' %>
        </p>
        <p class="max-w-2xl text-base leading-7 text-slate-500">
          <%= store && store.description ? store.description : 'Designed for product discovery, trustworthy service, and confident checkout across international markets.' %>
        </p>
      </div>
      <div class="flex flex-col gap-3 sm:flex-row">
        <a href="/products" class="inline-flex items-center justify-center rounded-2xl bg-primary px-6 py-3.5 text-base font-semibold text-white shadow-soft transition hover:bg-primary-dark">
          Shop the collection
        </a>
        <a href="/account" class="inline-flex items-center justify-center rounded-2xl border border-slate-200 bg-white px-6 py-3.5 text-base font-semibold text-slate-700 transition hover:border-primary hover:text-primary">
          My account
        </a>
      </div>
      <dl class="grid max-w-3xl grid-cols-1 gap-4 sm:grid-cols-4">
        <div class="metric-card rounded-3xl p-5">
          <dt class="text-sm font-medium text-slate-500">Products</dt>
          <dd class="metric-value mt-2 text-2xl font-semibold text-slate-950"><%= overview.publishedProducts || featured.length %></dd>
        </div>
        <div class="metric-card rounded-3xl p-5">
          <dt class="text-sm font-medium text-slate-500">Orders served</dt>
          <dd class="metric-value mt-2 text-2xl font-semibold text-slate-950"><%= overview.totalOrders || 0 %></dd>
        </div>
        <div class="metric-card rounded-3xl p-5">
          <dt class="text-sm font-medium text-slate-500">Markets</dt>
          <dd class="metric-value mt-2 text-2xl font-semibold text-slate-950"><%= store && store.markets ? store.markets.length : 1 %></dd>
        </div>
        <div class="metric-card rounded-3xl p-5">
          <dt class="text-sm font-medium text-slate-500">Return window</dt>
          <dd class="metric-value mt-2 text-2xl font-semibold text-slate-950"><%= store && store.return_window_days ? store.return_window_days : 30 %>d</dd>
        </div>
      </dl>
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      <% featured.slice(0, 2).forEach((item, index) => { %>
        <article class="surface-card overflow-hidden rounded-[2rem] <%= index === 0 ? 'sm:translate-y-8' : '' %>">
          <a href="/products/<%= item.slug %>" class="block aspect-[4/5] overflow-hidden bg-slate-100">
            <img src="<%= item.image %>" alt="<%= item.name %>" class="h-full w-full object-cover transition duration-300 hover:scale-105">
          </a>
          <div class="p-5">
            <p class="text-sm text-slate-500"><%= item.category || 'Featured product' %></p>
            <h2 class="section-title mt-2 text-xl font-semibold text-slate-950"><%= item.name %></h2>
            <p class="mt-2 text-sm text-slate-600"><%= currency.format(item.price || 0) %></p>
          </div>
        </article>
      <% }) %>
    </div>
  </div>
</section>

<section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
  <div class="grid gap-6 lg:grid-cols-3">
    <article class="surface-card rounded-[2rem] p-6">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary">Service</p>
      <h2 class="section-title mt-3 text-2xl font-semibold text-slate-950">Support that feels human</h2>
      <p class="mt-3 text-base leading-7 text-slate-600">Every order is backed by responsive support, clear fulfillment windows, and account-level visibility into your purchases.</p>
    </article>
    <article class="surface-card rounded-[2rem] p-6">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary">Fulfillment</p>
      <h2 class="section-title mt-3 text-2xl font-semibold text-slate-950">International by default</h2>
      <p class="mt-3 text-base leading-7 text-slate-600">Messaging, service promises, and product content are structured for customers buying from multiple markets and time zones.</p>
    </article>
    <article class="surface-card rounded-[2rem] p-6">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary">Confidence</p>
      <h2 class="section-title mt-3 text-2xl font-semibold text-slate-950">A calm, premium flow</h2>
      <p class="mt-3 text-base leading-7 text-slate-600">From catalog browsing to account management, the experience is built to feel polished, clear, and trustworthy.</p>
    </article>
  </div>
</section>

<section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-20">
  <div class="flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary">Featured collection</p>
      <h2 class="section-title mt-3 text-4xl font-semibold tracking-tight text-slate-950">Best-sellers customers trust first</h2>
    </div>
    <a href="/products" class="text-sm font-semibold text-primary transition hover:underline">View full catalog</a>
  </div>

  <% if (featured.length) { %>
    <div class="mt-10 grid grid-cols-1 gap-5 sm:grid-cols-2 xl:grid-cols-4">
      <% featured.forEach((product) => { %>
        <article class="surface-card lift-on-hover group overflow-hidden rounded-[2rem]">
          <a href="/products/<%= product.slug %>" class="block aspect-[4/4.2] overflow-hidden bg-slate-100">
            <img src="<%= product.image %>" alt="<%= product.name %>" class="h-full w-full object-cover transition duration-300 group-hover:scale-105">
          </a>
          <div class="space-y-4 p-5">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400"><%= product.category || 'Collection' %></p>
              <a href="/products/<%= product.slug %>" class="mt-2 block text-lg font-semibold text-slate-950 transition hover:text-primary"><%= product.name %></a>
              <div class="mt-3 flex items-center gap-2">
                <span class="text-base font-semibold text-slate-950"><%= currency.format(product.price || 0) %></span>
                <% if (product.compare_at_price) { %>
                  <span class="text-sm text-slate-400 line-through"><%= currency.format(product.compare_at_price) %></span>
                <% } %>
              </div>
            </div>
            <button type="button" data-add-to-cart="<%= product.id %>" data-quantity="1" class="inline-flex w-full items-center justify-center rounded-2xl bg-primary px-4 py-3 text-sm font-semibold text-white transition hover:bg-primary-dark">
              Add to cart
            </button>
          </div>
        </article>
      <% }) %>
    </div>
  <% } else { %>
    <div class="surface-card mt-10 rounded-[2rem] px-6 py-16 text-center">
      <h2 class="section-title text-2xl font-semibold text-slate-950">Collection coming soon</h2>
      <p class="mx-auto mt-3 max-w-xl text-base leading-7 text-slate-600">Featured products will appear here as soon as the catalog is published.</p>
    </div>
  <% } %>
</section>
