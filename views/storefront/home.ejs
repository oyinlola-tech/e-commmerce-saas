<%
  const currency = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' });
  const featured = Array.isArray(featuredProducts) ? featuredProducts : (Array.isArray(products) ? products.slice(0, 4) : []);
%>
<section class="relative overflow-hidden border-b border-gray-100 bg-gray-50">
  <div class="absolute inset-x-0 top-0 -z-10 h-full bg-gradient-to-br from-primary/10 via-white to-sky-50"></div>
  <div class="mx-auto grid max-w-7xl gap-12 px-4 py-14 sm:px-6 lg:grid-cols-[1.05fr_0.95fr] lg:px-8 lg:py-20">
    <div class="space-y-8">
      <span class="inline-flex items-center gap-2 rounded-full border border-primary-soft bg-primary-soft px-4 py-2 text-sm font-medium text-primary">
        <span class="inline-flex h-2.5 w-2.5 rounded-full bg-primary"></span>
        Curated by <%= store && store.name ? store.name : 'your brand' %>
      </span>
      <div class="space-y-5">
        <h1 class="max-w-3xl text-4xl font-semibold tracking-tight text-gray-900 sm:text-5xl">
          <%= store && store.name ? store.name : 'Your Store' %>
        </h1>
        <p class="max-w-2xl text-lg leading-8 text-gray-600">
          <%= store && store.tagline ? store.tagline : 'A clean, conversion-focused storefront that makes it easy for customers to discover your products and check out confidently.' %>
        </p>
      </div>
      <div class="flex flex-col gap-3 sm:flex-row">
        <a href="/products" class="inline-flex items-center justify-center rounded-2xl bg-primary px-6 py-3.5 text-base font-semibold text-white shadow-sm transition hover:bg-primary-dark">
          Shop Now
        </a>
        <a href="/products" class="inline-flex items-center justify-center rounded-2xl border border-gray-200 bg-white px-6 py-3.5 text-base font-semibold text-gray-700 transition hover:border-primary hover:text-primary">
          Browse products
        </a>
      </div>
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      <% (featured.length ? featured.slice(0, 2) : [null, null]).forEach((item, index) => { %>
        <article class="overflow-hidden rounded-[2rem] border border-gray-200 bg-white shadow-sm <%= index === 0 ? 'sm:translate-y-8' : '' %>">
          <div class="aspect-[4/5] bg-gray-100">
            <% if (item) { %>
              <img src="<%= item.image || 'https://placehold.co/640x800?text=Featured+Product' %>" alt="<%= item.name %>" class="h-full w-full object-cover">
            <% } else { %>
              <div class="flex h-full items-center justify-center text-sm font-medium text-gray-400">Featured collection preview</div>
            <% } %>
          </div>
          <div class="p-5">
            <p class="text-sm text-gray-500"><%= item ? 'Featured product' : 'Coming soon' %></p>
            <h2 class="mt-2 text-lg font-semibold text-gray-900"><%= item ? item.name : 'Next drop loading' %></h2>
            <p class="mt-2 text-sm text-gray-600"><%= item ? currency.format(item.price || 0) : 'New arrivals will appear here.' %></p>
          </div>
        </article>
      <% }) %>
    </div>
  </div>
</section>

<section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-20">
  <div class="flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary">Featured products</p>
      <h2 class="mt-2 text-3xl font-semibold tracking-tight text-gray-900">What shoppers should see first</h2>
    </div>
    <a href="/products" class="text-sm font-semibold text-primary transition hover:underline">View all products</a>
  </div>

  <% if (featured.length) { %>
    <div class="mt-10 grid grid-cols-2 gap-4 md:grid-cols-3 xl:grid-cols-4">
      <% featured.forEach((product) => { %>
        <article class="group overflow-hidden rounded-[2rem] border border-gray-200 bg-white shadow-sm transition duration-200 hover:-translate-y-1 hover:shadow-soft">
          <a href="/products/<%= product.slug %>" class="block aspect-square overflow-hidden bg-gray-100">
            <img src="<%= product.image || 'https://placehold.co/640x640?text=Product' %>" alt="<%= product.name %>" class="h-full w-full object-cover transition duration-300 group-hover:scale-105">
          </a>
          <div class="space-y-4 p-4">
            <div>
              <a href="/products/<%= product.slug %>" class="line-clamp-2 text-base font-semibold text-gray-900 transition hover:text-primary"><%= product.name %></a>
              <div class="mt-2 flex items-center gap-2">
                <span class="text-base font-semibold text-gray-900"><%= currency.format(product.price || 0) %></span>
                <% if (product.compare_at_price) { %>
                  <span class="text-sm text-gray-400 line-through"><%= currency.format(product.compare_at_price) %></span>
                <% } %>
              </div>
            </div>
            <button type="button" data-add-to-cart="<%= product.id %>" data-quantity="1" class="inline-flex w-full items-center justify-center rounded-2xl bg-primary px-4 py-3 text-sm font-semibold text-white transition hover:bg-primary-dark">
              Add to cart
            </button>
          </div>
        </article>
      <% }) %>
    </div>
  <% } else { %>
    <div class="mt-10 rounded-[2rem] border border-dashed border-gray-300 bg-gray-50 px-6 py-16 text-center">
      <h2 class="text-2xl font-semibold text-gray-900">Coming soon</h2>
      <p class="mx-auto mt-3 max-w-xl text-base leading-7 text-gray-600">Featured products will appear here once the store owner begins publishing the catalog.</p>
    </div>
  <% } %>
</section>
