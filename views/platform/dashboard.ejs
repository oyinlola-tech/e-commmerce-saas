<%
  const ownerStores = Array.isArray(stores) ? stores : [];
%>
<section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
  <div class="flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary">Owner dashboard</p>
      <h1 class="mt-3 text-3xl font-semibold tracking-tight text-gray-900 sm:text-4xl">Manage your stores</h1>
      <p class="mt-3 max-w-2xl text-base leading-7 text-gray-600">
        Jump into a storefront admin, monitor which brands are live, or spin up a new tenant with a clean subdomain in a few clicks.
      </p>
    </div>
    <button type="button" data-modal-open="create-store-modal" class="inline-flex items-center justify-center rounded-2xl bg-primary px-5 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-primary-dark focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2">
      Create New Store
    </button>
  </div>

  <% if (ownerStores.length) { %>
    <div class="mt-10 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      <% ownerStores.forEach((entry) => { %>
        <article class="rounded-3xl border border-gray-200 bg-white p-6 shadow-sm">
          <div class="flex items-start justify-between gap-4">
            <div class="flex min-w-0 items-center gap-4">
              <% if (entry.logo) { %>
                <img src="<%= entry.logo %>" alt="<%= entry.name %> logo" class="h-14 w-14 rounded-2xl object-cover">
              <% } else { %>
                <span class="inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-primary-soft text-lg font-semibold text-primary"><%= entry.name ? entry.name.charAt(0).toUpperCase() : 'S' %></span>
              <% } %>
              <div class="min-w-0">
                <h2 class="truncate text-xl font-semibold text-gray-900"><%= entry.name %></h2>
                <p class="mt-1 truncate text-sm text-gray-500"><%= entry.subdomain %>.yoursaas.com</p>
              </div>
            </div>
            <span class="inline-flex items-center rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-600">Live</span>
          </div>
          <div class="mt-6 rounded-2xl bg-gray-50 p-4">
            <p class="text-xs uppercase tracking-[0.2em] text-gray-400">Tenant ID</p>
            <p class="mt-2 text-sm font-medium text-gray-700"><%= entry.id %></p>
          </div>
          <div class="mt-6 flex items-center justify-between gap-3">
            <a href="/stores/<%= entry.id %>/manage" class="inline-flex items-center justify-center rounded-2xl border border-gray-200 px-4 py-2.5 text-sm font-medium text-gray-700 transition hover:border-primary hover:text-primary">
              Manage
            </a>
            <a href="/stores/<%= entry.id %>/manage" class="text-sm font-medium text-primary transition hover:underline">Open admin</a>
          </div>
        </article>
      <% }) %>
    </div>
  <% } else { %>
    <div class="mt-10 rounded-[2rem] border border-dashed border-gray-300 bg-white px-6 py-16 text-center shadow-sm">
      <span class="mx-auto inline-flex h-16 w-16 items-center justify-center rounded-3xl bg-primary-soft text-primary">
        <svg class="h-8 w-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
          <path d="M4 6.5h16V18a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6.5Z" stroke-width="1.5" stroke-linejoin="round"></path>
          <path d="M9 3h6" stroke-width="1.5" stroke-linecap="round"></path>
          <path d="M12 10v5" stroke-width="1.5" stroke-linecap="round"></path>
          <path d="M9.5 12.5H14.5" stroke-width="1.5" stroke-linecap="round"></path>
        </svg>
      </span>
      <h2 class="mt-6 text-2xl font-semibold text-gray-900">No stores yet</h2>
      <p class="mx-auto mt-3 max-w-xl text-base leading-7 text-gray-600">
        Create your first store to unlock the admin dashboard, product publishing workflow, and customer-facing storefront.
      </p>
      <button type="button" data-modal-open="create-store-modal" class="mt-8 inline-flex items-center justify-center rounded-2xl bg-primary px-5 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-primary-dark">
        Create your first store
      </button>
    </div>
  <% } %>
</section>

<div id="create-store-modal" data-modal-backdrop="create-store-modal" aria-hidden="true" class="fixed inset-0 z-[65] hidden items-center justify-center bg-gray-950/60 px-4 py-8 backdrop-blur-sm">
  <div class="w-full max-w-lg rounded-[2rem] bg-white p-8 shadow-2xl">
    <div class="flex items-start justify-between gap-4">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary">New tenant</p>
        <h2 class="mt-2 text-2xl font-semibold text-gray-900">Create a new store</h2>
        <p class="mt-3 text-sm leading-6 text-gray-600">Pick a memorable brand name and subdomain. The backend can handle uniqueness and availability checks on submit.</p>
      </div>
      <button type="button" data-modal-close="create-store-modal" class="inline-flex h-10 w-10 items-center justify-center rounded-2xl border border-gray-200 text-gray-600 transition hover:border-primary hover:text-primary" aria-label="Close modal">
        <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path>
        </svg>
      </button>
    </div>

    <form action="/stores" method="post" class="mt-8 space-y-5">
      <div>
        <label for="storeName" class="mb-1 block text-sm font-medium text-gray-700">Store Name</label>
        <input id="storeName" data-auto-slug-source data-auto-slug-target="#storeSubdomain" name="name" type="text" class="w-full rounded-2xl border border-gray-300 px-4 py-3 text-gray-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="Northline Studio">
      </div>
      <div>
        <label for="storeSubdomain" class="mb-1 block text-sm font-medium text-gray-700">Subdomain</label>
        <div class="flex overflow-hidden rounded-2xl border border-gray-300 shadow-sm focus-within:border-primary focus-within:ring-2 focus-within:ring-primary/20">
          <input id="storeSubdomain" name="subdomain" type="text" class="min-w-0 flex-1 border-0 px-4 py-3 text-gray-900 focus:outline-none focus:ring-0" placeholder="northline-studio">
          <span class="inline-flex items-center border-l border-gray-200 bg-gray-50 px-4 text-sm font-medium text-gray-500">.yoursaas.com</span>
        </div>
      </div>
      <div class="flex flex-col-reverse gap-3 pt-2 sm:flex-row sm:justify-end">
        <button type="button" data-modal-close="create-store-modal" class="inline-flex items-center justify-center rounded-2xl border border-gray-200 px-4 py-3 text-sm font-medium text-gray-700 transition hover:border-primary hover:text-primary">
          Cancel
        </button>
        <button type="submit" class="inline-flex items-center justify-center rounded-2xl bg-primary px-5 py-3 text-sm font-semibold text-white transition hover:bg-primary-dark">
          Create Store
        </button>
      </div>
    </form>
  </div>
</div>
