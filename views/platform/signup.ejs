<section class="mx-auto flex max-w-7xl items-center justify-center px-4 py-12 sm:px-6 lg:px-8 lg:py-20">
  <div class="grid w-full max-w-5xl gap-10 overflow-hidden rounded-[2rem] border border-gray-200 bg-white shadow-soft lg:grid-cols-[0.95fr_1.05fr]">
    <div class="bg-gray-950 px-8 py-10 text-white sm:px-10 sm:py-12">
      <span class="inline-flex rounded-full bg-white/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.24em] text-primary-light">Start selling</span>
      <h1 class="mt-6 text-3xl font-semibold tracking-tight sm:text-4xl">Create your MultiStore account</h1>
      <p class="mt-4 text-base leading-7 text-gray-300">
        Spin up your first tenant, invite your team later, and get a polished storefront live without wrestling the frontend from scratch.
      </p>
      <div class="mt-10 space-y-4">
        <div class="rounded-2xl bg-white/5 p-4">
          <p class="text-sm font-medium text-white">Fast setup</p>
          <p class="mt-2 text-sm text-gray-300">Create your owner account, launch your first store, and start listing products in minutes.</p>
        </div>
        <div class="rounded-2xl bg-white/5 p-4">
          <p class="text-sm font-medium text-white">Clean admin UX</p>
          <p class="mt-2 text-sm text-gray-300">Everything from inventory to orders is designed around clear workflows and mobile-friendly controls.</p>
        </div>
      </div>
    </div>

    <div class="px-8 py-10 sm:px-10 sm:py-12">
      <div class="max-w-md">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary">Owner signup</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight text-gray-900">Start your free trial</h2>
        <p class="mt-3 text-base text-gray-600">Already have an account? <a href="/login" class="font-semibold text-primary transition hover:underline">Sign in</a></p>
      </div>

      <form action="/signup" method="post" class="mt-8 space-y-5">
        <div>
          <label for="fullName" class="mb-1 block text-sm font-medium text-gray-700">Full Name</label>
          <input id="fullName" name="name" type="text" value="<%= formData && formData.name ? formData.name : '' %>" class="w-full rounded-2xl border border-gray-300 px-4 py-3 text-gray-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="Ada Lovelace">
          <%- include('../partials/form-error', { field: 'name' }) %>
        </div>
        <div>
          <label for="email" class="mb-1 block text-sm font-medium text-gray-700">Email</label>
          <input id="email" name="email" type="email" value="<%= formData && formData.email ? formData.email : '' %>" class="w-full rounded-2xl border border-gray-300 px-4 py-3 text-gray-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="you@example.com">
          <%- include('../partials/form-error', { field: 'email' }) %>
        </div>
        <div>
          <label for="password" class="mb-1 block text-sm font-medium text-gray-700">Password</label>
          <input id="password" name="password" type="password" class="w-full rounded-2xl border border-gray-300 px-4 py-3 text-gray-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="Create a secure password">
          <%- include('../partials/form-error', { field: 'password' }) %>
        </div>
        <div>
          <label for="confirmPassword" class="mb-1 block text-sm font-medium text-gray-700">Confirm Password</label>
          <input id="confirmPassword" name="confirmPassword" type="password" class="w-full rounded-2xl border border-gray-300 px-4 py-3 text-gray-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="Confirm your password">
          <%- include('../partials/form-error', { field: 'confirmPassword' }) %>
        </div>
        <button type="submit" class="inline-flex w-full items-center justify-center rounded-2xl bg-primary px-4 py-3.5 text-base font-semibold text-white shadow-sm transition hover:bg-primary-dark focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2">
          Create Account
        </button>
      </form>
    </div>
  </div>
</section>
