<%
  const tenantList = Array.isArray(stores) ? stores : [];
  const currency = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });
  const launchBadge = (status) => {
    switch ((status || '').toLowerCase()) {
      case 'pilot':
        return 'bg-sky-50 text-sky-700';
      case 'setup':
        return 'bg-amber-50 text-amber-700';
      case 'live':
      default:
        return 'bg-emerald-50 text-emerald-700';
    }
  };
%>
<section class="space-y-8">
  <div class="max-w-3xl">
    <span class="eyebrow">Tenant Directory</span>
    <h1 class="section-title mt-5 text-4xl font-semibold tracking-tight text-slate-950">Monitor every storefront like it matters, because it does.</h1>
    <p class="mt-4 text-lg leading-8 text-slate-600">
      Review commercial health, switch operational posture, and jump into any tenant workspace without losing global context.
    </p>
  </div>

  <div class="space-y-5">
    <% tenantList.forEach((store) => { %>
      <article class="surface-card rounded-[2rem] p-6">
        <div class="flex flex-col gap-6 xl:flex-row xl:items-start xl:justify-between">
          <div class="min-w-0 flex-1">
            <div class="flex flex-wrap items-center gap-3">
              <h2 class="text-2xl font-semibold text-slate-950"><%= store.name %></h2>
              <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] <%= launchBadge(store.launch_status) %>"><%= store.launch_status %></span>
            </div>
            <p class="mt-3 max-w-3xl text-base leading-7 text-slate-600"><%= store.description %></p>
            <div class="mt-5 grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
              <div class="rounded-2xl bg-slate-50 p-4">
                <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Markets</p>
                <p class="mt-2 text-sm font-semibold text-slate-900"><%= (store.markets || []).join(', ') %></p>
              </div>
              <div class="rounded-2xl bg-slate-50 p-4">
                <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Monthly revenue</p>
                <p class="mt-2 text-sm font-semibold text-slate-900"><%= currency.format(store.monthly_revenue || 0) %></p>
              </div>
              <div class="rounded-2xl bg-slate-50 p-4">
                <p class="text-xs uppercase tracking-[0.2em] text-slate-400">AOV</p>
                <p class="mt-2 text-sm font-semibold text-slate-900"><%= currency.format(store.average_order_value || 0) %></p>
              </div>
              <div class="rounded-2xl bg-slate-50 p-4">
                <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Health score</p>
                <p class="mt-2 text-sm font-semibold text-slate-900"><%= store.health_score || 0 %>/100</p>
              </div>
            </div>
          </div>

          <div class="w-full max-w-xl rounded-[1.75rem] border border-slate-200 bg-white p-5">
            <p class="text-sm font-semibold text-slate-900">Operational controls</p>
            <form action="/platform-admin/stores/<%= store.id %>/status" method="post" class="mt-5 space-y-4">
              <div class="grid gap-4 sm:grid-cols-2">
                <div>
                  <label for="launch-<%= store.id %>" class="mb-1 block text-sm font-medium text-slate-700">Launch status</label>
                  <select id="launch-<%= store.id %>" name="launch_status" class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20">
                    <% ['live', 'pilot', 'setup'].forEach((entry) => { %>
                      <option value="<%= entry %>" <%= store.launch_status === entry ? 'selected' : '' %>><%= entry.charAt(0).toUpperCase() + entry.slice(1) %></option>
                    <% }) %>
                  </select>
                </div>
                <div>
                  <label for="ops-<%= store.id %>" class="mb-1 block text-sm font-medium text-slate-700">Operational status</label>
                  <select id="ops-<%= store.id %>" name="operational_status" class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20">
                    <% ['healthy', 'watch', 'attention'].forEach((entry) => { %>
                      <option value="<%= entry %>" <%= store.operational_status === entry ? 'selected' : '' %>><%= entry.charAt(0).toUpperCase() + entry.slice(1) %></option>
                    <% }) %>
                  </select>
                </div>
              </div>
              <div class="flex flex-wrap gap-3">
                <button type="submit" class="inline-flex items-center justify-center rounded-2xl bg-primary px-5 py-3 text-sm font-semibold text-white transition hover:bg-primary-dark">Save status</button>
                <a href="/stores/<%= store.id %>/manage" class="inline-flex items-center justify-center rounded-2xl border border-slate-200 px-5 py-3 text-sm font-medium text-slate-700 transition hover:border-primary hover:text-primary">Open admin</a>
                <a href="/stores/<%= store.id %>/preview" class="inline-flex items-center justify-center rounded-2xl border border-slate-200 px-5 py-3 text-sm font-medium text-slate-700 transition hover:border-primary hover:text-primary">Storefront</a>
              </div>
            </form>
          </div>
        </div>
      </article>
    <% }) %>
  </div>
</section>
