<%
  const availableCurrencies = Array.isArray(currencyOptions) ? currencyOptions : [];
%>
<div class="flex flex-col gap-4 border-b border-slate-200/70 bg-white/80 px-4 py-4 backdrop-blur sm:px-6 lg:flex-row lg:items-center lg:justify-between lg:px-8">
  <div class="flex items-center gap-4">
    <button type="button" data-admin-sidebar-toggle class="inline-flex h-11 w-11 items-center justify-center rounded-2xl border border-slate-200 text-slate-700 lg:hidden" aria-label="Open sidebar">
      <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M3 5a1 1 0 011-1h12a1 1 0 110 2H4A1 1 0 013 5zm0 5a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm1 4a1 1 0 100 2h12a1 1 0 100-2H4z" clip-rule="evenodd"></path>
      </svg>
    </button>
    <div>
      <p class="text-sm font-medium text-slate-500">Global operations</p>
      <h1 class="section-title text-2xl font-semibold tracking-tight text-slate-950">Platform Control Center</h1>
    </div>
  </div>

  <div class="flex flex-wrap items-center gap-3">
    <% if (availableCurrencies.length > 1) { %>
      <form action="/preferences/currency" method="post" class="flex items-center gap-2 rounded-2xl border border-slate-200 bg-white px-3 py-3 text-sm text-slate-600 shadow-sm">
        <input type="hidden" name="returnTo" value="<%= currentUrl || currentPath || '/platform-admin' %>">
        <label for="platform-admin-currency" class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Currency</label>
        <select id="platform-admin-currency" name="code" onchange="this.form.submit()" class="border-0 bg-transparent pr-6 text-sm font-medium text-slate-700 focus:outline-none focus:ring-0">
          <% availableCurrencies.forEach((entry) => { %>
            <option value="<%= entry.code %>" <%= selectedCurrency === entry.code ? 'selected' : '' %>><%= entry.code %></option>
          <% }) %>
        </select>
      </form>
    <% } %>
    <span class="signal-chip text-slate-700">
      <span class="signal-dot"></span>
      Coverage across <%= platformBrand && Array.isArray(platformBrand.marketsServed) ? platformBrand.marketsServed.length : 4 %> regions
    </span>
    <div class="rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-600 shadow-sm">
      <span class="block text-xs uppercase tracking-[0.22em] text-slate-400">Admin email</span>
      <span class="mt-1 block font-medium text-slate-900"><%= systemAdminUser && systemAdminUser.email ? systemAdminUser.email : 'control@aislecommerce.com' %></span>
    </div>
  </div>
</div>
