# Shared monorepo environment
NODE_ENV=development
LOG_LEVEL=info

# Domains and public entrypoints
PLATFORM_ROOT_DOMAIN=localhost
APP_ROOT_DOMAIN=localhost
WEB_APP_URL=http://127.0.0.1:3000
GATEWAY_URL=http://127.0.0.1:4000
SWAGGER_PORT=4015

# Shared secrets
JWT_SECRET=replace-with-a-64-char-random-hex-string
JWT_ACCESS_TTL=1h
INTERNAL_SHARED_SECRET=replace-with-a-64-char-random-hex-string
COOKIE_SECRET=replace-with-a-64-char-random-hex-string
CSRF_SECRET=replace-with-a-64-char-random-hex-string

# Cookies and request protection
COOKIE_SECURE=false
COOKIE_DOMAIN=
COOKIE_SAMESITE=lax
INTERNAL_REQUEST_MAX_AGE_MS=300000
INTERNAL_REQUEST_NONCE_TTL_MS=300000

# Infrastructure
RABBITMQ_URL=amqp://127.0.0.1:5672
REDIS_URL=redis://127.0.0.1:6379
DISABLE_REDIS=false
EVENT_EXCHANGE=aisle.events

# Shared performance defaults
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
MUTATION_RATE_LIMIT_WINDOW_MS=600000
MUTATION_RATE_LIMIT_MAX=60
DATABASE_READ_URLS=
DB_POOL_MIN=2
DB_POOL_MAX=12
DB_IDLE_TIMEOUT_MS=60000
DB_ACQUIRE_TIMEOUT_MS=10000
DB_CONNECT_RETRIES=5
DB_CONNECT_RETRY_DELAY_MS=1000
REQUEST_TIMEOUT_MS=5000
BACKEND_REQUEST_TIMEOUT_MS=5000
EXTERNAL_API_TIMEOUT_MS=2500
PAGE_CACHE_TTL_SECONDS=60
STATIC_ASSET_CACHE_SECONDS=3600

# Storage and app features
STORE_LOGO_UPLOAD_DIR=uploads/logos

# Public app rate limits
# These defaults are intentionally strict. Relax them only if real traffic needs it.
WEB_PORT=3000
WEB_RATE_LIMIT_WINDOW_MS=60000
WEB_RATE_LIMIT_MAX=180
WEB_AUTH_RATE_LIMIT_WINDOW_MS=900000
WEB_AUTH_RATE_LIMIT_MAX=5
WEB_AUTH_PAGE_RATE_LIMIT_WINDOW_MS=900000
WEB_AUTH_PAGE_RATE_LIMIT_MAX=20
WEB_MUTATION_RATE_LIMIT_WINDOW_MS=600000
WEB_MUTATION_RATE_LIMIT_MAX=45

GATEWAY_PORT=4000
GATEWAY_RATE_LIMIT_WINDOW_MS=60000
GATEWAY_RATE_LIMIT_MAX=90
GATEWAY_AUTH_RATE_LIMIT_WINDOW_MS=900000
GATEWAY_AUTH_RATE_LIMIT_MAX=5
GATEWAY_MUTATION_RATE_LIMIT_WINDOW_MS=600000
GATEWAY_MUTATION_RATE_LIMIT_MAX=30

# External APIs
IP_GEOLOCATION_API_BASE=https://ipapi.co
FX_RATES_API_BASE=https://api.frankfurter.dev/v1
SUBSCRIPTION_DEFAULT_CURRENCY=NGN
PASSWORD_RESET_OTP_TTL_MINUTES=15

# Platform admin bootstrap
PLATFORM_ADMIN_NAME=Platform Admin
PLATFORM_ADMIN_EMAIL=admin@localhost
PLATFORM_ADMIN_PASSWORD=ChangeMe123!

# SMTP / notification delivery
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false
SMTP_FROM_NAME=Aisle
SMTP_FROM_EMAIL=

# Platform subscription billing keys only
# Store owners should add storefront provider keys in the admin settings UI.
# Only public keys are sent back to the browser; secret keys stay server-side.
PAYSTACK_PLATFORM_PUBLIC_KEY=
PAYSTACK_PLATFORM_SECRET_KEY=
FLUTTERWAVE_PLATFORM_PUBLIC_KEY=
FLUTTERWAVE_PLATFORM_SECRET_KEY=

# Internal service discovery
USER_SERVICE_URL=http://127.0.0.1:4101
STORE_SERVICE_URL=http://127.0.0.1:4102
COMPLIANCE_SERVICE_URL=http://127.0.0.1:4103
CUSTOMER_SERVICE_URL=http://127.0.0.1:4104
PRODUCT_SERVICE_URL=http://127.0.0.1:4105
CART_SERVICE_URL=http://127.0.0.1:4106
ORDER_SERVICE_URL=http://127.0.0.1:4107
PAYMENT_SERVICE_URL=http://127.0.0.1:4108
BILLING_SERVICE_URL=http://127.0.0.1:4109
SUPPORT_SERVICE_URL=http://127.0.0.1:4110
CHAT_SERVICE_URL=http://127.0.0.1:4111
NOTIFICATION_SERVICE_URL=http://127.0.0.1:4112

# Service ports
USER_SERVICE_PORT=4101
STORE_SERVICE_PORT=4102
COMPLIANCE_SERVICE_PORT=4103
CUSTOMER_SERVICE_PORT=4104
PRODUCT_SERVICE_PORT=4105
CART_SERVICE_PORT=4106
ORDER_SERVICE_PORT=4107
PAYMENT_SERVICE_PORT=4108
BILLING_SERVICE_PORT=4109
SUPPORT_SERVICE_PORT=4110
CHAT_SERVICE_PORT=4111
NOTIFICATION_SERVICE_PORT=4112

# Per-service database credentials
GATEWAY_DATABASE_HOST=127.0.0.1
GATEWAY_DATABASE_PORT=3306
GATEWAY_DATABASE_USER=root
GATEWAY_DATABASE_PASSWORD=password
GATEWAY_DATABASE_NAME=gateway_db

