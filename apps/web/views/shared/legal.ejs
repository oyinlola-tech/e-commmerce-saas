<%
  const page = legalPage || {};
  const highlights = Array.isArray(page.highlights) ? page.highlights : [];
  const facts = Array.isArray(page.facts) ? page.facts : [];
  const sections = Array.isArray(page.sections) ? page.sections : [];
%>
<section class="legal-page-shell relative overflow-hidden">
  <div class="hero-orb hero-orb-primary left-0 top-10 h-72 w-72"></div>
  <div class="hero-orb hero-orb-sky right-0 top-16 h-72 w-72"></div>
  <div class="platform-section-shell">
    <div class="legal-page-hero surface-card">
      <div class="legal-hero-grid">
        <div class="space-y-5">
          <div class="flex flex-wrap items-center gap-3">
            <span class="eyebrow"><%= page.audienceLabel || 'Legal information' %></span>
            <% if (page.lastUpdated) { %>
              <span class="signal-chip">
                <span class="signal-dot"></span>
                Last updated <%= page.lastUpdated %>
              </span>
            <% } %>
          </div>

          <% if (page.badge) { %>
            <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary"><%= page.badge %></p>
          <% } %>

          <div class="space-y-4">
            <h1 class="section-title text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl"><%= page.title || 'Legal page' %></h1>
            <% if (page.metaDescription) { %>
              <p class="max-w-3xl text-lg leading-8 text-slate-600"><%= page.metaDescription %></p>
            <% } %>
          </div>
        </div>

        <aside class="legal-summary-panel">
          <% if (page.noticeLabel) { %>
            <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary"><%= page.noticeLabel %></p>
          <% } %>
          <% if (page.notice) { %>
            <p class="mt-3 text-base leading-7 text-slate-600"><%= page.notice %></p>
          <% } %>

          <% if (facts.length) { %>
            <div class="theme-divider mt-6"></div>
            <div class="mt-6">
              <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary"><%= page.factsTitle || 'Quick facts' %></p>
              <dl class="legal-facts mt-4">
                <% facts.slice(0, 4).forEach((fact) => { %>
                  <div class="legal-fact-item">
                    <dt><%= fact.label %></dt>
                    <dd><%= fact.value %></dd>
                  </div>
                <% }) %>
              </dl>
            </div>
          <% } %>
        </aside>
      </div>
    </div>

    <% if (highlights.length) { %>
      <div class="legal-highlights-grid mt-6">
        <% highlights.forEach((item) => { %>
          <article class="platform-proof-card rounded-[1.6rem] p-5">
            <h2 class="section-title text-2xl font-semibold text-slate-950"><%= item.title %></h2>
            <p class="mt-3 text-base leading-7 text-slate-600"><%= item.body %></p>
          </article>
        <% }) %>
      </div>
    <% } %>

    <div class="legal-content-grid mt-6">
      <aside class="legal-sidebar theme-panel p-6">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary"><%= page.tocTitle || 'Contents' %></p>
        <nav class="legal-toc mt-4">
          <% sections.forEach((section, index) => { %>
            <a href="#<%= section.id %>">
              <span><%= String(index + 1).padStart(2, '0') %></span>
              <span><%= section.title %></span>
            </a>
          <% }) %>
        </nav>
      </aside>

      <div class="space-y-4">
        <% sections.forEach((section, index) => { %>
          <article id="<%= section.id %>" class="legal-section-card theme-panel p-6 sm:p-8">
            <div class="legal-section-header">
              <span class="legal-section-number"><%= String(index + 1).padStart(2, '0') %></span>
              <div>
                <h2 class="section-title text-3xl font-semibold text-slate-950"><%= section.title %></h2>
                <% if (section.summary) { %>
                  <p class="mt-3 text-base leading-7 text-slate-600"><%= section.summary %></p>
                <% } %>
              </div>
            </div>

            <% if (Array.isArray(section.paragraphs) && section.paragraphs.length) { %>
              <div class="legal-rich-text mt-5">
                <% section.paragraphs.forEach((paragraph) => { %>
                  <p><%= paragraph %></p>
                <% }) %>
              </div>
            <% } %>

            <% if (Array.isArray(section.bullets) && section.bullets.length) { %>
              <ul class="legal-list mt-5">
                <% section.bullets.forEach((bullet) => { %>
                  <li><%= bullet %></li>
                <% }) %>
              </ul>
            <% } %>
          </article>
        <% }) %>
      </div>
    </div>
  </div>
</section>
