<%
  const storeBrand = unsubscribeStore || null;
  const accentColor = storeBrand && storeBrand.theme_color ? storeBrand.theme_color : '#0F766E';
  const brandName = storeBrand && storeBrand.name
    ? storeBrand.name
    : (platformBrand && platformBrand.platformName ? platformBrand.platformName : 'Aisle');
  const customerName = unsubscribeCustomer && unsubscribeCustomer.name ? unsubscribeCustomer.name : 'there';
%>

<section class="relative overflow-hidden bg-slate-950 text-white">
  <div class="absolute inset-0 opacity-30" style="background: radial-gradient(circle at top, <%= accentColor %>55 0%, rgba(2,6,23,0) 55%);"></div>
  <div class="relative mx-auto max-w-6xl px-6 py-20 sm:px-8">
    <div class="max-w-3xl">
      <p class="text-xs font-semibold uppercase tracking-[0.32em]" style="color:<%= accentColor %>;">Email preferences</p>
      <h1 class="mt-6 text-4xl font-semibold tracking-tight sm:text-5xl"><%= unsubscribeSucceeded ? 'You have been unsubscribed' : 'We could not update your preference' %></h1>
      <p class="mt-6 max-w-2xl text-base leading-8 text-slate-300 sm:text-lg">
        <%= unsubscribeSucceeded
          ? `${customerName}, you will no longer receive monthly marketing product emails from ${brandName}.`
          : 'The unsubscribe link could not be processed. It may be invalid or expired.' %>
      </p>
    </div>
  </div>
</section>

<section class="bg-slate-50 py-16">
  <div class="mx-auto grid max-w-6xl gap-8 px-6 sm:px-8 lg:grid-cols-[minmax(0,1.2fr)_minmax(320px,0.8fr)]">
    <article class="rounded-[2rem] border border-slate-200 bg-white p-8 shadow-sm">
      <% if (unsubscribeSucceeded) { %>
        <div class="inline-flex rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.26em]" style="background-color:<%= accentColor %>14; color:<%= accentColor %>;">Preference updated</div>
        <h2 class="mt-6 text-2xl font-semibold text-slate-950">Monthly campaigns are now off</h2>
        <p class="mt-4 text-sm leading-7 text-slate-600">
          <%= unsubscribeAlreadyUnsubscribed
            ? 'This address was already removed from the monthly marketing list, so no further action was needed.'
            : 'This email address has been removed from this store’s monthly product marketing list.' %>
        </p>
        <p class="mt-4 text-sm leading-7 text-slate-600">
          You may still receive important service emails about your account, orders, payments, and security.
        </p>
      <% } else { %>
        <div class="inline-flex rounded-full bg-rose-50 px-4 py-2 text-xs font-semibold uppercase tracking-[0.26em] text-rose-700">Link unavailable</div>
        <h2 class="mt-6 text-2xl font-semibold text-slate-950">Try again from the latest email</h2>
        <p class="mt-4 text-sm leading-7 text-slate-600">
          Open the most recent marketing email and use the unsubscribe button again. If the problem keeps happening, contact the store directly for help.
        </p>
      <% } %>

      <div class="mt-8 flex flex-wrap gap-3">
        <% if (unsubscribeStorefrontUrl) { %>
          <a
            href="<%= unsubscribeStorefrontUrl %>"
            class="inline-flex items-center justify-center rounded-full px-5 py-3 text-sm font-semibold text-white transition hover:opacity-90"
            style="background-color:<%= accentColor %>;"
          >Visit <%= brandName %></a>
        <% } %>
        <a href="/" class="inline-flex items-center justify-center rounded-full border border-slate-200 px-5 py-3 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:text-slate-950">Return home</a>
      </div>
    </article>

    <aside class="rounded-[2rem] border border-slate-200 bg-white p-8 shadow-sm">
      <div class="flex items-center gap-4">
        <% if (storeBrand && storeBrand.logo_url) { %>
          <img src="<%= storeBrand.logo_url %>" alt="<%= brandName %> logo" class="h-16 w-16 rounded-2xl object-cover">
        <% } else { %>
          <div class="flex h-16 w-16 items-center justify-center rounded-2xl text-xl font-semibold text-white" style="background-color:<%= accentColor %>;">
            <%= brandName.slice(0, 1).toUpperCase() %>
          </div>
        <% } %>
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Store</p>
          <h3 class="mt-2 text-xl font-semibold text-slate-950"><%= brandName %></h3>
          <% if (unsubscribeCustomer && unsubscribeCustomer.email) { %>
            <p class="mt-2 text-sm text-slate-500"><%= unsubscribeCustomer.email %></p>
          <% } %>
        </div>
      </div>

      <div class="mt-8 rounded-[1.5rem] border border-slate-200 bg-slate-50 p-6">
        <p class="text-sm font-semibold text-slate-950">What changes now</p>
        <ul class="mt-4 space-y-3 text-sm leading-7 text-slate-600">
          <li>Monthly product roundups stop for this email address.</li>
          <li>Order, account, and security emails still continue when needed.</li>
          <li>You can always shop the store directly whenever you want.</li>
        </ul>
      </div>
    </aside>
  </div>
</section>
