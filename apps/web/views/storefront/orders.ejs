<%
  const money = typeof formatMoney === 'function' ? formatMoney : ((value) => value);
  const orders = Array.isArray(customerOrders) ? customerOrders : [];
%>
<section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
  <div class="max-w-3xl">
    <span class="eyebrow">My Orders</span>
    <h1 class="section-title mt-5 text-4xl font-semibold tracking-tight text-slate-950">Track every purchase in one place</h1>
    <p class="mt-4 text-lg leading-8 text-slate-600">Review totals, fulfillment status, and the items tied to each order.</p>
  </div>

  <% if (orders.length) { %>
    <div class="mt-10 space-y-5">
      <% orders.forEach((order) => { %>
        <article class="surface-card rounded-[2rem] p-6">
          <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
            <div>
              <h2 class="text-xl font-semibold text-slate-950">Order #<%= order.id %></h2>
              <p class="mt-2 text-sm text-slate-500"><%= new Date(order.created_at).toLocaleString() %></p>
            </div>
            <div class="text-left sm:text-right">
              <span class="inline-flex rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-slate-700"><%= order.status %></span>
              <p class="mt-3 text-lg font-semibold text-slate-950"><%= money(order.total || 0) %></p>
            </div>
          </div>
          <div class="mt-6 space-y-3">
            <% (order.items || []).forEach((item) => { %>
              <div class="flex items-center gap-4 rounded-2xl bg-slate-50 p-4">
                <img src="<%= item.image %>" alt="<%= item.name %>" loading="lazy" class="h-14 w-14 rounded-2xl object-cover">
                <div class="min-w-0 flex-1">
                  <p class="truncate text-sm font-semibold text-slate-900"><%= item.name %></p>
                  <p class="mt-1 text-sm text-slate-500">Qty <%= item.quantity || 1 %></p>
                </div>
                <p class="text-sm font-semibold text-slate-900"><%= money((item.price || 0) * (item.quantity || 1)) %></p>
              </div>
            <% }) %>
          </div>
        </article>
      <% }) %>
    </div>
  <% } else { %>
    <div class="surface-card mt-10 rounded-[2rem] px-6 py-16 text-center">
      <h2 class="section-title text-2xl font-semibold text-slate-950">No orders yet</h2>
      <p class="mx-auto mt-3 max-w-xl text-base leading-7 text-slate-600">Your order history will show up here after your first successful purchase.</p>
      <a href="/products" class="mt-8 inline-flex items-center justify-center rounded-2xl bg-primary px-5 py-3 text-sm font-semibold text-white shadow-soft transition hover:bg-primary-dark">
        Start shopping
      </a>
    </div>
  <% } %>
</section>
