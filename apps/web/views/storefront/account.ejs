<%
  const money = typeof formatMoney === 'function' ? formatMoney : ((value) => value);
  const orders = Array.isArray(customerOrders) ? customerOrders : [];
  const customerData = customer || {};
  const wishlistItems = Array.isArray(wishlistProducts) ? wishlistProducts : [];
  const recentlyViewed = Array.isArray(recentlyViewedProducts) ? recentlyViewedProducts : [];
%>
<section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
  <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr]">
    <aside class="surface-card rounded-[2rem] p-6">
      <span class="eyebrow">My Account</span>
      <h1 class="section-title mt-5 text-3xl font-semibold tracking-tight text-slate-950"><%= customerData.name || 'Customer' %></h1>
      <div class="mt-6 grid gap-3 sm:grid-cols-3">
        <div class="rounded-2xl bg-slate-50 p-4">
          <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Orders</p>
          <p class="mt-2 text-lg font-semibold text-slate-900"><%= orders.length %></p>
        </div>
        <div class="rounded-2xl bg-slate-50 p-4">
          <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Wishlist</p>
          <p class="mt-2 text-lg font-semibold text-slate-900"><%= wishlistItems.length %></p>
        </div>
        <div class="rounded-2xl bg-slate-50 p-4">
          <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Recently viewed</p>
          <p class="mt-2 text-lg font-semibold text-slate-900"><%= recentlyViewed.length %></p>
        </div>
      </div>
      <div class="mt-6 space-y-4 text-sm text-slate-600">
        <div class="rounded-2xl bg-slate-50 p-4">
          <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Email</p>
          <p class="mt-2 font-semibold text-slate-900"><%= customerData.email || 'No email on file' %></p>
        </div>
        <div class="rounded-2xl bg-slate-50 p-4">
          <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Address</p>
          <p class="mt-2 leading-6 text-slate-700"><%= [customerData.address, customerData.city, customerData.country, customerData.postal_code].filter(Boolean).join(', ') || 'No address saved yet' %></p>
        </div>
      </div>
    </aside>

    <section class="surface-card rounded-[2rem] p-6">
      <div class="flex items-center justify-between gap-4">
        <div>
          <p class="text-sm font-medium text-slate-500">Order history</p>
          <h2 class="section-title mt-1 text-2xl font-semibold text-slate-950">Recent purchases</h2>
        </div>
        <a href="/orders" class="text-sm font-semibold text-primary transition hover:underline">View all orders</a>
      </div>
      <% if (orders.length) { %>
        <div class="mt-6 space-y-4">
          <% orders.slice(0, 4).forEach((order) => { %>
            <article class="rounded-3xl border border-slate-200 bg-white p-5">
              <div class="flex items-center justify-between gap-4">
                <div>
                  <p class="text-sm font-semibold text-slate-900">Order #<%= order.id %></p>
                  <p class="mt-1 text-sm text-slate-500"><%= new Date(order.created_at).toLocaleString() %></p>
                </div>
                <span class="inline-flex rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-slate-700"><%= order.status %></span>
              </div>
            </article>
          <% }) %>
        </div>
      <% } else { %>
        <div class="mt-6 rounded-3xl border border-dashed border-slate-300 bg-slate-50 px-6 py-12 text-center">
          <p class="text-lg font-semibold text-slate-950">No orders yet</p>
          <p class="mt-2 text-sm leading-6 text-slate-500">Once you complete checkout, your order history will appear here.</p>
        </div>
      <% } %>
    </section>
  </div>

  <% if (recentlyViewed.length || wishlistItems.length) { %>
    <div class="mt-10 grid gap-8 xl:grid-cols-2">
      <% if (recentlyViewed.length) { %>
        <section class="surface-card rounded-[2rem] p-6">
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="text-sm font-medium text-slate-500">Recently viewed</p>
              <h2 class="section-title mt-1 text-2xl font-semibold text-slate-950">Continue exploring</h2>
            </div>
            <a href="/products" class="text-sm font-semibold text-primary transition hover:underline">Browse all</a>
          </div>
          <div class="mt-6 grid gap-4 sm:grid-cols-2">
            <% recentlyViewed.slice(0, 4).forEach((product) => { %>
              <article class="rounded-[1.75rem] border border-slate-200 bg-white p-4">
                <a href="/products/<%= product.slug %>" class="flex items-center gap-4">
                  <img src="<%= product.image %>" alt="<%= product.name %>" loading="lazy" class="h-16 w-16 rounded-2xl object-cover">
                  <div class="min-w-0">
                    <p class="truncate text-sm font-semibold text-slate-900"><%= product.name %></p>
                    <p class="mt-1 text-sm text-slate-500"><%= product.category %></p>
                  </div>
                </a>
              </article>
            <% }) %>
          </div>
        </section>
      <% } %>

      <% if (wishlistItems.length) { %>
        <section class="surface-card rounded-[2rem] p-6">
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="text-sm font-medium text-slate-500">Saved items</p>
              <h2 class="section-title mt-1 text-2xl font-semibold text-slate-950">Wishlist shortcuts</h2>
            </div>
            <a href="/wishlist" class="text-sm font-semibold text-primary transition hover:underline">Open wishlist</a>
          </div>
          <div class="mt-6 grid gap-4 sm:grid-cols-2">
            <% wishlistItems.slice(0, 4).forEach((product) => { %>
              <article class="rounded-[1.75rem] border border-slate-200 bg-white p-4">
                <a href="/products/<%= product.slug %>" class="flex items-center gap-4">
                  <img src="<%= product.image %>" alt="<%= product.name %>" loading="lazy" class="h-16 w-16 rounded-2xl object-cover">
                  <div class="min-w-0">
                    <p class="truncate text-sm font-semibold text-slate-900"><%= product.name %></p>
                    <p class="mt-1 text-sm text-slate-500"><%= money(product.price || 0) %></p>
                  </div>
                </a>
              </article>
            <% }) %>
          </div>
        </section>
      <% } %>
    </div>
  <% } %>
</section>
