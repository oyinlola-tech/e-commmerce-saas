<%
  const money = typeof formatMoney === 'function' ? formatMoney : ((value) => value);
  const featured = Array.isArray(featuredProducts) ? featuredProducts : (Array.isArray(products) ? products.slice(0, 4) : []);
  const spotlightProducts = Array.isArray(featured) ? featured.slice(0, 3) : [];
  const overview = stats || {};
  const storeThemeData = typeof storeTheme !== 'undefined'
    ? storeTheme
    : (typeof currentStoreTheme !== 'undefined' ? currentStoreTheme : {});
  const themeClasses = storeThemeData.classes || {};
  const themeCopy = storeThemeData.copy || {};
  const themeTags = Array.isArray(storeThemeData.marketingTags) ? storeThemeData.marketingTags : [];
  const themeFeatureCards = Array.isArray(storeThemeData.featureCards) ? storeThemeData.featureCards : [];
  const shoppingBenefits = Array.isArray(storeThemeData.shoppingBenefits) ? storeThemeData.shoppingBenefits : [];
  const discoveryCollections = Array.isArray(storeThemeData.discoveryCollections) ? storeThemeData.discoveryCollections : [];
  const categoryList = Array.isArray(categories) ? categories : [];
  const discoveryTagList = Array.isArray(discoveryTags) ? discoveryTags : [];
  const recentlyViewed = Array.isArray(recentlyViewedProducts) ? recentlyViewedProducts : [];
  const heroEyebrow = store && store.hero_eyebrow ? store.hero_eyebrow : (themeCopy.eyebrow || 'Curated storefront');
  const heroTitle = store && store.hero_title ? store.hero_title : (themeCopy.heroTitle || (store && store.tagline ? store.tagline : 'A premium storefront for modern essentials.'));
  const heroDescription = store && store.hero_description ? store.hero_description : (themeCopy.heroBody || (store && store.description ? store.description : 'Designed for product discovery, trustworthy service, and confident checkout across international markets.'));
  const heroSupport = store && store.hero_support ? store.hero_support : (themeCopy.heroSupport || (store && store.fulfillment_sla ? store.fulfillment_sla : 'Fast fulfillment available.'));
  const primaryCtaText = store && store.primary_cta_text ? store.primary_cta_text : (themeCopy.primaryCta || 'Shop the collection');
  const secondaryCtaText = store && store.secondary_cta_text ? store.secondary_cta_text : (themeCopy.secondaryCta || 'My account');
  const featuredCollectionTitle = store && store.featured_collection_title ? store.featured_collection_title : (themeCopy.catalogTitle || 'Best-sellers customers trust first');
  const featuredCollectionDescription = store && store.featured_collection_description ? store.featured_collection_description : (themeCopy.catalogBody || 'Thoughtfully merchandised products with clearer storytelling, faster scanning, and a premium path from browse to checkout.');
  const heroMetrics = [
    { label: 'Products live', value: overview.publishedProducts || featured.length || 0 },
    { label: 'Orders served', value: overview.totalOrders || 0 },
    { label: 'Markets', value: store && Array.isArray(store.markets) ? store.markets.length : 1 },
    { label: 'Returns window', value: `${store && store.return_window_days ? store.return_window_days : 30}d` }
  ];
%>
<section class="relative overflow-hidden">
  <div class="hero-orb hero-orb-primary left-0 top-4 h-64 w-64"></div>
  <div class="hero-orb hero-orb-sky right-0 top-10 h-72 w-72"></div>
  <div class="mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8 lg:py-20">
    <div class="grid gap-10 <%= themeClasses.heroGrid || 'lg:grid-cols-[1.04fr_0.96fr]' %>">
      <div class="space-y-8">
        <div class="flex flex-wrap gap-3">
          <span class="eyebrow"><%= heroEyebrow %></span>
          <% themeTags.slice(0, 2).forEach((tag) => { %>
            <span class="theme-chip"><%= tag %></span>
          <% }) %>
        </div>

        <div class="space-y-5">
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary"><%= storeThemeData.label || 'Storefront template' %></p>
          <h1 class="section-title max-w-4xl text-5xl font-semibold tracking-tight text-slate-950 sm:text-6xl">
            <%= store && store.name ? store.name : 'Aisle' %>
          </h1>
          <p class="max-w-3xl text-2xl leading-tight text-slate-900"><%= heroTitle %></p>
          <p class="max-w-2xl text-lg leading-8 text-slate-600"><%= heroDescription %></p>
          <p class="max-w-2xl text-sm leading-7 text-slate-500"><%= heroSupport %></p>
        </div>

        <div class="flex flex-col gap-3 sm:flex-row">
          <a href="/products" class="inline-flex items-center justify-center rounded-2xl bg-primary px-6 py-3.5 text-base font-semibold text-white shadow-soft transition hover:bg-primary-dark">
            <%= primaryCtaText %>
          </a>
          <a href="/account" class="inline-flex items-center justify-center rounded-2xl border border-slate-200 bg-white px-6 py-3.5 text-base font-semibold text-slate-700 transition hover:border-primary hover:text-primary">
            <%= secondaryCtaText %>
          </a>
        </div>

        <dl class="grid max-w-3xl grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4">
          <% heroMetrics.forEach((metric) => { %>
            <div class="theme-stat rounded-[1.75rem] p-5">
              <dt class="text-sm font-medium text-slate-500"><%= metric.label %></dt>
              <dd class="metric-value mt-2 text-2xl font-semibold text-slate-950"><%= metric.value %></dd>
            </div>
          <% }) %>
        </dl>
      </div>

      <div class="theme-hero-frame p-5 sm:p-6">
        <% if (spotlightProducts.length) { %>
          <div class="grid gap-4 <%= themeClasses.heroMediaGrid || 'sm:grid-cols-2' %>">
            <% spotlightProducts.forEach((item, index) => { %>
              <article class="theme-product-card overflow-hidden rounded-[2rem] <%= index === 0 && spotlightProducts.length > 1 ? 'sm:translate-y-8' : '' %>">
                <a href="/products/<%= item.slug %>" class="theme-hero-media block <%= themeClasses.heroCardAspect || 'aspect-[4/5]' %> overflow-hidden bg-slate-100">
                  <img src="<%= item.image %>" alt="<%= item.name %>" loading="lazy" class="h-full w-full object-cover transition duration-300 hover:scale-105">
                </a>
                <div class="space-y-2 p-5">
                  <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400"><%= item.category || storeThemeData.storeTypeLabel || storeThemeData.typeLabel || 'Featured' %></p>
                  <h2 class="section-title text-xl font-semibold text-slate-950"><%= item.name %></h2>
                  <div class="flex items-center gap-2">
                    <span class="text-base font-semibold text-slate-950"><%= money(item.price || 0) %></span>
                    <% if (item.compare_at_price) { %>
                      <span class="text-sm text-slate-400 line-through"><%= money(item.compare_at_price) %></span>
                    <% } %>
                  </div>
                </div>
              </article>
            <% }) %>
          </div>
        <% } else { %>
          <div class="theme-panel theme-panel-soft flex min-h-[26rem] flex-col items-center justify-center rounded-[2rem] px-6 py-12 text-center">
            <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary"><%= storeThemeData.storeTypeLabel || storeThemeData.typeLabel || 'Store category' %></p>
            <h2 class="section-title mt-4 text-3xl font-semibold text-slate-950">Catalog preview coming soon</h2>
            <p class="mt-3 max-w-md text-base leading-7 text-slate-600">Publish products to fill this hero stack with your category-specific cards, imagery, and merchandising rhythm.</p>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</section>

<section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
  <div class="grid gap-6 <%= themeClasses.featureGrid || 'lg:grid-cols-3' %>">
    <% themeFeatureCards.forEach((card) => { %>
      <article class="theme-panel rounded-[2rem] p-6">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary"><%= card.label %></p>
        <h2 class="section-title mt-3 text-2xl font-semibold text-slate-950"><%= card.title %></h2>
        <p class="mt-3 text-base leading-7 text-slate-600"><%= card.body %></p>
      </article>
    <% }) %>
  </div>
</section>

<% if (categoryList.length || discoveryTagList.length) { %>
  <section class="mx-auto max-w-7xl px-4 py-4 sm:px-6 lg:px-8 lg:py-8">
    <div class="grid gap-6 lg:grid-cols-[0.84fr_1.16fr]">
      <div class="theme-panel rounded-[2rem] p-6">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary">Shop by category</p>
        <div class="mt-4 flex flex-wrap gap-3">
          <% categoryList.slice(0, 8).forEach((category) => { %>
            <a href="/products?category=<%= encodeURIComponent(category.slug || category.name) %>" class="inline-flex items-center rounded-full border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-primary hover:text-primary">
              <%= category.name || category.slug %>
            </a>
          <% }) %>
        </div>
      </div>
      <div class="theme-panel rounded-[2rem] p-6">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary">Fast discovery</p>
        <div class="mt-4 flex flex-wrap gap-3">
          <% discoveryTagList.slice(0, 8).forEach((entry) => { %>
            <a href="/products?tag=<%= encodeURIComponent(entry.slug || entry.name) %>" class="inline-flex items-center rounded-full border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-primary hover:text-primary">
              <%= entry.name || entry.slug %>
            </a>
          <% }) %>
        </div>
      </div>
    </div>
  </section>
<% } %>

<% if (shoppingBenefits.length) { %>
  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
    <div class="grid gap-6 lg:grid-cols-3">
      <% shoppingBenefits.forEach((item) => { %>
        <article class="theme-panel rounded-[2rem] p-6">
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary"><%= item.label %></p>
          <h2 class="section-title mt-3 text-2xl font-semibold text-slate-950"><%= item.title %></h2>
          <p class="mt-3 text-base leading-7 text-slate-600"><%= item.body %></p>
        </article>
      <% }) %>
    </div>
  </section>
<% } %>

<% if (discoveryCollections.length) { %>
  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary">Curated pathways</p>
        <h2 class="section-title mt-3 text-4xl font-semibold tracking-tight text-slate-950">Merchandising built around how customers actually shop</h2>
      </div>
      <p class="max-w-2xl text-base leading-7 text-slate-600">These pathways borrow the strongest marketplace and DTC patterns: fast scanning, visible trust, and clearer routes back to favorites and replenishment.</p>
    </div>
    <div class="mt-8 grid gap-5 lg:grid-cols-3">
      <% discoveryCollections.forEach((item) => { %>
        <% const href = item.category ? `/products?category=${encodeURIComponent(item.category)}` : (item.tag ? `/products?tag=${encodeURIComponent(item.tag)}` : '/products'); %>
        <a href="<%= href %>" class="theme-product-card block rounded-[2rem] p-6 transition hover:-translate-y-1">
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary"><%= item.label %></p>
          <h3 class="section-title mt-3 text-2xl font-semibold text-slate-950"><%= item.title %></h3>
          <p class="mt-3 text-base leading-7 text-slate-600"><%= item.body %></p>
        </a>
      <% }) %>
    </div>
  </section>
<% } %>

<section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-20">
  <div class="grid gap-6 <%= themeClasses.catalogHeader || 'lg:grid-cols-[0.82fr_1.18fr] lg:items-end' %>">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary"><%= themeCopy.catalogLabel || 'Featured collection' %></p>
      <h2 class="section-title mt-3 text-4xl font-semibold tracking-tight text-slate-950"><%= featuredCollectionTitle %></h2>
    </div>
    <div class="theme-accent-note rounded-[2rem] px-6 py-5">
      <p class="text-sm leading-7 text-slate-600"><%= featuredCollectionDescription %></p>
    </div>
  </div>

  <% if (featured.length) { %>
    <div class="mt-10 grid grid-cols-1 gap-5 <%= themeClasses.catalogGrid || 'sm:grid-cols-2 xl:grid-cols-4' %>">
      <% featured.forEach((product) => { %>
        <article class="theme-product-card lift-on-hover group overflow-hidden rounded-[2rem]">
          <a href="/products/<%= product.slug %>" class="block <%= themeClasses.catalogCardAspect || 'aspect-[4/5]' %> overflow-hidden bg-slate-100">
            <img src="<%= product.image %>" alt="<%= product.name %>" loading="lazy" class="h-full w-full object-cover transition duration-300 group-hover:scale-105">
          </a>
          <div class="space-y-4 p-5">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400"><%= product.category || storeThemeData.storeTypeLabel || storeThemeData.typeLabel || 'Collection' %></p>
              <a href="/products/<%= product.slug %>" class="mt-2 block text-lg font-semibold text-slate-950 transition hover:text-primary"><%= product.name %></a>
              <div class="mt-3 flex items-center gap-2">
                <span class="text-base font-semibold text-slate-950"><%= money(product.price || 0) %></span>
                <% if (product.compare_at_price) { %>
                  <span class="text-sm text-slate-400 line-through"><%= money(product.compare_at_price) %></span>
                <% } %>
              </div>
            </div>
            <button type="button" data-add-to-cart="<%= product.id %>" data-quantity="1" class="inline-flex w-full items-center justify-center rounded-2xl bg-primary px-4 py-3 text-sm font-semibold text-white transition hover:bg-primary-dark">
              Add to cart
            </button>
          </div>
        </article>
      <% }) %>
    </div>
  <% } else { %>
    <div class="theme-panel mt-10 rounded-[2rem] px-6 py-16 text-center">
      <h2 class="section-title text-2xl font-semibold text-slate-950">Collection coming soon</h2>
      <p class="mx-auto mt-3 max-w-xl text-base leading-7 text-slate-600">Featured products will appear here as soon as the catalog is published.</p>
    </div>
  <% } %>
</section>

<% if (recentlyViewed.length) { %>
  <section class="mx-auto max-w-7xl px-4 pb-12 sm:px-6 lg:px-8 lg:pb-20">
    <div class="flex items-center justify-between gap-4">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary">Recently viewed</p>
        <h2 class="section-title mt-3 text-3xl font-semibold text-slate-950">Pick up where you left off</h2>
      </div>
      <a href="/products" class="text-sm font-semibold text-primary transition hover:underline">View catalog</a>
    </div>
    <div class="mt-8 grid gap-5 md:grid-cols-3 xl:grid-cols-4">
      <% recentlyViewed.forEach((product) => { %>
        <article class="theme-product-card overflow-hidden rounded-[2rem]">
          <a href="/products/<%= product.slug %>" class="block <%= themeClasses.catalogCardAspect || 'aspect-[4/5]' %> overflow-hidden bg-slate-100">
            <img src="<%= product.image %>" alt="<%= product.name %>" loading="lazy" class="h-full w-full object-cover">
          </a>
          <div class="p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400"><%= product.category || 'Collection' %></p>
            <a href="/products/<%= product.slug %>" class="mt-2 block text-lg font-semibold text-slate-950 transition hover:text-primary"><%= product.name %></a>
            <p class="mt-3 text-sm font-semibold text-slate-900"><%= money(product.price || 0) %></p>
          </div>
        </article>
      <% }) %>
    </div>
  </section>
<% } %>
