<%
  const money = typeof formatMoney === 'function' ? formatMoney : ((value) => value);
  const productList = Array.isArray(products) ? products : [];
  const categoryList = Array.isArray(categories) ? categories : [];
  const currentCategory = activeCategory || 'All';
  const storeThemeData = typeof storeTheme !== 'undefined'
    ? storeTheme
    : (typeof currentStoreTheme !== 'undefined' ? currentStoreTheme : {});
  const themeClasses = storeThemeData.classes || {};
  const themeCopy = storeThemeData.copy || {};
  const themeTags = Array.isArray(storeThemeData.marketingTags) ? storeThemeData.marketingTags : [];
%>
<section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
  <div class="theme-hero-frame overflow-hidden rounded-[2.35rem] p-8 sm:p-10">
    <div class="grid gap-6 <%= themeClasses.catalogHeader || 'lg:grid-cols-[0.82fr_1.18fr] lg:items-end' %>">
      <div class="max-w-3xl">
        <span class="eyebrow"><%= themeCopy.catalogLabel || 'Catalog' %></span>
        <h1 class="section-title mt-5 text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl"><%= themeCopy.catalogTitle || `Discover the ${store && store.name ? store.name : 'store'} collection` %></h1>
        <p class="mt-4 text-lg leading-8 text-slate-600"><%= themeCopy.catalogBody || 'Thoughtfully merchandised products with clearer storytelling, faster scanning, and a premium path from browse to checkout.' %></p>
      </div>
      <div class="theme-accent-note rounded-[2rem] px-6 py-5">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary"><%= storeThemeData.label || 'Template system' %></p>
        <div class="mt-3 flex flex-wrap gap-2">
          <% themeTags.slice(0, 3).forEach((tag) => { %>
            <span class="theme-chip"><%= tag %></span>
          <% }) %>
        </div>
      </div>
    </div>

    <div class="mt-8 flex flex-wrap gap-3">
      <a href="/products" class="inline-flex items-center rounded-full px-4 py-2 text-sm font-medium <%= currentCategory === 'All' ? 'bg-primary text-white' : 'border border-slate-200 bg-white text-slate-700 hover:border-primary hover:text-primary' %>">
        All
      </a>
      <% categoryList.forEach((category) => { %>
        <% const isActive = currentCategory === (category.name || category.slug) || currentCategory === (category.slug || category.name); %>
        <a href="/products?category=<%= encodeURIComponent(category.slug || category.name) %>" class="inline-flex items-center rounded-full px-4 py-2 text-sm font-medium <%= isActive ? 'bg-primary text-white' : 'border border-slate-200 bg-white text-slate-700 hover:border-primary hover:text-primary' %>">
          <%= category.name || category.slug %>
        </a>
      <% }) %>
    </div>
  </div>

  <% if (productList.length) { %>
    <div class="mt-10 grid grid-cols-1 gap-5 <%= themeClasses.catalogGrid || 'sm:grid-cols-2 xl:grid-cols-4' %>">
      <% productList.forEach((product) => { %>
        <article class="theme-product-card lift-on-hover group overflow-hidden rounded-[2rem]">
          <a href="/products/<%= product.slug %>" class="block <%= themeClasses.catalogCardAspect || 'aspect-[4/5]' %> overflow-hidden bg-slate-100">
            <img src="<%= product.image %>" alt="<%= product.name %>" class="h-full w-full object-cover transition duration-300 group-hover:scale-105">
          </a>
          <div class="space-y-4 p-5">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400"><%= product.category || storeThemeData.storeTypeLabel || storeThemeData.typeLabel || 'Collection' %></p>
              <a href="/products/<%= product.slug %>" class="mt-2 block text-lg font-semibold text-slate-950 transition hover:text-primary"><%= product.name %></a>
              <p class="mt-2 text-sm leading-6 text-slate-600"><%= product.description %></p>
              <div class="mt-3 flex items-center gap-2">
                <span class="text-base font-semibold text-slate-950"><%= money(product.price || 0) %></span>
                <% if (product.compare_at_price) { %>
                  <span class="text-sm text-slate-400 line-through"><%= money(product.compare_at_price) %></span>
                <% } %>
              </div>
            </div>
            <div class="flex gap-3">
              <a href="/products/<%= product.slug %>" class="inline-flex flex-1 items-center justify-center rounded-2xl border border-slate-200 px-4 py-3 text-sm font-medium text-slate-700 transition hover:border-primary hover:text-primary">
                View detail
              </a>
              <button type="button" data-add-to-cart="<%= product.id %>" data-quantity="1" class="inline-flex flex-1 items-center justify-center rounded-2xl bg-primary px-4 py-3 text-sm font-semibold text-white transition hover:bg-primary-dark">
                Add to cart
              </button>
            </div>
          </div>
        </article>
      <% }) %>
    </div>
  <% } else { %>
    <div class="theme-panel mt-10 rounded-[2rem] px-6 py-16 text-center">
      <h2 class="section-title text-2xl font-semibold text-slate-950">No products in this filter yet</h2>
      <p class="mx-auto mt-3 max-w-xl text-base leading-7 text-slate-600">Try another category or check back as the catalog expands.</p>
    </div>
  <% } %>
</section>
