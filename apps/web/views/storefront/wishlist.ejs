<%
  const money = typeof formatMoney === 'function' ? formatMoney : ((value) => value);
  const items = Array.isArray(wishlistProducts) ? wishlistProducts : [];
  const storeThemeData = typeof storeTheme !== 'undefined'
    ? storeTheme
    : (typeof currentStoreTheme !== 'undefined' ? currentStoreTheme : {});
  const themeClasses = storeThemeData.classes || {};
%>
<section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
  <div class="theme-hero-frame overflow-hidden rounded-[2.35rem] p-8 sm:p-10">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <span class="eyebrow">Saved for later</span>
        <h1 class="section-title mt-5 text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl">Your wishlist</h1>
        <p class="mt-4 max-w-2xl text-lg leading-8 text-slate-600">Keep favorite products close, compare options, and move the right ones into the cart when you are ready.</p>
      </div>
      <div class="theme-accent-note rounded-[2rem] px-6 py-5">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary">Saved items</p>
        <p data-wishlist-count class="mt-3 section-title text-3xl font-semibold text-slate-950"><%= items.length %></p>
      </div>
    </div>
  </div>

  <div data-wishlist-empty class="<%= items.length ? 'hidden ' : '' %>theme-panel mt-10 rounded-[2rem] px-6 py-16 text-center">
    <h2 class="section-title text-2xl font-semibold text-slate-950">Your wishlist is empty</h2>
    <p class="mx-auto mt-3 max-w-xl text-base leading-7 text-slate-600">Browse the catalog and save products you want to revisit before checkout.</p>
    <a href="/products" class="mt-8 inline-flex items-center justify-center rounded-2xl bg-primary px-5 py-3 text-sm font-semibold text-white shadow-soft transition hover:bg-primary-dark">
      Explore products
    </a>
  </div>

  <div data-wishlist-grid class="mt-10 grid grid-cols-1 gap-5 <%= themeClasses.catalogGrid || 'sm:grid-cols-2 xl:grid-cols-4' %>">
    <% items.forEach((product) => { %>
      <article data-wishlist-card="<%= product.id %>" class="theme-product-card lift-on-hover group overflow-hidden rounded-[2rem]">
        <a href="/products/<%= product.slug %>" class="block <%= themeClasses.catalogCardAspect || 'aspect-[4/5]' %> overflow-hidden bg-slate-100">
          <img src="<%= product.image %>" alt="<%= product.name %>" loading="lazy" class="h-full w-full object-cover transition duration-300 group-hover:scale-105">
        </a>
        <div class="space-y-4 p-5">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400"><%= product.category || 'Collection' %></p>
            <a href="/products/<%= product.slug %>" class="mt-2 block text-lg font-semibold text-slate-950 transition hover:text-primary"><%= product.name %></a>
            <p class="mt-2 text-sm leading-6 text-slate-600"><%= product.description %></p>
            <p class="mt-3 text-base font-semibold text-slate-950"><%= money(product.price || 0) %></p>
          </div>
          <div class="flex gap-3">
            <button type="button" data-add-to-cart="<%= product.id %>" data-quantity="1" class="inline-flex flex-1 items-center justify-center rounded-2xl bg-primary px-4 py-3 text-sm font-semibold text-white transition hover:bg-primary-dark">
              Add to cart
            </button>
            <button type="button" data-wishlist-toggle="<%= product.id %>" class="inline-flex items-center justify-center rounded-2xl border border-slate-200 px-4 py-3 text-sm font-medium text-slate-700 transition hover:border-primary hover:text-primary" aria-pressed="true">
              Remove
            </button>
          </div>
        </div>
      </article>
    <% }) %>
  </div>
</section>
