<%
  const money = typeof formatMoney === 'function' ? formatMoney : ((value) => value);
  const productData = product || {};
  const gallery = Array.isArray(productData.images) && productData.images.length ? productData.images : [productData.image];
  const inStock = typeof productData.inventory === 'undefined' ? true : Number(productData.inventory) > 0;
  const recommendations = Array.isArray(relatedProducts) ? relatedProducts : [];
  const storeThemeData = typeof storeTheme !== 'undefined'
    ? storeTheme
    : (typeof currentStoreTheme !== 'undefined' ? currentStoreTheme : {});
  const themeClasses = storeThemeData.classes || {};
  const themeCopy = storeThemeData.copy || {};
  const themeTrustPoints = Array.isArray(storeThemeData.trustPoints) ? storeThemeData.trustPoints : [];
%>
<section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
  <div class="grid gap-10 <%= themeClasses.productGrid || 'lg:grid-cols-[1fr_1fr]' %>">
    <div class="space-y-4">
      <div class="theme-hero-frame overflow-hidden rounded-[2.35rem]">
        <img src="<%= gallery[0] %>" alt="<%= productData.name %>" loading="eager" class="h-full w-full object-cover">
      </div>
      <div class="grid grid-cols-4 gap-3">
        <% gallery.slice(0, 4).forEach((image, index) => { %>
          <div class="overflow-hidden rounded-2xl border <%= index === 0 ? 'border-primary' : 'border-slate-200' %> bg-slate-100">
            <img src="<%= image %>" alt="<%= productData.name %> thumbnail <%= index + 1 %>" loading="lazy" class="aspect-square h-full w-full object-cover">
          </div>
        <% }) %>
      </div>
    </div>

    <div class="space-y-8">
      <div class="space-y-4">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary"><%= themeCopy.productLabel || productData.category || 'Product detail' %></p>
        <h1 class="section-title text-4xl font-semibold tracking-tight text-slate-950"><%= productData.name || 'Untitled product' %></h1>
        <div class="flex items-center gap-3">
          <span class="section-title text-3xl font-semibold text-slate-950"><%= money(productData.price || 0) %></span>
          <% if (productData.compare_at_price) { %>
            <span class="text-lg text-slate-400 line-through"><%= money(productData.compare_at_price) %></span>
          <% } %>
        </div>
        <p class="max-w-2xl text-base leading-8 text-slate-600"><%= productData.description || 'A premium product with clear merchandising and a trustworthy path to checkout.' %></p>
      </div>

      <% if (productData.highlights && productData.highlights.length) { %>
        <div class="theme-detail-panel rounded-[2rem] p-6">
          <p class="text-sm font-medium text-slate-500">Why customers choose it</p>
          <ul class="mt-4 space-y-3">
            <% productData.highlights.forEach((highlight) => { %>
              <li class="flex items-start gap-3 text-sm text-slate-600">
                <span class="mt-2 inline-flex h-2 w-2 rounded-full bg-primary"></span>
                <span><%= highlight %></span>
              </li>
            <% }) %>
          </ul>
        </div>
      <% } %>

      <div class="grid gap-4 sm:grid-cols-2">
        <div class="theme-panel rounded-[2rem] p-5">
          <p class="text-sm font-medium text-slate-500">SKU</p>
          <p class="mt-2 text-base font-semibold text-slate-950"><%= productData.sku || 'N/A' %></p>
        </div>
        <div class="theme-panel rounded-[2rem] p-5">
          <p class="text-sm font-medium text-slate-500">Availability</p>
          <p class="mt-2">
            <span class="inline-flex rounded-full px-3 py-1 text-sm font-semibold <%= inStock ? 'bg-emerald-50 text-emerald-700' : 'bg-rose-50 text-rose-700' %>">
              <%= inStock ? `In stock - ${productData.inventory} ready to ship` : 'Out of stock' %>
            </span>
          </p>
        </div>
      </div>

      <% if (themeTrustPoints.length) { %>
        <div class="theme-accent-note rounded-[2rem] px-6 py-5">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary"><%= storeThemeData.label || 'Store promise' %></p>
          <ul class="mt-4 space-y-3">
            <% themeTrustPoints.slice(0, 3).forEach((point) => { %>
              <li class="flex items-start gap-3 text-sm leading-6 text-slate-600">
                <span class="mt-2 inline-flex h-2 w-2 rounded-full bg-primary"></span>
                <span><%= point %></span>
              </li>
            <% }) %>
          </ul>
        </div>
      <% } %>

      <div class="theme-summary-card rounded-[2rem] p-6">
        <div class="flex flex-col gap-5 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <p class="text-sm font-medium text-slate-500">Quantity</p>
            <div class="mt-3 inline-flex items-center rounded-full border border-slate-200 bg-white p-1">
              <button type="button" data-quantity-step="-1" data-quantity-target="#product-quantity" class="inline-flex h-11 w-11 items-center justify-center rounded-full text-slate-600 transition hover:bg-slate-100" aria-label="Decrease quantity">
                <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M4 10a1 1 0 011-1h10a1 1 0 110 2H5a1 1 0 01-1-1z" clip-rule="evenodd"></path></svg>
              </button>
              <input id="product-quantity" type="number" min="1" value="1" class="h-11 w-16 border-0 bg-transparent text-center text-base font-semibold text-slate-900 focus:outline-none focus:ring-0">
              <button type="button" data-quantity-step="1" data-quantity-target="#product-quantity" class="inline-flex h-11 w-11 items-center justify-center rounded-full text-slate-600 transition hover:bg-slate-100" aria-label="Increase quantity">
                <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M10 4a1 1 0 011 1v4h4a1 1 0 110 2h-4v4a1 1 0 11-2 0v-4H5a1 1 0 110-2h4V5a1 1 0 011-1z" clip-rule="evenodd"></path></svg>
              </button>
            </div>
          </div>
          <div class="flex flex-col gap-3 sm:items-end">
            <button type="button" data-add-to-cart="<%= productData.id %>" data-qty-target="#product-quantity" class="inline-flex items-center justify-center rounded-2xl bg-primary px-6 py-3.5 text-base font-semibold text-white shadow-sm transition hover:bg-primary-dark disabled:cursor-not-allowed disabled:opacity-50" <%= inStock ? '' : 'disabled' %>>
              <%= inStock ? 'Add to cart' : 'Out of stock' %>
            </button>
            <button type="button" data-wishlist-toggle="<%= productData.id %>" class="inline-flex items-center justify-center rounded-2xl border border-slate-200 px-5 py-3 text-sm font-medium text-slate-700 transition hover:border-primary hover:text-primary" aria-pressed="<%= Array.isArray(wishlistIds) && wishlistIds.includes(String(productData.id)) ? 'true' : 'false' %>">
              Save to wishlist
            </button>
          </div>
        </div>
        <p class="mt-4 text-sm leading-6 text-slate-500"><%= themeCopy.productPromise || 'Secure checkout, order tracking, and support follow-up are available from your account after purchase.' %></p>
      </div>
    </div>
  </div>
</section>

<% if (recommendations.length) { %>
  <section class="mx-auto max-w-7xl px-4 pb-12 sm:px-6 lg:px-8 lg:pb-20">
    <div class="flex items-center justify-between gap-4">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary">You may also like</p>
        <h2 class="section-title mt-3 text-3xl font-semibold text-slate-950">More from this collection</h2>
      </div>
      <a href="/products" class="text-sm font-semibold text-primary transition hover:underline">Back to catalog</a>
    </div>
    <div class="mt-8 grid gap-5 md:grid-cols-3">
      <% recommendations.forEach((entry) => { %>
        <article class="theme-product-card lift-on-hover overflow-hidden rounded-[2rem]">
          <a href="/products/<%= entry.slug %>" class="block <%= themeClasses.catalogCardAspect || 'aspect-[4/5]' %> overflow-hidden bg-slate-100">
            <img src="<%= entry.image %>" alt="<%= entry.name %>" loading="lazy" class="h-full w-full object-cover">
          </a>
          <div class="p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400"><%= entry.category %></p>
            <a href="/products/<%= entry.slug %>" class="mt-2 block text-lg font-semibold text-slate-950 transition hover:text-primary"><%= entry.name %></a>
            <p class="mt-3 text-sm font-semibold text-slate-900"><%= money(entry.price || 0) %></p>
          </div>
        </article>
      <% }) %>
    </div>
  </section>
<% } %>
