<%
  const money = typeof formatMoney === 'function' ? formatMoney : ((value) => value);
  const productData = product || {};
  const gallery = Array.isArray(productData.images) && productData.images.length ? productData.images : [productData.image];
  const inStock = typeof productData.inventory === 'undefined' ? true : Number(productData.inventory) > 0;
  const recommendations = Array.isArray(relatedProducts) ? relatedProducts : [];
  const storeThemeData = typeof storeTheme !== 'undefined'
    ? storeTheme
    : (typeof currentStoreTheme !== 'undefined' ? currentStoreTheme : {});
  const themeClasses = storeThemeData.classes || {};
  const themeCopy = storeThemeData.copy || {};
  const themeTrustPoints = Array.isArray(storeThemeData.trustPoints) ? storeThemeData.trustPoints : [];
  const recentlyViewed = Array.isArray(recentlyViewedProducts) ? recentlyViewedProducts : [];
  const productTags = Array.isArray(productData.tags) ? productData.tags : [];
  const reviewList = Array.isArray(productReviews) ? productReviews : [];
  const viewerReviewData = viewerReview || null;
  const reviewEligibilityData = reviewEligibility || null;
  const canSubmitReview = Boolean(reviewEligibilityData && reviewEligibilityData.can_review);
  const canEditExistingReview = Boolean(viewerReviewData);
  const canOpenReviewForm = canSubmitReview || canEditExistingReview;
  const reviewStars = (rating) => `${'★'.repeat(Math.max(0, Math.min(5, Number(rating || 0))))}${'☆'.repeat(Math.max(0, 5 - Math.min(5, Number(rating || 0))))}`;
%>
<section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
  <div class="grid gap-10 <%= themeClasses.productGrid || 'lg:grid-cols-[1fr_1fr]' %>">
    <div class="space-y-4">
      <div class="theme-hero-frame overflow-hidden rounded-[2.35rem]">
        <img src="<%= gallery[0] %>" alt="<%= productData.name %>" loading="eager" class="h-full w-full object-cover">
      </div>
      <div class="grid grid-cols-4 gap-3">
        <% gallery.slice(0, 4).forEach((image, index) => { %>
          <div class="overflow-hidden rounded-2xl border <%= index === 0 ? 'border-primary' : 'border-slate-200' %> bg-slate-100">
            <img src="<%= image %>" alt="<%= productData.name %> thumbnail <%= index + 1 %>" loading="lazy" class="aspect-square h-full w-full object-cover">
          </div>
        <% }) %>
      </div>
    </div>

    <div class="space-y-8">
      <div class="space-y-4">
        <div class="flex flex-wrap items-center gap-3">
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary"><%= themeCopy.productLabel || productData.category || 'Product detail' %></p>
          <% if (productData.badge) { %>
            <span class="inline-flex rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-slate-700"><%= productData.badge %></span>
          <% } %>
          <% if (productData.audience) { %>
            <span class="inline-flex rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-slate-700"><%= productData.audience %></span>
          <% } %>
        </div>
        <h1 class="section-title text-4xl font-semibold tracking-tight text-slate-950"><%= productData.name || 'Untitled product' %></h1>
        <div>
          <%- include('../partials/store-price', {
            product: productData,
            money,
            wrapperClass: 'flex flex-wrap items-center gap-3',
            priceClass: 'section-title text-3xl font-semibold text-slate-950',
            compareAtClass: 'text-lg text-slate-400 line-through',
            discountClass: 'inline-flex rounded-full bg-rose-50 px-3 py-1 text-sm font-semibold uppercase tracking-[0.14em] text-rose-700',
            showLabel: true
          }) %>
        </div>
        <% if (productData.rating) { %>
          <p class="text-sm font-medium text-slate-500"><%= productData.rating.toFixed(1) %>/5 <% if (productData.review_count) { %>from <%= productData.review_count %> verified customer reviews<% } %></p>
        <% } %>
        <p class="max-w-2xl text-base leading-8 text-slate-600"><%= productData.description || 'A premium product with clear merchandising and a trustworthy path to checkout.' %></p>
      </div>

      <% if (productTags.length) { %>
        <div class="flex flex-wrap gap-3">
          <% productTags.forEach((tag) => { %>
            <a href="/products?tag=<%= encodeURIComponent(tag) %>" class="inline-flex items-center rounded-full border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-primary hover:text-primary">
              <%= tag %>
            </a>
          <% }) %>
        </div>
      <% } %>

      <% if (productData.highlights && productData.highlights.length) { %>
        <div class="theme-detail-panel rounded-[2rem] p-6">
          <p class="text-sm font-medium text-slate-500">Why customers choose it</p>
          <ul class="mt-4 space-y-3">
            <% productData.highlights.forEach((highlight) => { %>
              <li class="flex items-start gap-3 text-sm text-slate-600">
                <span class="mt-2 inline-flex h-2 w-2 rounded-full bg-primary"></span>
                <span><%= highlight %></span>
              </li>
            <% }) %>
          </ul>
        </div>
      <% } %>

      <div class="grid gap-4 sm:grid-cols-2">
        <div class="theme-panel rounded-[2rem] p-5">
          <p class="text-sm font-medium text-slate-500">SKU</p>
          <p class="mt-2 text-base font-semibold text-slate-950"><%= productData.sku || 'N/A' %></p>
        </div>
        <div class="theme-panel rounded-[2rem] p-5">
          <p class="text-sm font-medium text-slate-500">Availability</p>
          <p class="mt-2">
            <span class="inline-flex rounded-full px-3 py-1 text-sm font-semibold <%= inStock ? 'bg-emerald-50 text-emerald-700' : 'bg-rose-50 text-rose-700' %>">
              <%= inStock ? `In stock - ${productData.inventory} ready to ship` : 'Out of stock' %>
            </span>
          </p>
        </div>
      </div>

      <% if (themeTrustPoints.length) { %>
        <div class="theme-accent-note rounded-[2rem] px-6 py-5">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary"><%= storeThemeData.label || 'Store promise' %></p>
          <ul class="mt-4 space-y-3">
            <% themeTrustPoints.slice(0, 3).forEach((point) => { %>
              <li class="flex items-start gap-3 text-sm leading-6 text-slate-600">
                <span class="mt-2 inline-flex h-2 w-2 rounded-full bg-primary"></span>
                <span><%= point %></span>
              </li>
            <% }) %>
          </ul>
        </div>
      <% } %>

      <div class="theme-summary-card rounded-[2rem] p-6">
        <div class="flex flex-col gap-5 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <p class="text-sm font-medium text-slate-500">Quantity</p>
            <div class="mt-3 inline-flex items-center rounded-full border border-slate-200 bg-white p-1">
              <button type="button" data-quantity-step="-1" data-quantity-target="#product-quantity" class="inline-flex h-11 w-11 items-center justify-center rounded-full text-slate-600 transition hover:bg-slate-100" aria-label="Decrease quantity">
                <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M4 10a1 1 0 011-1h10a1 1 0 110 2H5a1 1 0 01-1-1z" clip-rule="evenodd"></path></svg>
              </button>
              <input id="product-quantity" type="number" min="1" value="1" class="h-11 w-16 border-0 bg-transparent text-center text-base font-semibold text-slate-900 focus:outline-none focus:ring-0">
              <button type="button" data-quantity-step="1" data-quantity-target="#product-quantity" class="inline-flex h-11 w-11 items-center justify-center rounded-full text-slate-600 transition hover:bg-slate-100" aria-label="Increase quantity">
                <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M10 4a1 1 0 011 1v4h4a1 1 0 110 2h-4v4a1 1 0 11-2 0v-4H5a1 1 0 110-2h4V5a1 1 0 011-1z" clip-rule="evenodd"></path></svg>
              </button>
            </div>
          </div>
          <div class="flex flex-col gap-3 sm:items-end">
            <button type="button" data-add-to-cart="<%= productData.id %>" data-qty-target="#product-quantity" class="inline-flex items-center justify-center rounded-2xl bg-primary px-6 py-3.5 text-base font-semibold text-white shadow-sm transition hover:bg-primary-dark disabled:cursor-not-allowed disabled:opacity-50" <%= inStock ? '' : 'disabled' %>>
              <%= inStock ? 'Add to cart' : 'Out of stock' %>
            </button>
            <button type="button" data-wishlist-toggle="<%= productData.id %>" class="inline-flex items-center justify-center rounded-2xl border border-slate-200 px-5 py-3 text-sm font-medium text-slate-700 transition hover:border-primary hover:text-primary" aria-pressed="<%= Array.isArray(wishlistIds) && wishlistIds.includes(String(productData.id)) ? 'true' : 'false' %>">
              Save to wishlist
            </button>
          </div>
        </div>
        <p class="mt-4 text-sm leading-6 text-slate-500"><%= themeCopy.productPromise || 'Secure checkout, order tracking, and support follow-up are available from your account after purchase.' %></p>
      </div>
    </div>
  </div>
</section>

<section id="reviews" class="mx-auto max-w-7xl px-4 pb-12 sm:px-6 lg:px-8 lg:pb-20">
  <div class="grid gap-8 xl:grid-cols-[0.9fr_1.1fr]">
    <div class="space-y-6">
      <div class="theme-panel rounded-[2rem] p-6">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary">Verified feedback</p>
        <h2 class="section-title mt-3 text-3xl font-semibold text-slate-950">Customer reviews</h2>
        <% if (productData.rating) { %>
          <p class="mt-3 text-base leading-7 text-slate-600"><span class="font-semibold text-slate-950"><%= productData.rating.toFixed(1) %>/5</span> from <%= productData.review_count || 0 %> approved customer reviews.</p>
        <% } else { %>
          <p class="mt-3 text-base leading-7 text-slate-600">This product does not have any approved reviews yet. Verified customers can add the first one after purchase.</p>
        <% } %>
      </div>

      <div class="theme-summary-card rounded-[2rem] p-6">
        <div class="flex items-center justify-between gap-4">
          <div>
            <p class="text-sm font-medium text-slate-500">Leave feedback</p>
            <h3 class="mt-1 text-2xl font-semibold text-slate-950">Share the buying experience</h3>
          </div>
          <% if (customer) { %>
            <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold <%= canOpenReviewForm ? 'bg-emerald-50 text-emerald-700' : 'bg-amber-50 text-amber-700' %>">
              <%= canOpenReviewForm ? 'Eligible to review' : 'Verified purchase required' %>
            </span>
          <% } %>
        </div>

        <% if (!customer) { %>
          <p class="mt-4 text-sm leading-6 text-slate-600">Sign in with the same customer account you used to check out to leave a verified review.</p>
          <a href="/login?returnTo=<%= encodeURIComponent(`/products/${productData.slug}`) %>" class="mt-5 inline-flex items-center justify-center rounded-2xl bg-primary px-5 py-3 text-sm font-semibold text-white shadow-soft transition hover:bg-primary-dark">
            Sign in to review
          </a>
        <% } else if (canOpenReviewForm) { %>
          <% if (viewerReviewData) { %>
            <div class="mt-4 rounded-2xl border <%= viewerReviewData.is_approved ? 'border-emerald-200 bg-emerald-50 text-emerald-900' : 'border-amber-200 bg-amber-50 text-amber-900' %> px-4 py-4 text-sm leading-6">
              <strong><%= viewerReviewData.is_approved ? 'Your review is live.' : 'Your review is waiting for approval.' %></strong>
              Editing and resubmitting it will send it back through moderation.
            </div>
          <% } else { %>
            <p class="mt-4 text-sm leading-6 text-slate-600">Only customers with a paid or fulfilled order can review this product, which keeps storefront trust signals anchored to real purchases.</p>
          <% } %>
          <form action="/products/<%= productData.slug %>/reviews" method="post" class="mt-5 space-y-4">
            <%- include('../partials/csrf-field') %>
            <div>
              <label for="reviewRating" class="block text-sm font-medium text-slate-700">Rating</label>
              <select id="reviewRating" name="rating" class="mt-2 w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20">
                <% [5, 4, 3, 2, 1].forEach((value) => { %>
                  <option value="<%= value %>" <%= Number(viewerReviewData && viewerReviewData.rating ? viewerReviewData.rating : 5) === value ? 'selected' : '' %>><%= value %> star<%= value === 1 ? '' : 's' %></option>
                <% }) %>
              </select>
            </div>
            <div>
              <label for="reviewTitle" class="block text-sm font-medium text-slate-700">Title</label>
              <input id="reviewTitle" name="title" type="text" maxlength="255" value="<%= viewerReviewData && viewerReviewData.title ? viewerReviewData.title : '' %>" class="mt-2 w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="Summarize what stood out">
            </div>
            <div>
              <label for="reviewBody" class="block text-sm font-medium text-slate-700">Review</label>
              <textarea id="reviewBody" name="body" rows="5" class="mt-2 w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="What was the fit, quality, or delivery experience like?"><%= viewerReviewData && viewerReviewData.body ? viewerReviewData.body : '' %></textarea>
            </div>
            <button type="submit" class="inline-flex items-center justify-center rounded-2xl bg-primary px-5 py-3 text-sm font-semibold text-white shadow-soft transition hover:bg-primary-dark">
              <%= viewerReviewData ? 'Update review' : 'Submit review' %>
            </button>
          </form>
        <% } else { %>
          <div class="mt-4 rounded-2xl border border-amber-200 bg-amber-50 px-4 py-4 text-sm leading-6 text-amber-900">
            Leave feedback after your first paid or fulfilled order for this product. That keeps reviews tied to real customer purchases.
          </div>
        <% } %>
      </div>
    </div>

    <div class="theme-panel rounded-[2rem] p-6">
      <div class="flex items-center justify-between gap-4">
        <div>
          <p class="text-sm font-medium text-slate-500">Storefront trust feed</p>
          <h3 class="mt-1 text-2xl font-semibold text-slate-950">Approved reviews</h3>
        </div>
        <span class="inline-flex rounded-full bg-primary-soft px-3 py-1 text-sm font-semibold text-primary"><%= reviewList.length %> live</span>
      </div>

      <% if (reviewList.length) { %>
        <div class="mt-6 space-y-4">
          <% reviewList.forEach((review) => { %>
            <article class="rounded-[2rem] border border-slate-200 p-5">
              <div class="flex flex-wrap items-center gap-3">
                <p class="text-sm font-semibold uppercase tracking-[0.2em] text-amber-500"><%= reviewStars(review.rating) %></p>
                <% if (review.verified_purchase) { %>
                  <span class="inline-flex rounded-full bg-sky-50 px-3 py-1 text-xs font-semibold text-sky-700">Verified purchase</span>
                <% } %>
              </div>
              <h4 class="mt-3 text-lg font-semibold text-slate-950"><%= review.title || 'Customer review' %></h4>
              <p class="mt-2 text-sm leading-6 text-slate-600"><%= review.body || 'No written review was provided.' %></p>
              <p class="mt-4 text-xs font-medium uppercase tracking-[0.16em] text-slate-400">
                Posted <%= review.created_at ? new Date(review.created_at).toLocaleString() : 'recently' %>
              </p>
            </article>
          <% }) %>
        </div>
      <% } else { %>
        <div class="mt-6 rounded-[2rem] border border-dashed border-slate-300 bg-slate-50 px-6 py-14 text-center">
          <p class="text-lg font-semibold text-slate-950">No reviews yet</p>
          <p class="mt-2 text-sm leading-6 text-slate-500">Be the first verified customer to share how this product performed after delivery.</p>
        </div>
      <% } %>
    </div>
  </div>
</section>

<% if (recommendations.length) { %>
  <section class="mx-auto max-w-7xl px-4 pb-12 sm:px-6 lg:px-8 lg:pb-20">
    <div class="flex items-center justify-between gap-4">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary">You may also like</p>
        <h2 class="section-title mt-3 text-3xl font-semibold text-slate-950">More from this collection</h2>
      </div>
      <a href="/products" class="text-sm font-semibold text-primary transition hover:underline">Back to catalog</a>
    </div>
    <div class="mt-8 grid gap-5 md:grid-cols-3">
      <% recommendations.forEach((entry) => { %>
        <article class="theme-product-card lift-on-hover overflow-hidden rounded-[2rem]">
          <a href="/products/<%= entry.slug %>" class="block <%= themeClasses.catalogCardAspect || 'aspect-[4/5]' %> overflow-hidden bg-slate-100">
            <img src="<%= entry.image %>" alt="<%= entry.name %>" loading="lazy" class="h-full w-full object-cover">
          </a>
          <div class="p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400"><%= entry.category %></p>
            <a href="/products/<%= entry.slug %>" class="mt-2 block text-lg font-semibold text-slate-950 transition hover:text-primary"><%= entry.name %></a>
            <div class="mt-3">
              <%- include('../partials/store-price', {
                product: entry,
                money,
                priceClass: 'text-sm font-semibold text-slate-900',
                compareAtClass: 'text-xs text-slate-400 line-through',
                showLabel: true
              }) %>
            </div>
          </div>
        </article>
      <% }) %>
    </div>
  </section>
<% } %>

<% if (recentlyViewed.length) { %>
  <section class="mx-auto max-w-7xl px-4 pb-12 sm:px-6 lg:px-8 lg:pb-20">
    <div class="flex items-center justify-between gap-4">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary">Recently viewed</p>
        <h2 class="section-title mt-3 text-3xl font-semibold text-slate-950">Keep comparing before you check out</h2>
      </div>
      <a href="/wishlist" class="text-sm font-semibold text-primary transition hover:underline">Open wishlist</a>
    </div>
    <div class="mt-8 grid gap-5 md:grid-cols-3 xl:grid-cols-4">
      <% recentlyViewed.forEach((entry) => { %>
        <article class="theme-product-card overflow-hidden rounded-[2rem]">
          <a href="/products/<%= entry.slug %>" class="block <%= themeClasses.catalogCardAspect || 'aspect-[4/5]' %> overflow-hidden bg-slate-100">
            <img src="<%= entry.image %>" alt="<%= entry.name %>" loading="lazy" class="h-full w-full object-cover">
          </a>
          <div class="p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400"><%= entry.category || 'Collection' %></p>
            <a href="/products/<%= entry.slug %>" class="mt-2 block text-lg font-semibold text-slate-950 transition hover:text-primary"><%= entry.name %></a>
            <div class="mt-3">
              <%- include('../partials/store-price', {
                product: entry,
                money,
                priceClass: 'text-sm font-semibold text-slate-900',
                compareAtClass: 'text-xs text-slate-400 line-through',
                showLabel: true
              }) %>
            </div>
          </div>
        </article>
      <% }) %>
    </div>
  </section>
<% } %>
