<%
  const money = typeof formatMoney === 'function' ? formatMoney : ((value) => value);
  const orderData = order || {};
  const confirmationItems = Array.isArray(orderData.items) ? orderData.items : [];
  const discountTotal = Number(orderData.discount_total || 0);
  const nextSteps = [
    orderData.status ? `Order status: ${orderData.status}` : 'Order status: confirmed',
    orderData.payment_status ? `Payment status: ${orderData.payment_status}` : 'Payment status: processing',
    store && store.fulfillment_sla ? `Fulfillment: ${store.fulfillment_sla}` : 'Fulfillment: you will receive delivery updates as the order progresses.'
  ];
%>
<section class="mx-auto max-w-4xl px-4 py-12 sm:px-6 lg:px-8 lg:py-20">
  <div class="surface-card rounded-[2rem] p-8 sm:p-10">
    <div class="text-center">
      <span class="inline-flex h-16 w-16 items-center justify-center rounded-full bg-emerald-100 text-emerald-600">
        <svg class="h-8 w-8" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M16.704 5.29a1 1 0 010 1.42l-7.2 7.2a1 1 0 01-1.415 0l-3-3a1 1 0 111.414-1.42l2.293 2.294 6.493-6.494a1 1 0 011.415 0z" clip-rule="evenodd"></path>
        </svg>
      </span>
      <h1 class="section-title mt-6 text-4xl font-semibold tracking-tight text-slate-950">Thank you for your order.</h1>
      <p class="mt-4 text-lg leading-8 text-slate-600">Your purchase is confirmed and the fulfillment team can now process it from the store operations workspace.</p>
    </div>

    <div class="mt-10 grid gap-6 rounded-[2rem] bg-slate-50 p-6 sm:grid-cols-3">
      <div>
        <p class="text-sm font-medium text-slate-500">Order number</p>
        <p class="mt-2 text-lg font-semibold text-slate-950">#<%= orderData.id || '0000' %></p>
      </div>
      <div>
        <p class="text-sm font-medium text-slate-500">Payment reference</p>
        <p class="mt-2 break-all text-lg font-semibold text-slate-950"><%= orderData.payment_reference || 'Processing' %></p>
      </div>
      <div>
        <p class="text-sm font-medium text-slate-500">Total</p>
        <p class="mt-2 text-lg font-semibold text-slate-950"><%= money(orderData.total || 0) %></p>
      </div>
    </div>

    <div class="mt-6 grid gap-4 rounded-[2rem] border border-slate-200 p-6 sm:grid-cols-4">
      <div>
        <p class="text-sm font-medium text-slate-500">Subtotal</p>
        <p class="mt-2 text-lg font-semibold text-slate-950"><%= money(orderData.subtotal || 0) %></p>
      </div>
      <div>
        <p class="text-sm font-medium text-slate-500">Discount</p>
        <p class="mt-2 text-lg font-semibold text-emerald-700"><%= discountTotal > 0 ? `-${money(discountTotal)}` : money(0) %></p>
      </div>
      <div>
        <p class="text-sm font-medium text-slate-500">Coupon</p>
        <p class="mt-2 text-lg font-semibold text-slate-950"><%= orderData.coupon_code || 'None' %></p>
      </div>
      <div>
        <p class="text-sm font-medium text-slate-500">Final total</p>
        <p class="mt-2 text-lg font-semibold text-slate-950"><%= money(orderData.total || 0) %></p>
      </div>
    </div>

    <div class="mt-10 space-y-4">
      <% confirmationItems.forEach((item) => { %>
        <article class="flex items-center gap-4 rounded-3xl border border-slate-200 p-4">
          <img src="<%= item.image || 'https://images.unsplash.com/photo-1523381210434-271e8be1f52b?auto=format&fit=crop&w=300&q=80' %>" alt="<%= item.name %>" loading="lazy" class="h-16 w-16 rounded-2xl object-cover">
          <div class="min-w-0 flex-1">
            <h2 class="truncate text-sm font-semibold text-slate-900"><%= item.name %></h2>
            <p class="mt-1 text-sm text-slate-500">Qty <%= item.quantity || 1 %></p>
          </div>
          <p class="text-sm font-semibold text-slate-900"><%= money((item.price || 0) * (item.quantity || 1)) %></p>
        </article>
      <% }) %>
    </div>

    <div class="mt-10 grid gap-4 rounded-[2rem] bg-slate-50 p-6 sm:grid-cols-3">
      <% nextSteps.forEach((entry) => { %>
        <div class="rounded-[1.5rem] bg-white px-4 py-4">
          <p class="text-sm leading-6 text-slate-600"><%= entry %></p>
        </div>
      <% }) %>
    </div>

    <div class="mt-10 flex flex-col gap-3 sm:flex-row sm:justify-center">
      <a href="/orders" class="inline-flex items-center justify-center rounded-2xl border border-slate-200 px-5 py-3 text-sm font-medium text-slate-700 transition hover:border-primary hover:text-primary">
        View orders
      </a>
      <a href="/account" class="inline-flex items-center justify-center rounded-2xl border border-slate-200 px-5 py-3 text-sm font-medium text-slate-700 transition hover:border-primary hover:text-primary">
        Track account
      </a>
      <a href="/" class="inline-flex items-center justify-center rounded-2xl bg-primary px-5 py-3 text-sm font-semibold text-white transition hover:bg-primary-dark">
        Back to home
      </a>
    </div>
  </div>
</section>
