<%
  const money = typeof formatMoney === 'function' ? formatMoney : ((value) => value);
  const cartItems = cart && Array.isArray(cart.items) ? cart.items : [];
  const cartTotal = cart && typeof cart.total !== 'undefined' ? cart.total : 0;
  const appliedCouponPreview = couponPreview || null;
  const discountTotal = Number(appliedCouponPreview && appliedCouponPreview.discount_total ? appliedCouponPreview.discount_total : 0);
  const discountedCartTotal = Math.max(0, Number(cartTotal || 0) - discountTotal);
  const orderCurrency = typeof baseCurrency === 'string' && baseCurrency ? baseCurrency : (store && store.default_currency ? store.default_currency : 'USD');
  const orderMoney = typeof formatMoneyFor === 'function'
    ? ((value) => formatMoneyFor(value, orderCurrency))
    : money;
  const chargeCurrencyDiffers = typeof selectedCurrency === 'string' && selectedCurrency && selectedCurrency !== orderCurrency;
  const storeThemeData = typeof storeTheme !== 'undefined'
    ? storeTheme
    : (typeof currentStoreTheme !== 'undefined' ? currentStoreTheme : {});
  const themeClasses = storeThemeData.classes || {};
  const themeCopy = storeThemeData.copy || {};
  const themeTrustPoints = Array.isArray(storeThemeData.trustPoints) ? storeThemeData.trustPoints : [];
  const checkoutProviderList = Array.isArray(checkoutProviders) ? checkoutProviders : [];
  const requestedProvider = typeof selectedCheckoutProvider === 'string' ? selectedCheckoutProvider : '';
  const selectedProvider = checkoutProviderList.some((provider) => provider.provider === requestedProvider)
    ? requestedProvider
    : (checkoutProviderList[0] ? checkoutProviderList[0].provider : 'paystack');
  const checkoutHighlights = [
    store && store.fulfillment_sla ? `Dispatch promise: ${store.fulfillment_sla}` : 'Dispatch promise: Orders move into fulfillment quickly after payment confirmation.',
    store && store.return_window_days ? `${store.return_window_days}-day returns on eligible orders.` : 'Flexible returns on eligible orders.',
    store && store.support_email ? `Support: ${store.support_email}` : 'Support stays available after purchase if you need delivery help.'
  ];
%>
<section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
  <div class="grid gap-8 <%= themeClasses.checkoutGrid || 'lg:grid-cols-[1.05fr_0.95fr]' %>">
    <form action="/checkout" method="post" data-checkout-form data-checkout-quote-endpoint="/checkout/quote" data-checkout-order-currency="<%= orderCurrency %>" class="order-2 space-y-6 lg:order-1">
      <%- include('../partials/csrf-field') %>
      <section class="theme-hero-frame rounded-[2.35rem] p-6">
        <span class="eyebrow"><%= themeCopy.checkoutLabel || 'Checkout' %></span>
        <h1 class="section-title mt-5 text-3xl font-semibold tracking-tight text-slate-950"><%= themeCopy.checkoutTitle || 'Shipping details' %></h1>
        <p class="mt-3 max-w-2xl text-base leading-7 text-slate-600"><%= themeCopy.checkoutBody || 'Complete your delivery details and payment method in a checkout designed to keep trust high and friction low.' %></p>

        <div class="mt-8 grid gap-5 sm:grid-cols-2">
          <div class="sm:col-span-2">
            <label for="name" class="mb-1 block text-sm font-medium text-slate-700">Full name</label>
            <input id="name" name="name" type="text" value="<%= customer && customer.name ? customer.name : '' %>" class="theme-input w-full rounded-2xl border px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="Amara Bello">
            <%- include('../partials/form-error', { field: 'name' }) %>
          </div>
          <div class="sm:col-span-2">
            <label for="address" class="mb-1 block text-sm font-medium text-slate-700">Address</label>
            <input id="address" name="address" type="text" value="<%= customer && customer.address ? customer.address : '' %>" class="theme-input w-full rounded-2xl border px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="17 Marina Road">
            <%- include('../partials/form-error', { field: 'address' }) %>
          </div>
          <div>
            <label for="city" class="mb-1 block text-sm font-medium text-slate-700">City</label>
            <input id="city" name="city" type="text" value="<%= customer && customer.city ? customer.city : '' %>" class="theme-input w-full rounded-2xl border px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="Lagos">
            <%- include('../partials/form-error', { field: 'city' }) %>
          </div>
          <div>
            <label for="country" class="mb-1 block text-sm font-medium text-slate-700">Country</label>
            <input id="country" name="country" type="text" value="<%= customer && customer.country ? customer.country : '' %>" class="theme-input w-full rounded-2xl border px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="Nigeria">
            <%- include('../partials/form-error', { field: 'country' }) %>
          </div>
          <div class="sm:col-span-2">
            <label for="postalCode" class="mb-1 block text-sm font-medium text-slate-700">Postal code</label>
            <input id="postalCode" name="postal_code" type="text" value="<%= customer && customer.postal_code ? customer.postal_code : '' %>" class="theme-input w-full rounded-2xl border px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="100001">
            <%- include('../partials/form-error', { field: 'postal_code' }) %>
          </div>
        </div>
      </section>

      <section class="theme-summary-card rounded-[2rem] p-6">
        <p class="text-sm font-medium text-slate-500">Payment provider</p>
        <% if (checkoutProviderList.length) { %>
          <div class="mt-5 grid gap-4 sm:grid-cols-2">
            <% checkoutProviderList.forEach((provider) => { %>
              <% const isSelected = provider.provider === selectedProvider; %>
              <label class="rounded-3xl border border-slate-200 bg-white p-4 transition hover:border-primary">
                <input type="radio" name="provider" value="<%= provider.provider %>" class="sr-only" <%= isSelected ? 'checked' : '' %>>
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <p class="text-sm font-semibold text-slate-900"><%= provider.provider === 'paystack' ? 'Paystack' : 'Flutterwave' %></p>
                    <p class="mt-2 text-sm text-slate-500">
                      <%= provider.provider === 'paystack'
                        ? 'Cards, transfers, USSD, and local channels through Paystack hosted checkout.'
                        : 'Cards, bank transfer, and USSD through Flutterwave hosted checkout.' %>
                    </p>
                  </div>
                  <span class="inline-flex rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-emerald-700">Live</span>
                </div>
              </label>
            <% }) %>
          </div>
          <div class="mt-5 rounded-[1.75rem] border border-slate-200 bg-white/80 p-5">
            <p class="text-sm font-semibold text-slate-900">How payment works</p>
            <p class="mt-3 text-sm leading-6 text-slate-500">After you confirm this order, we&apos;ll redirect you to the selected payment provider to complete the payment securely. Your order only moves forward after the transaction is verified on the server.</p>
            <div class="mt-4 grid gap-3 sm:grid-cols-3">
              <div class="rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-600">Server-side verification before fulfillment</div>
              <div class="rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-600">Provider-hosted checkout keeps card entry off your store pages</div>
              <div class="rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-600">Orders stay traceable by reference after payment</div>
            </div>
          </div>
        <% } else { %>
          <div class="mt-5 rounded-[1.75rem] border border-amber-200 bg-amber-50 px-5 py-5">
            <p class="text-sm font-semibold text-amber-900">No payment provider is active for this store yet.</p>
            <p class="mt-2 text-sm leading-6 text-amber-800">The store owner needs to activate Paystack or Flutterwave before checkout can continue.</p>
          </div>
        <% } %>
      </section>

      <button type="submit" data-checkout-submit class="inline-flex w-full items-center justify-center rounded-2xl bg-primary px-5 py-3.5 text-base font-semibold text-white shadow-soft transition hover:bg-primary-dark disabled:cursor-not-allowed disabled:opacity-50" <%= checkoutProviderList.length ? '' : 'disabled' %>>
        Place order
      </button>
    </form>

    <aside class="order-1 space-y-6 lg:order-2">
      <section class="theme-summary-card rounded-[2rem] p-6">
        <p class="text-sm font-medium text-slate-500">Order summary</p>
        <% if (chargeCurrencyDiffers) { %>
          <div class="mt-4 rounded-[1.5rem] border border-sky-200 bg-sky-50 px-4 py-4">
            <p class="text-sm font-semibold text-sky-900">Final checkout is charged in <%= orderCurrency %>.</p>
            <p class="mt-2 text-sm leading-6 text-sky-800">Store browsing can follow your local currency preference, but the hosted payment amount and stored order ledger stay aligned to the store base currency for payment accuracy.</p>
          </div>
        <% } %>
        <% if (appliedCouponPreview && appliedCouponPreview.coupon) { %>
          <div class="mt-4 rounded-[1.5rem] border border-emerald-200 bg-emerald-50 px-4 py-4">
            <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
              <div>
                <p class="text-sm font-semibold text-emerald-900">Coupon <%= appliedCouponPreview.coupon.code %></p>
                <p class="mt-1 text-sm leading-6 text-emerald-800"><%= appliedCouponPreview.coupon.description || 'Store savings applied to this checkout.' %></p>
              </div>
              <p class="text-sm font-semibold text-emerald-700">-<%= orderMoney(discountTotal) %></p>
            </div>
            <p class="mt-3 text-xs uppercase tracking-[0.18em] text-emerald-700">Need to change it? Update your cart before placing the order.</p>
          </div>
        <% } %>
        <div class="mt-6 space-y-4">
          <% cartItems.forEach((item) => { %>
            <article class="flex items-center gap-4">
              <img src="<%= item.image %>" alt="<%= item.name %>" loading="lazy" class="h-16 w-16 rounded-2xl object-cover">
              <div class="min-w-0 flex-1">
                <h2 class="truncate text-sm font-semibold text-slate-900"><%= item.name %></h2>
                <p class="mt-1 text-sm text-slate-500">Qty <%= item.quantity || 1 %></p>
              </div>
              <p class="text-sm font-semibold text-slate-900"><%= orderMoney((item.price || 0) * (item.quantity || 1)) %></p>
            </article>
          <% }) %>
        </div>
        <div class="mt-6 border-t border-slate-200 pt-6 text-sm text-slate-600">
          <div class="flex items-center justify-between">
            <span>Subtotal</span>
            <span data-checkout-subtotal class="font-semibold text-slate-900"><%= orderMoney(cartTotal || 0) %></span>
          </div>
          <% if (appliedCouponPreview && appliedCouponPreview.coupon) { %>
            <div class="mt-4 flex items-center justify-between">
              <span>Discount (<%= appliedCouponPreview.coupon.code %>)</span>
              <span data-checkout-discount class="font-semibold text-emerald-700">-<%= orderMoney(discountTotal) %></span>
            </div>
          <% } else { %>
            <div class="mt-4 flex items-center justify-between">
              <span>Discount</span>
              <span data-checkout-discount class="font-semibold text-slate-900"><%= orderMoney(0) %></span>
            </div>
          <% } %>
          <div class="mt-4 flex items-center justify-between">
            <span>Shipping</span>
            <span data-checkout-shipping><%= orderMoney(0) %></span>
          </div>
          <div class="mt-4 flex items-center justify-between">
            <span data-checkout-tax-label>Tax</span>
            <span data-checkout-tax><%= orderMoney(0) %></span>
          </div>
          <div class="mt-6 flex items-center justify-between text-lg font-semibold text-slate-900">
            <span>Total</span>
            <span data-checkout-total><%= orderMoney(discountedCartTotal || 0) %></span>
          </div>
          <p data-checkout-quote-status class="mt-4 text-xs leading-5 text-slate-500">Enter your delivery details to preview the final shipping and tax breakdown before redirecting to payment.</p>
        </div>
      </section>

      <% if (themeTrustPoints.length) { %>
        <section class="theme-accent-note rounded-[2rem] px-6 py-5">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary"><%= storeThemeData.label || 'Store promise' %></p>
          <ul class="mt-4 space-y-3">
            <% themeTrustPoints.slice(0, 3).forEach((point) => { %>
              <li class="flex items-start gap-3 text-sm leading-6 text-slate-600">
                <span class="mt-2 inline-flex h-2 w-2 rounded-full bg-primary"></span>
                <span><%= point %></span>
              </li>
            <% }) %>
          </ul>
        </section>
      <% } %>

      <section class="theme-panel rounded-[2rem] p-6">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary">Before you pay</p>
        <div class="mt-4 space-y-4">
          <% checkoutHighlights.forEach((point) => { %>
            <div class="rounded-[1.5rem] border border-slate-200 bg-white px-4 py-4">
              <p class="text-sm leading-6 text-slate-600"><%= point %></p>
            </div>
          <% }) %>
        </div>
      </section>
    </aside>
  </div>
</section>
