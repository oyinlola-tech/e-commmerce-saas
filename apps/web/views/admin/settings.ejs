<%
  const storeThemeData = typeof storeTheme !== 'undefined'
    ? storeTheme
    : (typeof currentStoreTheme !== 'undefined' ? currentStoreTheme : {});
  const storeTypeChoices = typeof storeTypes !== 'undefined' && Array.isArray(storeTypes) ? storeTypes : [];
  const templateChoices = typeof storeTemplates !== 'undefined' && Array.isArray(storeTemplates) ? storeTemplates : [];
  const fontChoices = typeof fontPresets !== 'undefined' && Array.isArray(fontPresets) ? fontPresets : [];
  const selectedTemplateKey = store && store.template_key ? store.template_key : (storeThemeData.templateKey || 'fashion');
  const selectedStoreType = store && store.store_type ? store.store_type : (storeThemeData.storeType || (storeTypeChoices[0] ? storeTypeChoices[0].key : selectedTemplateKey));
  const selectedFontKey = store && store.font_preset ? store.font_preset : (storeThemeData.fonts ? storeThemeData.fonts.key : 'jakarta');
  const selectedStoreTypeChoice = storeTypeChoices.find((entry) => entry.key === selectedStoreType) || storeTypeChoices[0] || null;
  const recommendedTemplateForType = selectedStoreTypeChoice
    ? (templateChoices.find((template) => template.key === selectedStoreTypeChoice.recommendedTemplateKey) || null)
    : null;
  const recommendedFontForType = selectedStoreTypeChoice
    ? (fontChoices.find((preset) => preset.key === selectedStoreTypeChoice.recommendedFontPreset) || null)
    : null;
  const themeCopy = storeThemeData.copy || {};
  const providerConfigs = typeof paymentProviderConfigs !== 'undefined' && paymentProviderConfigs ? paymentProviderConfigs : {};
  const providerDrafts = typeof paymentProviderDrafts !== 'undefined' && paymentProviderDrafts ? paymentProviderDrafts : {};
  const paymentConfigWarningMessage = typeof paymentProviderConfigWarning === 'string' ? paymentProviderConfigWarning : '';
  const paystackConfig = providerConfigs.paystack || {};
  const flutterwaveConfig = providerConfigs.flutterwave || {};
  const paystackDraft = providerDrafts.paystack || {};
  const flutterwaveDraft = providerDrafts.flutterwave || {};
  const previewHeroTitle = store && store.hero_title ? store.hero_title : (themeCopy.heroTitle || (store && store.tagline ? store.tagline : 'A premium storefront for modern essentials.'));
  const previewHeroDescription = store && store.hero_description ? store.hero_description : (themeCopy.heroBody || (store && store.description ? store.description : 'Designed for product discovery, trustworthy service, and confident checkout across international markets.'));
  const previewPrimaryCta = store && store.primary_cta_text ? store.primary_cta_text : (themeCopy.primaryCta || 'Shop the collection');
  const previewFeaturedDescription = store && store.featured_collection_description ? store.featured_collection_description : (themeCopy.catalogBody || 'This preview reflects the currently active storefront design system.');
  const paystackReady = Boolean(
    (paystackDraft.public_key || paystackConfig.public_key)
    && (paystackDraft.secret_key || paystackConfig.has_secret_key)
    && (paystackDraft.status || paystackConfig.status || 'inactive') === 'active'
  );
  const flutterwaveReady = Boolean(
    (flutterwaveDraft.public_key || flutterwaveConfig.public_key)
    && (flutterwaveDraft.secret_key || flutterwaveConfig.has_secret_key)
    && (flutterwaveDraft.webhook_secret_hash || flutterwaveConfig.has_webhook_secret_hash)
    && (flutterwaveDraft.status || flutterwaveConfig.status || 'inactive') === 'active'
  );
  const paymentReadyCount = [paystackReady, flutterwaveReady].filter(Boolean).length;
%>
<section class="space-y-8">
  <div class="surface-card rounded-[2.25rem] p-8">
    <div class="grid gap-8 xl:grid-cols-[1.04fr_0.96fr] xl:items-end">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary">Brand settings</p>
        <h1 class="section-title mt-3 text-4xl font-semibold tracking-tight text-slate-950">Store settings should remove launch friction, not add more of it.</h1>
        <p class="mt-4 max-w-2xl text-base leading-7 text-slate-600">This page now combines storefront identity, customer-trust details, and the exact payment credentials required for verified Paystack and Flutterwave checkout.</p>
      </div>
      <div class="grid gap-4 sm:grid-cols-3">
        <article class="metric-card rounded-3xl p-5">
          <p class="text-sm font-medium text-slate-500">Payments ready</p>
          <p class="metric-value mt-3 text-3xl font-semibold text-slate-950"><%= paymentReadyCount %>/2</p>
        </article>
        <article class="metric-card rounded-3xl p-5">
          <p class="text-sm font-medium text-slate-500">Support identity</p>
          <p class="mt-3 text-sm font-semibold text-slate-950"><%= store && store.support_email ? 'Configured' : 'Needs work' %></p>
        </article>
        <article class="metric-card rounded-3xl p-5">
          <p class="text-sm font-medium text-slate-500">Storefront URL</p>
          <p class="mt-3 truncate text-sm font-semibold text-slate-950"><%= storefrontUrl || '/' %></p>
        </article>
      </div>
    </div>
  </div>

  <form action="/admin/settings" method="post" enctype="multipart/form-data" class="grid gap-8 xl:grid-cols-[1fr_0.92fr]">
    <%- include('../partials/csrf-field') %>

    <section class="space-y-6">
      <div class="surface-card rounded-[2rem] p-6">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary">Identity</p>
            <h2 class="section-title mt-2 text-2xl font-semibold text-slate-950">Storefront trust signals</h2>
          </div>
          <p class="max-w-md text-sm leading-6 text-slate-500">Customers decide fast whether a storefront is credible. Brand, support, delivery promise, and returns need to feel complete before the first paid session.</p>
        </div>

        <div class="mt-6 grid gap-5">
          <div>
            <label for="storeName" class="mb-1 block text-sm font-medium text-slate-700">Store name</label>
            <input id="storeName" name="name" type="text" value="<%= store && store.name ? store.name : '' %>" class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="Aisle">
            <%- include('../partials/form-error', { field: 'name' }) %>
          </div>
          <div>
            <label for="tagline" class="mb-1 block text-sm font-medium text-slate-700">Tagline</label>
            <input id="tagline" name="tagline" type="text" value="<%= store && store.tagline ? store.tagline : '' %>" class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="Cross-border essentials for modern homes, studios, and teams.">
          </div>
          <div>
            <label for="description" class="mb-1 block text-sm font-medium text-slate-700">Description</label>
            <textarea id="description" name="description" rows="5" class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="Describe the store experience..."><%= store && store.description ? store.description : '' %></textarea>
          </div>
          <div class="grid gap-5 sm:grid-cols-2">
            <div>
              <label for="logo" class="mb-1 block text-sm font-medium text-slate-700">Logo upload</label>
              <input id="logo" name="logo" type="file" accept="image/png,image/jpeg,image/webp" class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-700 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20">
              <p class="mt-2 text-sm text-slate-500">PNG, JPEG, or WebP up to 2MB. The upload path is now hardened to accept only detected image formats.</p>
              <%- include('../partials/form-error', { field: 'logo' }) %>
            </div>
            <div>
              <label for="logoPreview" class="mb-1 block text-sm font-medium text-slate-700">Current logo URL</label>
              <input id="logoPreview" name="logoPreview" type="text" value="<%= store && store.logo ? store.logo : '' %>" class="w-full rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-slate-500 shadow-sm" readonly>
            </div>
          </div>
          <div>
            <label for="themeColor" class="mb-1 block text-sm font-medium text-slate-700">Theme colour</label>
            <div class="flex items-center gap-4 rounded-2xl border border-slate-300 bg-white px-4 py-3 shadow-sm">
              <input id="themeColor" name="theme_color" type="color" value="<%= store && store.theme_color ? store.theme_color : '#0F766E' %>" data-template-color-input class="h-12 w-16 rounded-xl border-0 bg-transparent p-0">
              <div>
                <p class="text-sm font-medium text-slate-900" data-template-color-label><%= store && store.theme_color ? store.theme_color : '#0F766E' %></p>
                <p class="mt-1 text-sm text-slate-500">Applied to calls-to-action, badges, links, and focus states.</p>
              </div>
            </div>
          </div>
          <div class="grid gap-5 sm:grid-cols-2">
            <div>
              <label for="supportEmail" class="mb-1 block text-sm font-medium text-slate-700">Support email</label>
              <input id="supportEmail" name="support_email" type="email" value="<%= store && store.support_email ? store.support_email : '' %>" class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="support@example.com">
            </div>
            <div>
              <label for="contactPhone" class="mb-1 block text-sm font-medium text-slate-700">Contact phone</label>
              <input id="contactPhone" name="contact_phone" type="text" value="<%= store && store.contact_phone ? store.contact_phone : '' %>" class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="+234 800 000 0000">
            </div>
            <div>
              <label for="fulfillmentSla" class="mb-1 block text-sm font-medium text-slate-700">Fulfillment SLA</label>
              <input id="fulfillmentSla" name="fulfillment_sla" type="text" value="<%= store && store.fulfillment_sla ? store.fulfillment_sla : '' %>" class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="Ships same day before 16:00 UTC">
            </div>
            <div>
              <label for="returnWindow" class="mb-1 block text-sm font-medium text-slate-700">Return window (days)</label>
              <input id="returnWindow" name="return_window_days" type="number" min="1" step="1" value="<%= store && store.return_window_days ? store.return_window_days : 30 %>" class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20">
            </div>
          </div>
        </div>
      </div>

      <div class="surface-card rounded-[2rem] p-6">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary">Design system</p>
            <h2 class="section-title mt-2 text-2xl font-semibold text-slate-950">Template, store type, and typography</h2>
          </div>
          <p class="max-w-md text-sm leading-6 text-slate-500">Store type helps onboarding guidance, while template and typography shape the customer-facing storefront. Keep this simple so the owner reaches launch faster.</p>
        </div>

        <div class="mt-6 grid gap-5 sm:grid-cols-2">
          <div>
            <label for="storeType" class="mb-1 block text-sm font-medium text-slate-700">Store category</label>
            <select id="storeType" name="store_type" class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20">
              <% storeTypeChoices.forEach((storeType) => { %>
                <% const recommendedTemplate = templateChoices.find((template) => template.key === storeType.recommendedTemplateKey); %>
                <% const recommendedFont = fontChoices.find((preset) => preset.key === storeType.recommendedFontPreset); %>
                <option
                  value="<%= storeType.key %>"
                  data-store-type-label="<%= storeType.label %>"
                  data-recommended-template-label="<%= recommendedTemplate ? recommendedTemplate.label : '' %>"
                  data-recommended-font-label="<%= recommendedFont ? recommendedFont.label : '' %>"
                  <%= selectedStoreType === storeType.key ? 'selected' : '' %>><%= storeType.label %></option>
              <% }) %>
            </select>
            <p class="mt-2 text-sm text-slate-500" data-store-type-recommendation-label>Recommended starter: <%= recommendedTemplateForType ? recommendedTemplateForType.label : 'Fashion Atelier' %> + <%= recommendedFontForType ? recommendedFontForType.label : 'Editorial Serif' %></p>
          </div>
          <div>
            <label for="fontPreset" class="mb-1 block text-sm font-medium text-slate-700">Font preset</label>
            <select id="fontPreset" name="font_preset" data-template-font-input class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20">
              <% fontChoices.forEach((preset) => { %>
                <option value="<%= preset.key %>" <%= selectedFontKey === preset.key ? 'selected' : '' %>><%= preset.label %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <input type="hidden" name="template_key" value="<%= selectedTemplateKey %>" data-template-key-input>
        <div class="mt-6 grid gap-3 sm:grid-cols-2">
          <% templateChoices.forEach((template) => { %>
            <label class="group cursor-pointer">
              <input type="radio" name="template_picker" value="<%= template.key %>" class="peer sr-only" data-template-option data-template-key="<%= template.key %>" data-template-label="<%= template.label %>" data-template-type-label="<%= template.typeLabel %>" data-template-default-color="<%= template.defaultColor %>" data-template-font="<%= template.fontPreset %>" <%= selectedTemplateKey === template.key ? 'checked' : '' %>>
              <span class="theme-preview-tile block rounded-[1.75rem] border border-slate-200 p-4 transition peer-checked:border-primary peer-checked:ring-2 peer-checked:ring-primary/20 group-hover:border-primary">
                <span class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">
                  <svg class="h-2.5 w-2.5" viewBox="0 0 10 10" aria-hidden="true">
                    <circle cx="5" cy="5" r="5" fill="<%= template.defaultColor %>"></circle>
                  </svg>
                  <%= template.typeLabel %>
                </span>
                <strong class="mt-3 block section-title text-xl font-semibold text-slate-950"><%= template.label %></strong>
                <span class="mt-2 block text-sm leading-6 text-slate-600"><%= template.description %></span>
              </span>
            </label>
          <% }) %>
        </div>
      </div>

      <div class="surface-card rounded-[2rem] p-6">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary">SEO and storefront copy</p>
            <h2 class="section-title mt-2 text-2xl font-semibold text-slate-950">What shoppers read before they trust checkout</h2>
          </div>
          <p class="max-w-md text-sm leading-6 text-slate-500">Good copy reduces bounce, improves product discovery, and closes the credibility gap for first-time visitors.</p>
        </div>

        <div class="mt-6 grid gap-5">
          <div>
            <label for="seoTitle" class="mb-1 block text-sm font-medium text-slate-700">SEO title</label>
            <input id="seoTitle" name="seo_title" type="text" value="<%= store && store.seo_title ? store.seo_title : '' %>" class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="<%= store && store.name ? store.name : 'Store name' %>">
          </div>
          <div>
            <label for="seoDescription" class="mb-1 block text-sm font-medium text-slate-700">SEO description</label>
            <textarea id="seoDescription" name="seo_description" rows="4" class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="Describe the store for search and social previews."><%= store && store.seo_description ? store.seo_description : '' %></textarea>
          </div>
          <div>
            <label for="seoKeywords" class="mb-1 block text-sm font-medium text-slate-700">SEO keywords</label>
            <input id="seoKeywords" name="seo_keywords" type="text" value="<%= store && store.seo_keywords ? store.seo_keywords : '' %>" class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="fashion, premium essentials, Lagos, international shipping">
          </div>
        </div>

        <div class="mt-8 grid gap-5 sm:grid-cols-2">
          <div class="sm:col-span-2">
            <label for="announcementText" class="mb-1 block text-sm font-medium text-slate-700">Announcement bar</label>
            <input id="announcementText" name="announcement_text" type="text" value="<%= store && store.announcement_text ? store.announcement_text : '' %>" class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="Free Lagos delivery above NGN 50,000">
          </div>
          <div>
            <label for="heroEyebrow" class="mb-1 block text-sm font-medium text-slate-700">Hero eyebrow</label>
            <input id="heroEyebrow" name="hero_eyebrow" type="text" value="<%= store && store.hero_eyebrow ? store.hero_eyebrow : '' %>" class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="<%= themeCopy.eyebrow || 'Curated storefront' %>">
          </div>
          <div>
            <label for="heroSupport" class="mb-1 block text-sm font-medium text-slate-700">Hero support line</label>
            <input id="heroSupport" name="hero_support" type="text" value="<%= store && store.hero_support ? store.hero_support : '' %>" class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="<%= themeCopy.heroSupport || (store && store.fulfillment_sla ? store.fulfillment_sla : 'Fast fulfillment available.') %>">
          </div>
          <div class="sm:col-span-2">
            <label for="heroTitle" class="mb-1 block text-sm font-medium text-slate-700">Hero title</label>
            <input id="heroTitle" name="hero_title" type="text" value="<%= store && store.hero_title ? store.hero_title : '' %>" class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="<%= themeCopy.heroTitle || 'A premium storefront for modern essentials.' %>">
          </div>
          <div class="sm:col-span-2">
            <label for="heroDescription" class="mb-1 block text-sm font-medium text-slate-700">Hero description</label>
            <textarea id="heroDescription" name="hero_description" rows="4" class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="<%= themeCopy.heroBody || 'Designed for product discovery, trustworthy service, and confident checkout across international markets.' %>"><%= store && store.hero_description ? store.hero_description : '' %></textarea>
          </div>
          <div>
            <label for="primaryCtaText" class="mb-1 block text-sm font-medium text-slate-700">Primary CTA label</label>
            <input id="primaryCtaText" name="primary_cta_text" type="text" value="<%= store && store.primary_cta_text ? store.primary_cta_text : '' %>" class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="<%= themeCopy.primaryCta || 'Shop the collection' %>">
          </div>
          <div>
            <label for="secondaryCtaText" class="mb-1 block text-sm font-medium text-slate-700">Secondary CTA label</label>
            <input id="secondaryCtaText" name="secondary_cta_text" type="text" value="<%= store && store.secondary_cta_text ? store.secondary_cta_text : '' %>" class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="<%= themeCopy.secondaryCta || 'My account' %>">
          </div>
          <div>
            <label for="featuredCollectionTitle" class="mb-1 block text-sm font-medium text-slate-700">Catalog section title</label>
            <input id="featuredCollectionTitle" name="featured_collection_title" type="text" value="<%= store && store.featured_collection_title ? store.featured_collection_title : '' %>" class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="<%= themeCopy.catalogTitle || 'Best-sellers customers trust first' %>">
          </div>
          <div>
            <label for="footerBlurb" class="mb-1 block text-sm font-medium text-slate-700">Footer blurb</label>
            <input id="footerBlurb" name="footer_blurb" type="text" value="<%= store && store.footer_blurb ? store.footer_blurb : '' %>" class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="A premium commerce experience built for confident discovery and trustworthy fulfillment.">
          </div>
          <div class="sm:col-span-2">
            <label for="featuredCollectionDescription" class="mb-1 block text-sm font-medium text-slate-700">Catalog section description</label>
            <textarea id="featuredCollectionDescription" name="featured_collection_description" rows="4" class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="<%= themeCopy.catalogBody || 'Thoughtfully merchandised products with clearer storytelling and a smoother path from browse to checkout.' %>"><%= store && store.featured_collection_description ? store.featured_collection_description : '' %></textarea>
          </div>
        </div>
      </div>

      <div class="surface-card rounded-[2rem] p-6">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary">Payments</p>
            <h2 class="section-title mt-2 text-2xl font-semibold text-slate-950">Paystack and Flutterwave credentials</h2>
          </div>
          <p class="max-w-md text-sm leading-6 text-slate-500">Storefront checkout is now limited to Paystack and Flutterwave. Stripe is out of scope here, and Flutterwave requires a webhook secret hash for safe verification.</p>
        </div>

        <% if (paymentConfigWarningMessage) { %>
          <div class="mt-4 rounded-2xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-800"><%= paymentConfigWarningMessage %></div>
        <% } %>

        <div class="mt-6 grid gap-5 xl:grid-cols-2">
          <section class="rounded-[1.5rem] border border-slate-200 bg-white p-5">
            <div class="flex items-start justify-between gap-4">
              <div>
                <h3 class="text-lg font-semibold text-slate-950">Paystack</h3>
                <p class="mt-1 text-sm leading-6 text-slate-500">Use for hosted checkout, server-side verification, and store-owner refunds.</p>
              </div>
              <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] <%= paystackReady ? 'bg-emerald-100 text-emerald-700' : 'bg-slate-100 text-slate-600' %>"><%= paystackReady ? 'ready' : (paystackDraft.status || paystackConfig.status || 'inactive') %></span>
            </div>

            <div class="mt-5 space-y-4">
              <div>
                <label for="paystackPublicKey" class="mb-1 block text-sm font-medium text-slate-700">Public key</label>
                <input id="paystackPublicKey" name="paystack_public_key" type="text" value="<%= paystackDraft.public_key || paystackConfig.public_key || '' %>" class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="pk_live_... or pk_test_...">
                <%- include('../partials/form-error', { field: 'paystack_public_key' }) %>
              </div>
              <div>
                <label for="paystackSecretKey" class="mb-1 block text-sm font-medium text-slate-700">Secret key</label>
                <input id="paystackSecretKey" name="paystack_secret_key" type="password" value="" class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="<%= paystackConfig.has_secret_key ? 'Leave blank to keep the saved secret key' : 'sk_live_... or sk_test_...' %>">
                <p class="mt-2 text-sm text-slate-500"><%= paystackConfig.has_secret_key ? 'A secret key is already stored securely. Leave this blank to keep it unchanged.' : 'No secret key is stored yet.' %></p>
                <%- include('../partials/form-error', { field: 'paystack_secret_key' }) %>
              </div>
              <div>
                <label for="paystackStatus" class="mb-1 block text-sm font-medium text-slate-700">Status</label>
                <select id="paystackStatus" name="paystack_status" class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20">
                  <option value="inactive" <%= (paystackDraft.status || paystackConfig.status || 'inactive') === 'inactive' ? 'selected' : '' %>>Inactive</option>
                  <option value="active" <%= (paystackDraft.status || paystackConfig.status || 'inactive') === 'active' ? 'selected' : '' %>>Active</option>
                </select>
              </div>
            </div>
          </section>

          <section class="rounded-[1.5rem] border border-slate-200 bg-white p-5">
            <div class="flex items-start justify-between gap-4">
              <div>
                <h3 class="text-lg font-semibold text-slate-950">Flutterwave</h3>
                <p class="mt-1 text-sm leading-6 text-slate-500">Hosted checkout and refunds are supported, but webhook signature validation depends on the secret hash below.</p>
              </div>
              <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] <%= flutterwaveReady ? 'bg-emerald-100 text-emerald-700' : 'bg-slate-100 text-slate-600' %>"><%= flutterwaveReady ? 'ready' : (flutterwaveDraft.status || flutterwaveConfig.status || 'inactive') %></span>
            </div>

            <div class="mt-5 space-y-4">
              <div>
                <label for="flutterwavePublicKey" class="mb-1 block text-sm font-medium text-slate-700">Public key</label>
                <input id="flutterwavePublicKey" name="flutterwave_public_key" type="text" value="<%= flutterwaveDraft.public_key || flutterwaveConfig.public_key || '' %>" class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="FLWPUBK_...">
                <%- include('../partials/form-error', { field: 'flutterwave_public_key' }) %>
              </div>
              <div>
                <label for="flutterwaveSecretKey" class="mb-1 block text-sm font-medium text-slate-700">Secret key</label>
                <input id="flutterwaveSecretKey" name="flutterwave_secret_key" type="password" value="" class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="<%= flutterwaveConfig.has_secret_key ? 'Leave blank to keep the saved secret key' : 'FLWSECK_...' %>">
                <p class="mt-2 text-sm text-slate-500"><%= flutterwaveConfig.has_secret_key ? 'A secret key is already stored securely. Leave this blank to keep it unchanged.' : 'No secret key is stored yet.' %></p>
                <%- include('../partials/form-error', { field: 'flutterwave_secret_key' }) %>
              </div>
              <div>
                <label for="flutterwaveWebhookSecretHash" class="mb-1 block text-sm font-medium text-slate-700">Webhook secret hash</label>
                <input id="flutterwaveWebhookSecretHash" name="flutterwave_webhook_secret_hash" type="password" value="<%= flutterwaveDraft.webhook_secret_hash || '' %>" class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="<%= flutterwaveConfig.has_webhook_secret_hash ? 'Leave blank to keep the saved webhook hash' : 'Paste the Flutterwave webhook secret hash' %>">
                <p class="mt-2 text-sm text-slate-500"><%= flutterwaveConfig.has_webhook_secret_hash ? 'A webhook secret hash is already stored securely. Leave this blank to keep it unchanged.' : 'Required before Flutterwave can be safely activated for verified storefront payments.' %></p>
                <%- include('../partials/form-error', { field: 'flutterwave_webhook_secret_hash' }) %>
              </div>
              <div>
                <label for="flutterwaveStatus" class="mb-1 block text-sm font-medium text-slate-700">Status</label>
                <select id="flutterwaveStatus" name="flutterwave_status" class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20">
                  <option value="inactive" <%= (flutterwaveDraft.status || flutterwaveConfig.status || 'inactive') === 'inactive' ? 'selected' : '' %>>Inactive</option>
                  <option value="active" <%= (flutterwaveDraft.status || flutterwaveConfig.status || 'inactive') === 'active' ? 'selected' : '' %>>Active</option>
                </select>
              </div>
            </div>
          </section>
        </div>
      </div>
    </section>

    <aside class="space-y-6">
      <section class="surface-card rounded-[2rem] p-6">
        <p class="text-sm font-medium text-slate-500">Launch readiness</p>
        <div class="mt-5 space-y-4">
          <article class="rounded-[1.5rem] border border-slate-200 bg-slate-50 p-4">
            <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Live storefront</p>
            <a href="<%= storefrontUrl || '/' %>" target="_blank" rel="noreferrer" class="mt-2 block break-all text-sm font-semibold text-primary transition hover:underline"><%= storefrontUrl || '/' %></a>
          </article>
          <article class="rounded-[1.5rem] border border-slate-200 bg-slate-50 p-4">
            <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Payment verification</p>
            <p class="mt-2 text-sm leading-6 text-slate-600">Paystack needs active keys. Flutterwave needs active keys plus the webhook secret hash so incoming webhooks can be verified before an order moves into confirmed.</p>
          </article>
          <article class="rounded-[1.5rem] border border-slate-200 bg-slate-50 p-4">
            <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Refund handling</p>
            <p class="mt-2 text-sm leading-6 text-slate-600">Store owners can now refund from the order detail page. The refund action uses the verified payment reference and updates order state for Paystack and Flutterwave.</p>
          </article>
        </div>
      </section>

      <section class="surface-card rounded-[2rem] p-6">
        <p class="text-sm font-medium text-slate-500">Preview</p>
        <div class="mt-5 rounded-[1.75rem] border border-slate-200 bg-slate-50 p-5">
          <div class="mb-4 flex flex-wrap gap-2">
            <span class="inline-flex rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-slate-700"><%= storeThemeData.label || 'Store template' %></span>
            <span class="inline-flex rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-slate-700"><%= storeThemeData.storeTypeLabel || storeThemeData.typeLabel || 'Store type' %></span>
          </div>
          <div class="flex items-center gap-3">
            <% if (store && store.logo) { %>
              <img src="<%= store.logo %>" alt="<%= store.name %> logo" class="h-12 w-12 rounded-2xl object-cover">
            <% } else { %>
              <span class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-primary text-lg font-semibold text-white"><%= store && store.name ? store.name.charAt(0).toUpperCase() : 'S' %></span>
            <% } %>
            <div>
              <p class="text-base font-semibold text-slate-900"><%= store && store.name ? store.name : 'Aisle' %></p>
              <p class="text-sm text-slate-500"><%= store && store.tagline ? store.tagline : 'Global storefront experience' %></p>
            </div>
          </div>
          <div class="mt-5 rounded-2xl bg-white p-4">
            <button type="button" class="inline-flex w-full items-center justify-center rounded-2xl bg-primary px-4 py-3 text-sm font-semibold text-white shadow-soft"><%= previewPrimaryCta %></button>
          </div>
          <p class="mt-4 text-base font-semibold text-slate-900"><%= previewHeroTitle %></p>
          <p class="mt-2 text-sm leading-6 text-slate-500"><%= previewHeroDescription %></p>
          <p class="mt-4 text-sm leading-6 text-slate-500"><%= previewFeaturedDescription %></p>
        </div>
      </section>

      <section class="surface-card rounded-[2rem] p-6">
        <p class="text-sm font-medium text-slate-500">SEO snippet</p>
        <div class="mt-5 rounded-[1.75rem] border border-slate-200 bg-slate-50 p-5">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">Search preview</p>
          <p class="mt-3 text-lg font-semibold text-blue-700"><%= store && store.seo_title ? store.seo_title : (store && store.name ? store.name : 'Store name') %></p>
          <p class="mt-1 break-all text-sm text-emerald-700"><%= storefrontUrl || '/' %></p>
          <p class="mt-3 text-sm leading-6 text-slate-600"><%= store && store.seo_description ? store.seo_description : (store && store.description ? store.description : 'Describe the store for search and social previews.') %></p>
        </div>
      </section>

      <div class="surface-card rounded-[2rem] p-6">
        <button type="submit" class="inline-flex w-full items-center justify-center rounded-2xl bg-primary px-5 py-3 text-sm font-semibold text-white shadow-soft transition hover:bg-primary-dark">Save settings</button>
      </div>
    </aside>
  </form>
</section>
