<%
  const tasks = Array.isArray(onboardingTasks) ? onboardingTasks : [];
  const progress = onboardingProgress || {};
  const completedRequired = Number(progress.completed_required_tasks || tasks.filter((task) => task.required && task.complete).length);
  const requiredTasks = Number(progress.required_tasks || tasks.filter((task) => task.required).length);
  const minutesRemaining = Number(progress.estimated_minutes_remaining || 0);
  const nextTask = tasks.find((task) => task.required && !task.complete) || tasks.find((task) => !task.complete) || null;
  const currentStepLabel = String(progress.current_step || 'initial')
    .replace(/[_-]+/g, ' ')
    .replace(/\b\w/g, (match) => match.toUpperCase());
  const taskStatusClass = (task) => task.complete
    ? 'bg-emerald-50 text-emerald-700 border-emerald-200'
    : 'bg-amber-50 text-amber-800 border-amber-200';
%>
<section class="space-y-8">
  <div class="surface-card rounded-[2.25rem] p-8">
    <div class="grid gap-8 xl:grid-cols-[1.02fr_0.98fr] xl:items-start">
      <div>
        <span class="eyebrow">Launch Guide</span>
        <h1 class="section-title mt-5 text-4xl font-semibold tracking-tight text-slate-950">Launch this store with a guided path that stays grounded in real data.</h1>
        <p class="mt-4 max-w-2xl text-lg leading-8 text-slate-600">
          Each step is derived from the live store record, published catalog, payment configuration, and order history, so the team always lands on the next real blocker.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <% if (nextTask) { %>
            <a href="<%= nextTask.href %>" class="inline-flex items-center justify-center rounded-2xl bg-primary px-5 py-3 text-sm font-semibold text-white shadow-soft transition hover:bg-primary-dark"><%= nextTask.action || 'Continue setup' %></a>
          <% } %>
          <a href="/admin" class="inline-flex items-center justify-center rounded-2xl border border-slate-200 px-5 py-3 text-sm font-medium text-slate-700 transition hover:border-primary hover:text-primary">Back to dashboard</a>
        </div>
      </div>

      <div class="space-y-4">
        <article class="metric-card rounded-3xl p-6">
          <p class="text-sm font-medium text-slate-500">Required steps complete</p>
          <p class="metric-value mt-3 text-3xl font-semibold text-slate-950"><%= completedRequired %> of <%= requiredTasks %></p>
          <p class="mt-3 text-sm text-slate-500"><%= currentStepLabel %><%= minutesRemaining ? ` • about ${minutesRemaining} minutes remaining` : '' %></p>
        </article>
        <div class="grid gap-4 sm:grid-cols-3">
          <article class="rounded-3xl border border-slate-200 bg-white p-5 shadow-soft">
            <p class="text-sm font-medium text-slate-500">Published products</p>
            <p class="mt-3 text-3xl font-semibold text-slate-950"><%= Number(publishedProductsCount || 0) %></p>
          </article>
          <article class="rounded-3xl border border-slate-200 bg-white p-5 shadow-soft">
            <p class="text-sm font-medium text-slate-500">Active gateways</p>
            <p class="mt-3 text-3xl font-semibold text-slate-950"><%= Number(paymentProvidersReady || 0) %></p>
          </article>
          <article class="rounded-3xl border border-slate-200 bg-white p-5 shadow-soft">
            <p class="text-sm font-medium text-slate-500">Orders seen</p>
            <p class="mt-3 text-3xl font-semibold text-slate-950"><%= Number(orderCount || 0) %></p>
          </article>
        </div>
      </div>
    </div>
  </div>

  <section class="surface-card rounded-[2rem] p-6">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-sm font-medium text-slate-500">Guided sequence</p>
        <h2 class="section-title mt-1 text-2xl font-semibold text-slate-950">From setup friction to first paid order</h2>
      </div>
      <span class="inline-flex rounded-full <%= progress.completed ? 'bg-emerald-50 text-emerald-700' : 'bg-amber-50 text-amber-800' %> px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em]"><%= progress.completed ? 'Launch ready' : 'In progress' %></span>
    </div>

    <div class="mt-6 space-y-4">
      <% tasks.forEach((task, index) => { %>
        <article class="rounded-[1.75rem] border p-5 <%= task.complete ? 'border-emerald-200 bg-emerald-50/70' : 'border-slate-200 bg-white' %>">
          <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
            <div class="min-w-0">
              <div class="flex flex-wrap items-center gap-3">
                <span class="inline-flex h-9 w-9 items-center justify-center rounded-full <%= task.complete ? 'bg-emerald-600 text-white' : 'bg-slate-100 text-slate-500' %> text-sm font-semibold"><%= index + 1 %></span>
                <p class="text-base font-semibold text-slate-950"><%= task.title %></p>
                <span class="inline-flex rounded-full border px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] <%= taskStatusClass(task) %>"><%= task.complete ? 'Complete' : 'Open' %></span>
                <span class="inline-flex rounded-full bg-slate-100 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-700"><%= task.required ? 'Required' : 'Optional' %></span>
              </div>
              <p class="mt-3 max-w-3xl text-sm leading-6 text-slate-600"><%= task.description %></p>
            </div>
            <div class="flex flex-col gap-3 lg:items-end">
              <% if (task.href) { %>
                <a href="<%= task.href %>" class="inline-flex items-center justify-center rounded-2xl border border-slate-200 px-4 py-2.5 text-sm font-semibold text-slate-700 transition hover:border-primary hover:text-primary"><%= task.action || 'Open' %></a>
              <% } %>
              <% if (!task.complete && task.estimate_minutes) { %>
                <p class="text-xs font-medium uppercase tracking-[0.18em] text-slate-400">About <%= task.estimate_minutes %> min</p>
              <% } %>
            </div>
          </div>
        </article>
      <% }) %>
    </div>
  </section>
</section>
