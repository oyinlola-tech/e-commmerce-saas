<%
  const money = typeof formatMoney === 'function' ? formatMoney : ((value) => value);
  const orderData = order || {};
  const orderItems = Array.isArray(orderData.items) ? orderData.items : [];
  const discountTotal = Number(orderData.discount_total || 0);
  const manualStatuses = ['pending', 'confirmed', 'shipped', 'delivered', 'payment_failed', 'refund_pending', 'refunded'];
  const normalizedOrderStatus = String(orderData.status || 'pending').toLowerCase();
  const normalizedPaymentStatus = String(orderData.payment_status || 'pending').toLowerCase();
  const hasRefundedState = normalizedOrderStatus === 'refunded' || normalizedPaymentStatus === 'refunded';
  const canRequestRefund = Boolean(orderData.payment_reference) && ['paid', 'success'].includes(normalizedPaymentStatus);
  const orderStatusClass = (status) => {
    switch ((status || '').toLowerCase()) {
      case 'delivered':
      case 'confirmed':
        return 'bg-emerald-50 text-emerald-700';
      case 'shipped':
        return 'bg-sky-50 text-sky-700';
      case 'refunded':
        return 'bg-slate-200 text-slate-700';
      case 'payment_failed':
        return 'bg-rose-50 text-rose-700';
      case 'refund_pending':
        return 'bg-fuchsia-50 text-fuchsia-700';
      default:
        return 'bg-amber-50 text-amber-700';
    }
  };
  const paymentStatusClass = (status) => {
    switch ((status || '').toLowerCase()) {
      case 'paid':
      case 'success':
        return 'bg-emerald-50 text-emerald-700';
      case 'refunded':
        return 'bg-slate-200 text-slate-700';
      case 'failed':
        return 'bg-rose-50 text-rose-700';
      default:
        return 'bg-amber-50 text-amber-700';
    }
  };
%>
<section class="space-y-8">
  <div class="flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary">Order detail</p>
      <h1 class="mt-2 text-3xl font-semibold tracking-tight text-gray-900">Order #<%= orderData.id || '0000' %></h1>
      <p class="mt-3 max-w-2xl text-base leading-7 text-gray-600">Review customer information, purchased items, payment traceability, and update fulfillment status from a single screen.</p>
    </div>
    <a href="/admin/orders" class="inline-flex items-center justify-center rounded-2xl border border-gray-200 px-5 py-3 text-sm font-medium text-gray-700 transition hover:border-primary hover:text-primary">
      Back to Orders
    </a>
  </div>

  <div class="grid gap-8 xl:grid-cols-[0.95fr_1.05fr]">
    <aside class="space-y-6">
      <section class="rounded-[2rem] border border-gray-200 bg-white p-6 shadow-sm">
        <p class="text-sm font-medium text-gray-500">Customer information</p>
        <div class="mt-5 space-y-4 text-sm text-gray-600">
          <div>
            <p class="font-semibold text-gray-900"><%= orderData.customer && orderData.customer.name ? orderData.customer.name : 'Guest customer' %></p>
            <p class="mt-1"><%= orderData.customer && orderData.customer.email ? orderData.customer.email : 'No email provided' %></p>
          </div>
          <div class="rounded-2xl bg-gray-50 p-4">
            <p class="text-xs uppercase tracking-[0.2em] text-gray-400">Shipping address</p>
            <p class="mt-2 leading-6 text-gray-700"><%= orderData.customer && orderData.customer.address ? orderData.customer.address : 'Address pending at checkout' %></p>
          </div>
          <div class="rounded-2xl bg-gray-50 p-4">
            <p class="text-xs uppercase tracking-[0.2em] text-gray-400">Coupon</p>
            <p class="mt-2 font-semibold text-gray-900"><%= orderData.coupon_code || 'None' %></p>
          </div>
        </div>
      </section>

      <section class="rounded-[2rem] border border-gray-200 bg-white p-6 shadow-sm">
        <p class="text-sm font-medium text-gray-500">Order and payment state</p>
        <div class="mt-5 space-y-4">
          <div class="flex items-center justify-between gap-4 rounded-2xl bg-gray-50 p-4">
            <div>
              <p class="text-xs uppercase tracking-[0.2em] text-gray-400">Fulfillment status</p>
              <span class="mt-2 inline-flex rounded-full px-3 py-1 text-xs font-semibold <%= orderStatusClass(orderData.status) %>"><%= orderData.status || 'pending' %></span>
            </div>
            <div class="text-right">
              <p class="text-xs uppercase tracking-[0.2em] text-gray-400">Payment status</p>
              <span class="mt-2 inline-flex rounded-full px-3 py-1 text-xs font-semibold <%= paymentStatusClass(orderData.payment_status) %>"><%= orderData.payment_status || 'pending' %></span>
            </div>
          </div>
          <div class="rounded-2xl bg-gray-50 p-4">
            <p class="text-xs uppercase tracking-[0.2em] text-gray-400">Payment reference</p>
            <p class="mt-2 break-all text-sm font-semibold text-gray-900"><%= orderData.payment_reference || 'Not assigned yet' %></p>
          </div>
        </div>
      </section>

      <section class="rounded-[2rem] border border-gray-200 bg-white p-6 shadow-sm">
        <p class="text-sm font-medium text-gray-500">Update status</p>
        <form action="/admin/orders/<%= orderData.id %>/status" method="post" class="mt-5 space-y-4">
          <%- include('../partials/csrf-field') %>
          <label for="status" class="block text-sm font-medium text-gray-700">Status</label>
          <select id="status" name="status" class="w-full rounded-2xl border border-gray-300 px-4 py-3 text-gray-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20">
            <% manualStatuses.forEach((status) => { %>
              <option value="<%= status %>" <%= normalizedOrderStatus === status ? 'selected' : '' %>><%= status.replace(/_/g, ' ') %></option>
            <% }) %>
          </select>
          <button type="submit" class="inline-flex w-full items-center justify-center rounded-2xl bg-primary px-4 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-primary-dark">
            Update Status
          </button>
        </form>
      </section>

      <section class="rounded-[2rem] border border-gray-200 bg-white p-6 shadow-sm">
        <p class="text-sm font-medium text-gray-500">Refund</p>
        <% if (canRequestRefund) { %>
          <form action="/admin/orders/<%= orderData.id %>/refund" method="post" class="mt-5 space-y-4">
            <%- include('../partials/csrf-field') %>
            <div>
              <label for="refundReason" class="block text-sm font-medium text-gray-700">Reason</label>
              <textarea id="refundReason" name="refund_reason" rows="4" class="mt-2 w-full rounded-2xl border border-gray-300 px-4 py-3 text-gray-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="Customer requested cancellation after payment."></textarea>
            </div>
            <button type="submit" class="inline-flex w-full items-center justify-center rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-semibold text-rose-700 transition hover:border-rose-300 hover:bg-rose-100">
              Issue Refund
            </button>
          </form>
        <% } else if (hasRefundedState) { %>
          <div class="mt-5 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4 text-sm leading-6 text-slate-600">
            A refund has already been recorded for this order. Use the order timeline and payment reference for support follow-up.
          </div>
        <% } else { %>
          <div class="mt-5 rounded-2xl border border-amber-200 bg-amber-50 px-4 py-4 text-sm leading-6 text-amber-800">
            Refunds are only available after a verified successful payment with a stored payment reference.
          </div>
        <% } %>
      </section>
    </aside>

    <section class="rounded-[2rem] border border-gray-200 bg-white p-6 shadow-sm">
      <div class="flex items-center justify-between gap-4">
        <div>
          <p class="text-sm font-medium text-gray-500">Purchased items</p>
          <h2 class="mt-1 text-2xl font-semibold text-gray-900">Order summary</h2>
        </div>
        <span class="inline-flex rounded-full bg-primary-soft px-3 py-1 text-sm font-semibold text-primary"><%= orderItems.length %> items</span>
      </div>

      <% if (orderItems.length) { %>
        <div class="mt-6 space-y-4">
          <% orderItems.forEach((item) => { %>
            <article class="flex flex-col gap-4 rounded-3xl border border-gray-200 p-4 sm:flex-row sm:items-center sm:justify-between">
              <div class="flex items-center gap-4">
                <img src="<%= item.image || 'https://images.unsplash.com/photo-1523381210434-271e8be1f52b?auto=format&fit=crop&w=300&q=80' %>" alt="<%= item.name %>" loading="lazy" class="h-16 w-16 rounded-2xl object-cover">
                <div>
                  <h3 class="text-sm font-semibold text-gray-900"><%= item.name %></h3>
                  <p class="mt-1 text-sm text-gray-500">Qty <%= item.quantity || 1 %></p>
                </div>
              </div>
              <p class="text-base font-semibold text-gray-900"><%= money((item.price || 0) * (item.quantity || 1)) %></p>
            </article>
          <% }) %>
        </div>
      <% } else { %>
        <div class="mt-6 rounded-3xl border border-dashed border-gray-300 bg-gray-50 px-6 py-12 text-center">
          <p class="text-lg font-semibold text-gray-900">No order items found</p>
          <p class="mt-2 text-sm leading-6 text-gray-500">This order does not currently contain any line items.</p>
        </div>
      <% } %>

      <div class="mt-8 border-t border-gray-200 pt-6">
        <div class="flex items-center justify-between text-sm text-gray-600">
          <span>Order date</span>
          <span><%= orderData.created_at ? new Date(orderData.created_at).toLocaleString() : 'Just now' %></span>
        </div>
        <div class="mt-4 flex items-center justify-between text-sm text-gray-600">
          <span>Subtotal</span>
          <span><%= money(orderData.subtotal || 0) %></span>
        </div>
        <div class="mt-4 flex items-center justify-between text-sm text-gray-600">
          <span>Discount</span>
          <span class="<%= discountTotal > 0 ? 'font-semibold text-emerald-700' : '' %>"><%= discountTotal > 0 ? `-${money(discountTotal)}` : money(0) %></span>
        </div>
        <div class="mt-4 flex items-center justify-between text-sm text-gray-600">
          <span>Payment status</span>
          <span><%= orderData.payment_status || 'pending' %></span>
        </div>
        <div class="mt-4 flex items-center justify-between text-sm text-gray-600">
          <span>Payment reference</span>
          <span class="max-w-[320px] break-all text-right text-gray-900"><%= orderData.payment_reference || 'Pending' %></span>
        </div>
        <div class="mt-4 flex items-center justify-between text-lg font-semibold text-gray-900">
          <span>Total</span>
          <span><%= money(orderData.total || 0) %></span>
        </div>
      </div>
    </section>
  </div>
</section>
