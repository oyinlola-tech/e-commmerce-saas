<%
  const money = typeof formatMoney === 'function' ? formatMoney : ((value) => value);
  const productList = Array.isArray(products) ? products : [];
%>
<section class="space-y-8">
  <div class="flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary">Catalog</p>
      <h1 class="section-title mt-2 text-3xl font-semibold tracking-tight text-slate-950">Products</h1>
      <p class="mt-3 max-w-2xl text-base leading-7 text-slate-600">Control merchandising, stock, positioning, and product storytelling from one organized workspace.</p>
    </div>
    <a href="/admin/products/new" class="inline-flex items-center justify-center rounded-2xl bg-primary px-5 py-3 text-sm font-semibold text-white shadow-soft transition hover:bg-primary-dark">
      Add Product
    </a>
  </div>

  <% if (productList.length) { %>
    <div class="grid gap-5 xl:grid-cols-2">
      <% productList.forEach((product) => { %>
        <article class="surface-card rounded-[2rem] p-5">
          <div class="flex gap-4">
            <img src="<%= product.image %>" alt="<%= product.name %>" loading="lazy" class="h-28 w-28 rounded-3xl object-cover">
            <div class="min-w-0 flex-1">
              <div class="flex flex-wrap items-center gap-3">
                <h2 class="text-xl font-semibold text-slate-950"><%= product.name %></h2>
                <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold <%= String(product.status || '').toLowerCase() === 'published' ? 'bg-emerald-50 text-emerald-700' : 'bg-slate-100 text-slate-700' %>"><%= String(product.status || 'draft').charAt(0).toUpperCase() + String(product.status || 'draft').slice(1) %></span>
                <% if (product.has_discount) { %>
                  <span class="inline-flex rounded-full bg-rose-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-rose-700"><%= product.is_flash_sale ? 'Flash sale' : `${product.discount_percentage}% off` %></span>
                <% } %>
              </div>
              <p class="mt-2 text-sm text-slate-500"><%= product.category || 'General' %> • <%= product.sku || 'No SKU assigned' %></p>
              <p class="mt-3 text-sm leading-6 text-slate-600"><%= product.description %></p>
              <div class="mt-4 grid gap-3 sm:grid-cols-3">
                <div class="rounded-2xl bg-slate-50 p-3">
                  <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Price</p>
                  <p class="mt-2 text-sm font-semibold text-slate-900"><%= money(product.price || 0) %></p>
                  <% if (product.compare_at_price) { %>
                    <p class="mt-1 text-xs text-slate-500 line-through"><%= money(product.compare_at_price) %></p>
                  <% } %>
                </div>
                <div class="rounded-2xl bg-slate-50 p-3">
                  <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Inventory</p>
                  <p class="mt-2 text-sm font-semibold text-slate-900"><%= typeof product.inventory !== 'undefined' ? product.inventory : 0 %></p>
                </div>
                <div class="rounded-2xl bg-slate-50 p-3">
                  <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Featured</p>
                  <p class="mt-2 text-sm font-semibold text-slate-900"><%= product.featured ? 'Yes' : 'No' %></p>
                </div>
              </div>
            </div>
          </div>
          <div class="mt-5 flex items-center gap-4">
            <a href="/admin/products/<%= product.id %>/edit" class="inline-flex items-center justify-center rounded-2xl border border-slate-200 px-4 py-2.5 text-sm font-medium text-slate-700 transition hover:border-primary hover:text-primary">Edit</a>
            <form action="/admin/products/<%= product.id %>/delete" method="post" class="inline">
              <%- include('../partials/csrf-field') %>
              <button type="submit" class="inline-flex items-center justify-center rounded-2xl border border-rose-200 px-4 py-2.5 text-sm font-medium text-rose-600 transition hover:bg-rose-50">Delete</button>
            </form>
          </div>
        </article>
      <% }) %>
    </div>
  <% } else { %>
    <div class="surface-card rounded-[2rem] px-6 py-16 text-center">
      <span class="mx-auto inline-flex h-16 w-16 items-center justify-center rounded-3xl bg-primary-soft text-primary">
        <svg class="h-8 w-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
          <path d="M4.5 7.5h15v9.75A1.75 1.75 0 0 1 17.75 19H6.25A1.75 1.75 0 0 1 4.5 17.25V7.5Z" stroke-width="1.5" stroke-linejoin="round"></path>
          <path d="M8 7.5V6A1.5 1.5 0 0 1 9.5 4.5h5A1.5 1.5 0 0 1 16 6v1.5" stroke-width="1.5" stroke-linecap="round"></path>
        </svg>
      </span>
      <h2 class="section-title mt-6 text-2xl font-semibold text-slate-950">No products yet</h2>
      <p class="mx-auto mt-3 max-w-xl text-base leading-7 text-slate-600">Create your first product to power the storefront, cart, and checkout experience.</p>
      <a href="/admin/products/new" class="mt-8 inline-flex items-center justify-center rounded-2xl bg-primary px-5 py-3 text-sm font-semibold text-white shadow-soft transition hover:bg-primary-dark">
        Add your first product
      </a>
    </div>
  <% } %>
</section>
