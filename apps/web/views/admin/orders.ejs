<%
  const money = typeof formatMoney === 'function' ? formatMoney : ((value) => value);
  const orderList = Array.isArray(orders) ? orders : [];
  const paidOrders = orderList.filter((entry) => String(entry.payment_status || '').trim().toLowerCase() === 'paid').length;
  const pendingOrders = orderList.filter((entry) => ['pending', 'confirmed'].includes(String(entry.status || '').trim().toLowerCase())).length;
  const refundWatchlist = orderList.filter((entry) => ['refund_pending', 'refunded'].includes(String(entry.status || '').trim().toLowerCase())).length;
  const orderStatusClass = (status) => {
    switch (String(status || '').trim().toLowerCase()) {
      case 'delivered':
        return 'bg-emerald-50 text-emerald-700';
      case 'confirmed':
      case 'shipped':
        return 'bg-sky-50 text-sky-700';
      case 'refund_pending':
        return 'bg-amber-50 text-amber-800';
      case 'refunded':
        return 'bg-slate-200 text-slate-700';
      case 'payment_failed':
        return 'bg-rose-50 text-rose-700';
      default:
        return 'bg-amber-50 text-amber-700';
    }
  };
  const paymentStatusClass = (status) => {
    switch (String(status || '').trim().toLowerCase()) {
      case 'paid':
        return 'bg-emerald-50 text-emerald-700';
      case 'refunded':
        return 'bg-slate-200 text-slate-700';
      case 'failed':
        return 'bg-rose-50 text-rose-700';
      default:
        return 'bg-amber-50 text-amber-700';
    }
  };
%>
<section class="space-y-8">
  <div class="surface-card rounded-[2.25rem] p-8">
    <div class="grid gap-8 xl:grid-cols-[1.05fr_0.95fr] xl:items-end">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary">Operations</p>
        <h1 class="mt-3 text-4xl font-semibold tracking-tight text-slate-950">Orders are where payment trust and fulfillment clarity either hold up or leak.</h1>
        <p class="mt-4 max-w-2xl text-base leading-7 text-slate-600">This queue now separates payment signal from fulfillment state so the owner can see what is truly paid, what is still pending, and which orders need refund handling.</p>
      </div>
      <div class="grid gap-4 sm:grid-cols-3">
        <article class="metric-card rounded-3xl p-5">
          <p class="text-sm font-medium text-slate-500">Total orders</p>
          <p class="metric-value mt-3 text-3xl font-semibold text-slate-950"><%= orderList.length %></p>
        </article>
        <article class="metric-card rounded-3xl p-5">
          <p class="text-sm font-medium text-slate-500">Paid</p>
          <p class="metric-value mt-3 text-3xl font-semibold text-slate-950"><%= paidOrders %></p>
        </article>
        <article class="metric-card rounded-3xl p-5">
          <p class="text-sm font-medium text-slate-500">Refund watch</p>
          <p class="metric-value mt-3 text-3xl font-semibold text-slate-950"><%= refundWatchlist %></p>
        </article>
      </div>
    </div>
  </div>

  <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
    <article class="metric-card rounded-3xl p-6">
      <p class="text-sm font-medium text-slate-500">Awaiting action</p>
      <p class="metric-value mt-3 text-3xl font-semibold text-slate-950"><%= pendingOrders %></p>
      <p class="mt-3 text-sm text-slate-500">Pending or confirmed orders that still need operator attention.</p>
    </article>
    <article class="metric-card rounded-3xl p-6">
      <p class="text-sm font-medium text-slate-500">Failed payments</p>
      <p class="metric-value mt-3 text-3xl font-semibold text-slate-950"><%= orderList.filter((entry) => String(entry.payment_status || '').trim().toLowerCase() === 'failed').length %></p>
      <p class="mt-3 text-sm text-slate-500">Useful for recovery workflows and checkout debugging.</p>
    </article>
    <article class="metric-card rounded-3xl p-6">
      <p class="text-sm font-medium text-slate-500">Delivered</p>
      <p class="metric-value mt-3 text-3xl font-semibold text-slate-950"><%= orderList.filter((entry) => String(entry.status || '').trim().toLowerCase() === 'delivered').length %></p>
      <p class="mt-3 text-sm text-slate-500">Orders that made it all the way through fulfillment.</p>
    </article>
    <article class="metric-card rounded-3xl p-6">
      <p class="text-sm font-medium text-slate-500">Refunded</p>
      <p class="metric-value mt-3 text-3xl font-semibold text-slate-950"><%= orderList.filter((entry) => String(entry.payment_status || '').trim().toLowerCase() === 'refunded').length %></p>
      <p class="mt-3 text-sm text-slate-500">Verified refunds from Paystack or Flutterwave.</p>
    </article>
  </div>

  <% if (orderList.length) { %>
    <div class="table-shell overflow-x-auto rounded-[2rem]">
      <table class="min-w-full divide-y divide-slate-200">
        <thead class="bg-slate-50">
          <tr>
            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Order</th>
            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Customer</th>
            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Date</th>
            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Total</th>
            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Payment</th>
            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Fulfillment</th>
            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Reference</th>
            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-200 bg-white">
          <% orderList.forEach((entry) => { %>
            <tr class="transition hover:bg-slate-50">
              <td class="px-6 py-4 text-sm font-medium text-slate-900">
                <a href="/admin/orders/<%= entry.id %>" class="font-semibold text-slate-900 transition hover:text-primary">#<%= entry.id %></a>
              </td>
              <td class="px-6 py-4 text-sm text-slate-600">
                <p class="font-medium text-slate-900"><%= entry.customer_name || (entry.customer && entry.customer.name) || 'Guest customer' %></p>
                <p class="mt-1 text-xs text-slate-400"><%= (entry.customer && entry.customer.email) || 'No email captured' %></p>
              </td>
              <td class="whitespace-nowrap px-6 py-4 text-sm text-slate-600"><%= entry.created_at ? new Date(entry.created_at).toLocaleString() : 'Just now' %></td>
              <td class="whitespace-nowrap px-6 py-4 text-sm font-semibold text-slate-900"><%= money(entry.total || 0) %></td>
              <td class="whitespace-nowrap px-6 py-4">
                <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold <%= paymentStatusClass(entry.payment_status) %>"><%= entry.payment_status || 'pending' %></span>
              </td>
              <td class="whitespace-nowrap px-6 py-4">
                <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold <%= orderStatusClass(entry.status) %>"><%= entry.status || 'pending' %></span>
              </td>
              <td class="px-6 py-4 text-xs text-slate-500">
                <% if (entry.payment_reference) { %>
                  <span class="rounded-xl bg-slate-100 px-3 py-2 font-mono text-[11px] text-slate-600"><%= entry.payment_reference %></span>
                <% } else { %>
                  <span>No payment reference yet</span>
                <% } %>
              </td>
              <td class="whitespace-nowrap px-6 py-4 text-sm">
                <a href="/admin/orders/<%= entry.id %>" class="font-semibold text-primary transition hover:underline">Open order</a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } else { %>
    <div class="surface-card rounded-[2rem] px-6 py-16 text-center">
      <span class="mx-auto inline-flex h-16 w-16 items-center justify-center rounded-3xl bg-primary-soft text-primary">
        <svg class="h-8 w-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
          <path d="M5 8h14" stroke-width="1.5" stroke-linecap="round"></path>
          <path d="M5 12h14" stroke-width="1.5" stroke-linecap="round"></path>
          <path d="M5 16h8" stroke-width="1.5" stroke-linecap="round"></path>
          <rect x="3.25" y="4.25" width="17.5" height="15.5" rx="2.75" stroke-width="1.5"></rect>
        </svg>
      </span>
      <h2 class="mt-6 text-2xl font-semibold text-slate-950">No orders yet</h2>
      <p class="mx-auto mt-3 max-w-2xl text-base leading-7 text-slate-600">This store still has the classic activation gap: no product-led route from first publish to first paid checkout. Finish settings, publish a product, and activate Paystack or Flutterwave before sending traffic.</p>
      <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
        <a href="/admin/products/new" class="inline-flex items-center justify-center rounded-2xl bg-primary px-5 py-3 text-sm font-semibold text-white shadow-soft transition hover:bg-primary-dark">Add product</a>
        <a href="/admin/settings" class="inline-flex items-center justify-center rounded-2xl border border-slate-200 px-5 py-3 text-sm font-medium text-slate-700 transition hover:border-primary hover:text-primary">Set up payments</a>
      </div>
    </div>
  <% } %>
</section>
