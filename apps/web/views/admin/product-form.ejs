<%
  const editing = !!product;
  const productData = product || {};
  const formTarget = editing ? `/admin/products/${productData.id}` : '/admin/products';
%>
<section class="space-y-8">
  <div class="flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary">Catalog</p>
      <h1 class="section-title mt-2 text-3xl font-semibold tracking-tight text-slate-950"><%= editing ? 'Edit product' : 'Add product' %></h1>
      <p class="mt-3 max-w-2xl text-base leading-7 text-slate-600">Shape how the product sells: pricing, copy, imagery, availability, and what customers should understand at a glance.</p>
    </div>
    <a href="/admin/products" class="inline-flex items-center justify-center rounded-2xl border border-slate-200 px-5 py-3 text-sm font-medium text-slate-700 transition hover:border-primary hover:text-primary">
      Back to products
    </a>
  </div>

  <form action="<%= formTarget %>" method="post" class="grid gap-8 xl:grid-cols-[1.15fr_0.85fr]">
    <div class="surface-card space-y-6 rounded-[2rem] p-6">
      <div class="grid gap-5 sm:grid-cols-2">
        <div class="sm:col-span-2">
          <label for="name" class="mb-1 block text-sm font-medium text-slate-700">Name</label>
          <input id="name" name="name" type="text" value="<%= productData.name || '' %>" class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="Atlas Carryall">
          <%- include('../partials/form-error', { field: 'name' }) %>
        </div>
        <div>
          <label for="category" class="mb-1 block text-sm font-medium text-slate-700">Category</label>
          <input id="category" name="category" type="text" value="<%= productData.category || '' %>" class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="Travel">
        </div>
        <div>
          <label for="sku" class="mb-1 block text-sm font-medium text-slate-700">SKU</label>
          <input id="sku" name="sku" type="text" value="<%= productData.sku || '' %>" class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="AIS-ATLAS-145">
          <%- include('../partials/form-error', { field: 'sku' }) %>
        </div>
      </div>

      <div>
        <label for="description" class="mb-1 block text-sm font-medium text-slate-700">Description</label>
        <textarea id="description" name="description" rows="7" class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="Write a concise, shopper-friendly description..."><%= productData.description || '' %></textarea>
        <%- include('../partials/form-error', { field: 'description' }) %>
      </div>

      <div>
        <label for="highlights" class="mb-1 block text-sm font-medium text-slate-700">Highlights</label>
        <textarea id="highlights" name="highlights" rows="5" class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="One product benefit per line"><%= Array.isArray(productData.highlights) ? productData.highlights.join('\n') : '' %></textarea>
      </div>

      <div class="grid gap-5 sm:grid-cols-2">
        <div>
          <label for="price" class="mb-1 block text-sm font-medium text-slate-700">Price</label>
          <input id="price" name="price" type="number" min="0" step="0.01" value="<%= typeof productData.price !== 'undefined' ? productData.price : '' %>" class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="145.00">
          <%- include('../partials/form-error', { field: 'price' }) %>
        </div>
        <div>
          <label for="compareAtPrice" class="mb-1 block text-sm font-medium text-slate-700">Compare at price</label>
          <input id="compareAtPrice" name="compare_at_price" type="number" min="0" step="0.01" value="<%= typeof productData.compare_at_price !== 'undefined' && productData.compare_at_price !== null ? productData.compare_at_price : '' %>" class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="168.00">
        </div>
        <div>
          <label for="inventory" class="mb-1 block text-sm font-medium text-slate-700">Inventory</label>
          <input id="inventory" name="inventory" type="number" min="0" step="1" value="<%= typeof productData.inventory !== 'undefined' ? productData.inventory : '' %>" class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="52">
        </div>
        <div class="flex items-center gap-3 rounded-2xl border border-slate-300 bg-white px-4 py-3 shadow-sm">
          <input id="featured" name="featured" type="checkbox" value="1" <%= productData.featured ? 'checked' : '' %> class="h-4 w-4 rounded border-slate-300 text-primary focus:ring-primary">
          <label for="featured" class="text-sm font-medium text-slate-700">Feature on storefront</label>
        </div>
      </div>
    </div>

    <div class="space-y-6">
      <div class="surface-card rounded-[2rem] p-6">
        <h2 class="text-lg font-semibold text-slate-950">Media</h2>
        <p class="mt-2 text-sm leading-6 text-slate-500">Use live image URLs so the product detail and catalog are fully populated immediately.</p>
        <div class="mt-6 space-y-5">
          <div>
            <label for="image" class="mb-1 block text-sm font-medium text-slate-700">Primary image URL</label>
            <input id="image" name="image" type="url" value="<%= productData.image || '' %>" class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="https://images.unsplash.com/...">
          </div>
          <div>
            <label for="gallery" class="mb-1 block text-sm font-medium text-slate-700">Gallery image URLs</label>
            <textarea id="gallery" name="gallery" rows="5" class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="One URL per line"><%= Array.isArray(productData.images) ? productData.images.join('\n') : '' %></textarea>
          </div>
        </div>
      </div>

      <div class="surface-card rounded-[2rem] p-6">
        <div class="flex items-start justify-between gap-4">
          <div>
            <h2 class="text-lg font-semibold text-slate-950">Publication</h2>
            <p class="mt-2 text-sm leading-6 text-slate-500">Decide whether the storefront should show this item immediately after saving.</p>
          </div>
          <label class="inline-flex cursor-pointer items-center gap-3 rounded-full bg-slate-100 px-4 py-2">
            <input name="status" type="checkbox" value="published" <%= productData.status === 'Published' ? 'checked' : '' %> class="h-4 w-4 rounded border-slate-300 text-primary focus:ring-primary">
            <span class="text-sm font-medium text-slate-700">Published</span>
          </label>
        </div>
        <p class="mt-4 rounded-2xl bg-slate-50 px-4 py-3 text-sm text-slate-600">Draft products remain hidden until your team is ready to go live.</p>
      </div>

      <div class="surface-card flex flex-col gap-3 rounded-[2rem] p-6 sm:flex-row sm:justify-end">
        <a href="/admin/products" class="inline-flex items-center justify-center rounded-2xl border border-slate-200 px-4 py-3 text-sm font-medium text-slate-700 transition hover:border-primary hover:text-primary">
          Cancel
        </a>
        <button type="submit" class="inline-flex items-center justify-center rounded-2xl bg-primary px-5 py-3 text-sm font-semibold text-white shadow-soft transition hover:bg-primary-dark">
          Save Product
        </button>
      </div>
    </div>
  </form>
</section>
