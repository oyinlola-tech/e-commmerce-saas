<%
  const money = typeof formatMoney === 'function' ? formatMoney : ((value) => value);
  const metrics = {
    totalProducts: stats && typeof stats.totalProducts !== 'undefined' ? stats.totalProducts : (Array.isArray(products) ? products.length : 0),
    publishedProducts: stats && typeof stats.publishedProducts !== 'undefined' ? stats.publishedProducts : 0,
    totalOrders: stats && typeof stats.totalOrders !== 'undefined' ? stats.totalOrders : (Array.isArray(orders) ? orders.length : 0),
    revenue30d: stats && typeof stats.revenue30d !== 'undefined' ? stats.revenue30d : 0,
    customersCount: stats && typeof stats.customersCount !== 'undefined' ? stats.customersCount : 0,
    marketsCount: stats && typeof stats.marketsCount !== 'undefined' ? stats.marketsCount : (store && Array.isArray(store.markets) ? store.markets.length : 0)
  };
  const orderList = Array.isArray(orders) ? orders : [];
  const recent = Array.isArray(recentOrders) ? recentOrders : orderList.slice(0, 5);
  const checklist = Array.isArray(launchChecklist) ? launchChecklist : [];
  const completedChecklistCount = checklist.filter((item) => item.complete).length;
  const nextMilestone = checklist.find((item) => !item.complete) || null;
  const paidOrdersCount = orderList.filter((entry) => String(entry.payment_status || '').trim().toLowerCase() === 'paid').length;
  const pendingOrdersCount = orderList.filter((entry) => ['pending', 'confirmed', 'refund_pending'].includes(String(entry.status || '').trim().toLowerCase())).length;
  const storefrontHost = store && store.custom_domain
    ? store.custom_domain
    : (store && store.subdomain && platformBrand && platformBrand.website ? `${store.subdomain}.${platformBrand.website}` : 'Not configured');
  const orderStatusClass = (status) => {
    switch (String(status || '').trim().toLowerCase()) {
      case 'delivered':
        return 'bg-emerald-50 text-emerald-700';
      case 'confirmed':
      case 'shipped':
        return 'bg-sky-50 text-sky-700';
      case 'refund_pending':
        return 'bg-amber-50 text-amber-800';
      case 'refunded':
        return 'bg-slate-200 text-slate-700';
      case 'payment_failed':
        return 'bg-rose-50 text-rose-700';
      default:
        return 'bg-amber-50 text-amber-700';
    }
  };
  const paymentStatusClass = (status) => {
    switch (String(status || '').trim().toLowerCase()) {
      case 'paid':
        return 'bg-emerald-50 text-emerald-700';
      case 'refunded':
        return 'bg-slate-200 text-slate-700';
      case 'failed':
        return 'bg-rose-50 text-rose-700';
      default:
        return 'bg-amber-50 text-amber-700';
    }
  };
%>
<section class="space-y-8">
  <div class="surface-card rounded-[2.25rem] p-8">
    <div class="grid gap-8 xl:grid-cols-[1.08fr_0.92fr] xl:items-start">
      <div>
        <span class="eyebrow">Store Command</span>
        <h1 class="section-title mt-5 text-4xl font-semibold tracking-tight text-slate-950">Move from store setup to first verified sale without losing trust on the way.</h1>
        <p class="mt-4 max-w-2xl text-lg leading-8 text-slate-600">
          This workspace now centers the launch path: store identity, payment readiness, catalog quality, and the orders that actually convert into paid revenue.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a href="/admin/products/new" class="inline-flex items-center justify-center rounded-2xl bg-primary px-5 py-3 text-sm font-semibold text-white shadow-soft transition hover:bg-primary-dark">Add first product</a>
          <a href="/admin/settings" class="inline-flex items-center justify-center rounded-2xl border border-slate-200 px-5 py-3 text-sm font-medium text-slate-700 transition hover:border-primary hover:text-primary">Configure payments</a>
          <a href="<%= storefrontUrl || '/' %>" target="_blank" rel="noreferrer" class="inline-flex items-center justify-center rounded-2xl border border-slate-200 px-5 py-3 text-sm font-medium text-slate-700 transition hover:border-primary hover:text-primary">Open storefront</a>
        </div>
      </div>

      <div class="space-y-4">
        <article class="metric-card rounded-3xl p-6">
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="text-sm font-medium text-slate-500">Revenue (last 30 days)</p>
              <p class="metric-value mt-3 text-3xl font-semibold text-slate-950"><%= money(metrics.revenue30d || 0) %></p>
            </div>
            <span class="inline-flex rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-emerald-700"><%= paidOrdersCount %> paid</span>
          </div>
          <p class="mt-4 text-sm text-slate-500">This now excludes failed and refunded orders so the owner sees closer-to-real revenue.</p>
        </article>

        <article class="rounded-3xl border border-slate-200 bg-white/90 p-6 shadow-soft">
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="text-sm font-medium text-slate-500">Launch checklist</p>
              <p class="mt-2 text-2xl font-semibold text-slate-950"><%= completedChecklistCount %> of <%= checklist.length || 0 %> complete</p>
            </div>
            <span class="inline-flex rounded-full <%= checklist.length && completedChecklistCount === checklist.length ? 'bg-emerald-50 text-emerald-700' : 'bg-amber-50 text-amber-800' %> px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em]"><%= checklist.length && completedChecklistCount === checklist.length ? 'Launch ready' : 'In progress' %></span>
          </div>
          <div class="mt-5 grid grid-cols-4 gap-2" aria-label="Launch checklist progress">
            <% (checklist.length ? checklist : [{}, {}, {}, {}]).forEach((item) => { %>
              <span class="h-2 rounded-full <%= item.complete ? 'bg-primary' : 'bg-slate-200' %>"></span>
            <% }) %>
          </div>
          <% if (nextMilestone) { %>
            <div class="mt-5 rounded-[1.5rem] border border-slate-200 bg-slate-50 p-4">
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">Next best action</p>
              <p class="mt-2 text-sm font-semibold text-slate-900"><%= nextMilestone.title %></p>
              <p class="mt-2 text-sm leading-6 text-slate-500"><%= nextMilestone.description %></p>
              <a href="<%= nextMilestone.href %>" class="mt-4 inline-flex text-sm font-semibold text-primary transition hover:underline"><%= nextMilestone.action %></a>
            </div>
          <% } %>
        </article>
      </div>
    </div>
  </div>

  <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
    <article class="metric-card rounded-3xl p-6">
      <p class="text-sm font-medium text-slate-500">Total products</p>
      <p class="metric-value mt-3 text-3xl font-semibold tracking-tight text-slate-950"><%= metrics.totalProducts %></p>
      <p class="mt-3 text-sm text-slate-500"><%= metrics.publishedProducts %> are currently live on the storefront.</p>
    </article>
    <article class="metric-card rounded-3xl p-6">
      <p class="text-sm font-medium text-slate-500">Orders to watch</p>
      <p class="metric-value mt-3 text-3xl font-semibold tracking-tight text-slate-950"><%= pendingOrdersCount %></p>
      <p class="mt-3 text-sm text-slate-500">Pending, confirmed, or refund-pending orders that need operator attention.</p>
    </article>
    <article class="metric-card rounded-3xl p-6">
      <p class="text-sm font-medium text-slate-500">Customers</p>
      <p class="metric-value mt-3 text-3xl font-semibold tracking-tight text-slate-950"><%= metrics.customersCount %></p>
      <p class="mt-3 text-sm text-slate-500">Known shoppers with saved identity in this store context.</p>
    </article>
    <article class="metric-card rounded-3xl p-6">
      <p class="text-sm font-medium text-slate-500">Markets served</p>
      <p class="metric-value mt-3 text-3xl font-semibold tracking-tight text-slate-950"><%= metrics.marketsCount %></p>
      <p class="mt-3 text-sm text-slate-500">Useful when you are localizing copy, logistics, and payment messaging.</p>
    </article>
  </div>

  <div class="grid gap-8 xl:grid-cols-[1.02fr_0.98fr]">
    <section class="surface-card rounded-[2rem] p-6">
      <div class="flex items-center justify-between gap-4">
        <div>
          <p class="text-sm font-medium text-slate-500">Launch path</p>
          <h2 class="section-title mt-1 text-2xl font-semibold text-slate-950">From onboarding friction to first sale</h2>
        </div>
        <span class="text-sm font-semibold text-slate-500"><%= completedChecklistCount %>/<%= checklist.length || 0 %> complete</span>
      </div>

      <div class="mt-6 space-y-4">
        <% checklist.forEach((item) => { %>
          <article class="rounded-[1.75rem] border <%= item.complete ? 'border-emerald-200 bg-emerald-50/70' : 'border-slate-200 bg-white' %> p-5">
            <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
              <div class="min-w-0">
                <div class="flex items-center gap-3">
                  <span class="inline-flex h-8 w-8 items-center justify-center rounded-full <%= item.complete ? 'bg-emerald-600 text-white' : 'bg-slate-100 text-slate-500' %> text-sm font-semibold"><%= item.complete ? 'OK' : '!' %></span>
                  <p class="text-base font-semibold text-slate-950"><%= item.title %></p>
                </div>
                <p class="mt-3 text-sm leading-6 text-slate-600"><%= item.description %></p>
              </div>
              <div class="flex flex-col gap-3 sm:items-end">
                <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] <%= item.complete ? 'bg-emerald-100 text-emerald-700' : 'bg-amber-50 text-amber-800' %>"><%= item.complete ? 'Complete' : 'Needed' %></span>
                <a href="<%= item.href %>" class="text-sm font-semibold text-primary transition hover:underline"><%= item.action %></a>
              </div>
            </div>
          </article>
        <% }) %>
      </div>
    </section>

    <section class="surface-card rounded-[2rem] p-6">
      <p class="text-sm font-medium text-slate-500">Trust and readiness</p>
      <h2 class="section-title mt-1 text-2xl font-semibold text-slate-950">What a shopper sees before paying</h2>

      <div class="mt-6 space-y-4">
        <article class="rounded-[1.75rem] border border-slate-200 bg-white p-5">
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="text-sm font-semibold text-slate-950">Storefront host</p>
              <p class="mt-2 text-sm text-slate-500"><%= storefrontHost %></p>
            </div>
            <a href="/admin/domain" class="text-sm font-semibold text-primary transition hover:underline">Update</a>
          </div>
        </article>

        <article class="rounded-[1.75rem] border border-slate-200 bg-white p-5">
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="text-sm font-semibold text-slate-950">Customer support identity</p>
              <p class="mt-2 text-sm text-slate-500"><%= store && store.support_email ? store.support_email : 'Add a real support email before launch.' %></p>
              <p class="mt-2 text-sm text-slate-500"><%= store && store.fulfillment_sla ? store.fulfillment_sla : 'Add a fulfillment promise so checkout feels credible.' %></p>
            </div>
            <a href="/admin/settings" class="text-sm font-semibold text-primary transition hover:underline">Edit</a>
          </div>
        </article>

        <article class="rounded-[1.75rem] border border-slate-200 bg-white p-5">
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="text-sm font-semibold text-slate-950">Catalog coverage</p>
              <p class="mt-2 text-sm text-slate-500"><%= metrics.publishedProducts ? `${metrics.publishedProducts} published product${metrics.publishedProducts === 1 ? '' : 's'} ready for discovery.` : 'No published products yet.' %></p>
              <p class="mt-2 text-sm text-slate-500">Product discovery does not work until real categories, prices, and inventory exist.</p>
            </div>
            <a href="/admin/products" class="text-sm font-semibold text-primary transition hover:underline">Manage</a>
          </div>
        </article>

        <article class="rounded-[1.75rem] border border-slate-200 bg-white p-5">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">Launch notes</p>
          <ul class="mt-4 space-y-3 text-sm leading-6 text-slate-600">
            <li class="flex items-start gap-3">
              <span class="mt-2 inline-flex h-2 w-2 rounded-full bg-primary"></span>
              <span>Paystack and Flutterwave should both be activated only after keys and webhook verification are complete.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-2 inline-flex h-2 w-2 rounded-full bg-primary"></span>
              <span>Dashboard revenue now reflects paid orders in the last 30 days instead of every order record.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-2 inline-flex h-2 w-2 rounded-full bg-primary"></span>
              <span>Refunds now belong in the order detail flow so operators can act against the verified payment reference.</span>
            </li>
          </ul>
        </article>
      </div>
    </section>
  </div>

  <section class="surface-card rounded-[2rem] p-6">
    <div class="flex items-center justify-between gap-4">
      <div>
        <p class="text-sm font-medium text-slate-500">Recent orders</p>
        <h2 class="section-title mt-1 text-2xl font-semibold text-slate-950">Verified payment and fulfillment signal</h2>
      </div>
      <a href="/admin/orders" class="text-sm font-semibold text-primary transition hover:underline">View all orders</a>
    </div>

    <% if (recent.length) { %>
      <div class="table-shell mt-6 overflow-x-auto rounded-[1.75rem]">
        <table class="min-w-full divide-y divide-slate-200">
          <thead class="bg-slate-50">
            <tr>
              <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Order</th>
              <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Customer</th>
              <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Date</th>
              <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Total</th>
              <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Payment</th>
              <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Order status</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-200 bg-white">
            <% recent.forEach((entry) => { %>
              <tr class="transition hover:bg-slate-50">
                <td class="px-6 py-4 text-sm font-medium text-slate-900">
                  <a href="/admin/orders/<%= entry.id %>" class="font-semibold text-slate-900 transition hover:text-primary">#<%= entry.id %></a>
                  <% if (entry.payment_reference) { %>
                    <p class="mt-1 font-mono text-xs text-slate-400"><%= entry.payment_reference %></p>
                  <% } %>
                </td>
                <td class="px-6 py-4 text-sm text-slate-600"><%= entry.customer_name || (entry.customer && entry.customer.name) || 'Guest customer' %></td>
                <td class="whitespace-nowrap px-6 py-4 text-sm text-slate-600"><%= entry.created_at ? new Date(entry.created_at).toLocaleDateString() : 'Today' %></td>
                <td class="whitespace-nowrap px-6 py-4 text-sm font-semibold text-slate-900"><%= money(entry.total || 0) %></td>
                <td class="whitespace-nowrap px-6 py-4">
                  <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold <%= paymentStatusClass(entry.payment_status) %>"><%= entry.payment_status || 'pending' %></span>
                </td>
                <td class="whitespace-nowrap px-6 py-4">
                  <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold <%= orderStatusClass(entry.status) %>"><%= entry.status || 'pending' %></span>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="mt-6 rounded-3xl border border-dashed border-slate-300 bg-slate-50 px-6 py-12 text-center">
        <p class="text-lg font-semibold text-slate-950">No orders yet</p>
        <p class="mx-auto mt-2 max-w-2xl text-sm leading-6 text-slate-500">This is the biggest product gap right now: the store owner needs a faster path from setup to a credible first checkout. Finish the checklist above, publish a product, and activate Paystack or Flutterwave.</p>
      </div>
    <% } %>
  </section>
</section>
