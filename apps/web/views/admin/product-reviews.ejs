<%
  const productData = product || {};
  const reviewList = Array.isArray(productReviews) ? productReviews : [];
  const approvedCount = reviewList.filter((entry) => entry.is_approved).length;
  const pendingCount = reviewList.filter((entry) => !entry.is_approved).length;
  const reviewStars = (rating) => `${'★'.repeat(Math.max(0, Math.min(5, Number(rating || 0))))}${'☆'.repeat(Math.max(0, 5 - Math.min(5, Number(rating || 0))))}`;
%>
<section class="space-y-8">
  <div class="flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary">Customer trust</p>
      <h1 class="section-title mt-2 text-3xl font-semibold tracking-tight text-slate-950">Product reviews</h1>
      <p class="mt-3 max-w-3xl text-base leading-7 text-slate-600">Moderate verified customer feedback before it appears on the storefront, and keep trust signals aligned with the actual buying experience.</p>
    </div>
    <div class="flex flex-wrap gap-3">
      <a href="/admin/products/<%= productData.id %>/edit" class="inline-flex items-center justify-center rounded-2xl border border-slate-200 px-5 py-3 text-sm font-medium text-slate-700 transition hover:border-primary hover:text-primary">
        Edit Product
      </a>
      <a href="/admin/products" class="inline-flex items-center justify-center rounded-2xl bg-primary px-5 py-3 text-sm font-semibold text-white shadow-soft transition hover:bg-primary-dark">
        Back to Products
      </a>
    </div>
  </div>

  <div class="grid gap-8 xl:grid-cols-[0.92fr_1.08fr]">
    <aside class="space-y-6">
      <section class="surface-card rounded-[2rem] p-6">
        <div class="flex gap-4">
          <img src="<%= productData.image %>" alt="<%= productData.name %>" loading="lazy" class="h-28 w-28 rounded-3xl object-cover">
          <div class="min-w-0 flex-1">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400"><%= productData.category || 'General' %></p>
            <h2 class="mt-2 text-2xl font-semibold text-slate-950"><%= productData.name || 'Product' %></h2>
            <p class="mt-2 text-sm text-slate-500"><%= productData.sku || 'No SKU assigned' %></p>
            <% if (productData.rating) { %>
              <p class="mt-3 text-sm font-medium text-slate-600"><%= productData.rating.toFixed(1) %>/5 from <%= productData.review_count || 0 %> approved reviews</p>
            <% } else { %>
              <p class="mt-3 text-sm font-medium text-slate-500">No approved reviews are live on the storefront yet.</p>
            <% } %>
          </div>
        </div>
      </section>

      <section class="surface-card rounded-[2rem] p-6">
        <p class="text-sm font-medium text-slate-500">Moderation snapshot</p>
        <div class="mt-5 grid gap-3 sm:grid-cols-3">
          <div class="rounded-2xl bg-slate-50 p-4">
            <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Total</p>
            <p class="mt-2 text-2xl font-semibold text-slate-950"><%= reviewList.length %></p>
          </div>
          <div class="rounded-2xl bg-emerald-50 p-4">
            <p class="text-xs uppercase tracking-[0.2em] text-emerald-700">Approved</p>
            <p class="mt-2 text-2xl font-semibold text-emerald-800"><%= approvedCount %></p>
          </div>
          <div class="rounded-2xl bg-amber-50 p-4">
            <p class="text-xs uppercase tracking-[0.2em] text-amber-700">Needs review</p>
            <p class="mt-2 text-2xl font-semibold text-amber-800"><%= pendingCount %></p>
          </div>
        </div>
      </section>
    </aside>

    <section class="surface-card rounded-[2rem] p-6">
      <div class="flex items-center justify-between gap-4">
        <div>
          <p class="text-sm font-medium text-slate-500">Feedback queue</p>
          <h2 class="mt-1 text-2xl font-semibold text-slate-950">Review moderation</h2>
        </div>
        <span class="inline-flex rounded-full bg-primary-soft px-3 py-1 text-sm font-semibold text-primary"><%= pendingCount %> pending</span>
      </div>

      <% if (reviewList.length) { %>
        <div class="mt-6 space-y-4">
          <% reviewList.forEach((review) => { %>
            <article class="rounded-[2rem] border border-slate-200 p-5">
              <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
                <div class="min-w-0 flex-1">
                  <div class="flex flex-wrap items-center gap-3">
                    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-amber-500"><%= reviewStars(review.rating) %></p>
                    <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold <%= review.is_approved ? 'bg-emerald-50 text-emerald-700' : 'bg-amber-50 text-amber-700' %>">
                      <%= review.is_approved ? 'Approved' : 'Needs approval' %>
                    </span>
                    <% if (review.verified_purchase) { %>
                      <span class="inline-flex rounded-full bg-sky-50 px-3 py-1 text-xs font-semibold text-sky-700">Verified purchase</span>
                    <% } %>
                  </div>
                  <h3 class="mt-3 text-lg font-semibold text-slate-950"><%= review.title || 'Customer review' %></h3>
                  <p class="mt-2 text-sm leading-6 text-slate-600"><%= review.body || 'No additional written feedback was provided.' %></p>
                  <div class="mt-4 flex flex-wrap gap-4 text-xs font-medium uppercase tracking-[0.16em] text-slate-400">
                    <span>Customer #<%= review.customer_id %></span>
                    <% if (review.order_item_id) { %>
                      <span>Order item #<%= review.order_item_id %></span>
                    <% } %>
                    <span>Submitted <%= review.created_at ? new Date(review.created_at).toLocaleString() : 'recently' %></span>
                  </div>
                </div>

                <form action="/admin/products/<%= productData.id %>/reviews/<%= review.id %>/moderate" method="post" class="sm:w-44">
                  <%- include('../partials/csrf-field') %>
                  <input type="hidden" name="is_approved" value="<%= review.is_approved ? 'false' : 'true' %>">
                  <button type="submit" class="inline-flex w-full items-center justify-center rounded-2xl border px-4 py-3 text-sm font-semibold transition <%= review.is_approved ? 'border-slate-200 text-slate-700 hover:border-rose-200 hover:text-rose-600' : 'border-emerald-200 bg-emerald-50 text-emerald-700 hover:border-emerald-300 hover:bg-emerald-100' %>">
                    <%= review.is_approved ? 'Hide review' : 'Approve review' %>
                  </button>
                </form>
              </div>
            </article>
          <% }) %>
        </div>
      <% } else { %>
        <div class="mt-6 rounded-[2rem] border border-dashed border-slate-300 bg-slate-50 px-6 py-14 text-center">
          <p class="text-lg font-semibold text-slate-950">No reviews yet</p>
          <p class="mt-2 text-sm leading-6 text-slate-500">Verified customer feedback will appear here as soon as shoppers start leaving reviews from the storefront.</p>
        </div>
      <% } %>
    </section>
  </div>
</section>
