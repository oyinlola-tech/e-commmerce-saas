<script id="currency-context-data" type="application/json">
  <%- JSON.stringify((currencyContext && currencyContext.client) || null).replace(/</g, '\\u003c') %>
</script>
<script nonce="<%= cspNonce %>">
  (() => {
    const focusableSelector = [
      'a[href]',
      'button:not([disabled])',
      'input:not([disabled]):not([type="hidden"])',
      'select:not([disabled])',
      'textarea:not([disabled])',
      '[tabindex]:not([tabindex="-1"])'
    ].join(',');

    const modalState = {
      activeId: null,
      previousFocus: null
    };

    const getFocusableElements = (container) => {
      if (!container) {
        return [];
      }

      return Array.from(container.querySelectorAll(focusableSelector)).filter((element) => {
        return !element.hasAttribute('hidden') && element.offsetParent !== null;
      });
    };

    window.slugify = (value = '') => {
      return String(value)
        .toLowerCase()
        .trim()
        .replace(/[^a-z0-9\s-]/g, '')
        .replace(/[\s_-]+/g, '-')
        .replace(/^-+|-+$/g, '');
    };

    window.openModal = (id) => {
      const modal = document.getElementById(id);
      if (!modal) {
        return;
      }

      modalState.previousFocus = document.activeElement;
      modalState.activeId = id;
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      modal.setAttribute('aria-hidden', 'false');
      document.body.classList.add('overflow-hidden');

      const focusable = getFocusableElements(modal);
      if (focusable.length) {
        focusable[0].focus();
      }
    };

    window.closeModal = (id) => {
      const modal = document.getElementById(id);
      if (!modal) {
        return;
      }

      modal.classList.remove('flex');
      modal.classList.add('hidden');
      modal.setAttribute('aria-hidden', 'true');
      document.body.classList.remove('overflow-hidden');

      if (modalState.previousFocus && typeof modalState.previousFocus.focus === 'function') {
        modalState.previousFocus.focus();
      }

      if (modalState.activeId === id) {
        modalState.activeId = null;
      }
    };

    const createToastIcon = (type) => {
      const svgNamespace = 'http://www.w3.org/2000/svg';
      const svg = document.createElementNS(svgNamespace, 'svg');
      const path = document.createElementNS(svgNamespace, 'path');

      svg.setAttribute('class', 'h-4 w-4');
      svg.setAttribute('viewBox', '0 0 20 20');
      svg.setAttribute('fill', 'currentColor');
      svg.setAttribute('aria-hidden', 'true');

      if (type === 'error') {
        path.setAttribute('fill-rule', 'evenodd');
        path.setAttribute('clip-rule', 'evenodd');
        path.setAttribute('d', 'M18 10A8 8 0 112 10a8 8 0 0116 0zm-8-4a1 1 0 00-1 1v3a1 1 0 102 0V7a1 1 0 00-1-1zm0 8a1.25 1.25 0 100-2.5A1.25 1.25 0 0010 14z');
      } else {
        path.setAttribute('fill-rule', 'evenodd');
        path.setAttribute('clip-rule', 'evenodd');
        path.setAttribute('d', 'M16.704 5.29a1 1 0 010 1.42l-7.2 7.2a1 1 0 01-1.415 0l-3-3a1 1 0 111.414-1.42l2.293 2.294 6.493-6.494a1 1 0 011.415 0z');
      }

      svg.appendChild(path);
      return svg;
    };

    window.showToast = (message, type = 'success') => {
      const containerId = 'toast-container';
      let container = document.getElementById(containerId);
      const isError = type === 'error';

      if (!container) {
        container = document.createElement('div');
        container.id = containerId;
        container.className = 'fixed bottom-4 right-4 z-[70] flex w-full max-w-sm flex-col gap-3 px-4 sm:px-0';
        document.body.appendChild(container);
      }

      const toast = document.createElement('div');
      toast.className = `toast-enter rounded-2xl border bg-white p-4 shadow-lg ${isError ? 'border-red-200' : 'border-emerald-200'}`;

      const content = document.createElement('div');
      content.className = 'flex items-start gap-3';

      const icon = document.createElement('span');
      icon.className = `mt-0.5 inline-flex h-8 w-8 flex-none items-center justify-center rounded-full ${isError ? 'bg-red-100 text-red-600' : 'bg-emerald-100 text-emerald-600'}`;
      icon.appendChild(createToastIcon(type));

      const body = document.createElement('div');
      body.className = 'min-w-0 flex-1';

      const title = document.createElement('p');
      title.className = 'text-sm font-semibold text-gray-900';
      title.textContent = isError ? 'Unable to continue' : 'Done';

      const description = document.createElement('p');
      description.className = 'mt-1 text-sm text-gray-600';
      description.textContent = String(message ?? '');

      body.append(title, description);
      content.append(icon, body);
      toast.appendChild(content);

      container.appendChild(toast);

      window.setTimeout(() => {
        toast.classList.remove('toast-enter');
        toast.classList.add('toast-exit');
        window.setTimeout(() => toast.remove(), 180);
      }, 3000);
    };

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && modalState.activeId) {
        window.closeModal(modalState.activeId);
      }

      if (event.key !== 'Tab' || !modalState.activeId) {
        return;
      }

      const modal = document.getElementById(modalState.activeId);
      const focusable = getFocusableElements(modal);
      if (!focusable.length) {
        return;
      }

      const first = focusable[0];
      const last = focusable[focusable.length - 1];

      if (event.shiftKey && document.activeElement === first) {
        event.preventDefault();
        last.focus();
      } else if (!event.shiftKey && document.activeElement === last) {
        event.preventDefault();
        first.focus();
      }
    });

    document.addEventListener('click', (event) => {
      const modalOpenTrigger = event.target.closest('[data-modal-open]');
      if (modalOpenTrigger) {
        event.preventDefault();
        window.openModal(modalOpenTrigger.dataset.modalOpen);
        return;
      }

      const modalCloseTrigger = event.target.closest('[data-modal-close]');
      if (modalCloseTrigger) {
        event.preventDefault();
        window.closeModal(modalCloseTrigger.dataset.modalClose);
        return;
      }

      const dismissTrigger = event.target.closest('[data-dismiss-parent]');
      if (dismissTrigger) {
        const target = dismissTrigger.closest(dismissTrigger.dataset.dismissParent);
        if (target) {
          target.remove();
        }
        return;
      }

      const backdrop = event.target.closest('[data-modal-backdrop]');
      if (backdrop && backdrop === event.target) {
        window.closeModal(backdrop.dataset.modalBackdrop);
      }
    });

    document.addEventListener('DOMContentLoaded', () => {
      try {
        const key = 'aisle.currencyContext';
        const payloadNode = document.getElementById('currency-context-data');
        const payload = payloadNode ? JSON.parse(payloadNode.textContent || 'null') : null;
        if (payload) {
          sessionStorage.setItem(key, JSON.stringify(payload));
        }
      } catch (error) {
        // Ignore storage access failures in private browsing modes.
      }

      const closePopover = (popover) => {
        if (!popover) {
          return;
        }

        const button = popover.querySelector('[data-popover-button]');
        const panel = popover.querySelector('[data-popover-panel]');
        if (!button || !panel) {
          return;
        }

        button.setAttribute('aria-expanded', 'false');
        panel.classList.add('hidden');
      };

      const openPopover = (popover) => {
        if (!popover) {
          return;
        }

        document.querySelectorAll('[data-popover]').forEach((entry) => {
          if (entry !== popover) {
            closePopover(entry);
          }
        });

        const button = popover.querySelector('[data-popover-button]');
        const panel = popover.querySelector('[data-popover-panel]');
        if (!button || !panel) {
          return;
        }

        button.setAttribute('aria-expanded', 'true');
        panel.classList.remove('hidden');
      };

      const syncMobileNavState = (button, panel, isOpen) => {
        if (!button || !panel) {
          return;
        }

        button.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
        panel.classList.toggle('hidden', !isOpen);

        button.querySelectorAll('[data-mobile-nav-icon]').forEach((icon) => {
          const shouldShow = icon.dataset.mobileNavIcon === (isOpen ? 'open' : 'closed');
          icon.classList.toggle('hidden', !shouldShow);
        });
      };

      document.querySelectorAll('[data-popover]').forEach((popover) => {
        const button = popover.querySelector('[data-popover-button]');
        const panel = popover.querySelector('[data-popover-panel]');
        if (!button || !panel) {
          return;
        }

        closePopover(popover);

        button.addEventListener('click', (event) => {
          event.preventDefault();
          const isExpanded = button.getAttribute('aria-expanded') === 'true';
          if (isExpanded) {
            closePopover(popover);
          } else {
            openPopover(popover);
          }
        });
      });

      document.addEventListener('click', (event) => {
        document.querySelectorAll('[data-popover]').forEach((popover) => {
          if (!popover.contains(event.target)) {
            closePopover(popover);
          }
        });
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          document.querySelectorAll('[data-popover]').forEach((popover) => closePopover(popover));
        }
      });

      document.querySelectorAll('[data-mobile-nav-button]').forEach((button) => {
        const targetId = button.getAttribute('aria-controls');
        const panel = targetId ? document.getElementById(targetId) : null;
        if (!panel) {
          return;
        }

        syncMobileNavState(button, panel, false);

        button.addEventListener('click', (event) => {
          event.preventDefault();
          const isOpen = button.getAttribute('aria-expanded') === 'true';
          syncMobileNavState(button, panel, !isOpen);
        });

        panel.querySelectorAll('a').forEach((link) => {
          link.addEventListener('click', () => {
            syncMobileNavState(button, panel, false);
          });
        });
      });

      document.querySelectorAll('[data-submit-on-change]').forEach((control) => {
        control.addEventListener('change', () => {
          const form = control.closest('form');
          if (!form) {
            return;
          }

          if (typeof form.requestSubmit === 'function') {
            form.requestSubmit();
            return;
          }

          form.submit();
        });
      });

      const getControlSource = (control) => {
        if (!control) {
          return null;
        }

        if (control.tagName === 'SELECT') {
          return control.options[control.selectedIndex] || null;
        }

        return control;
      };

      const syncTemplateSelection = (templateInput, options = {}) => {
        const { markEdited = false } = options;
        const source = getControlSource(templateInput);
        if (!source) {
          return;
        }

        const container = templateInput.closest('form') || document;
        const templateKeyInput = container.querySelector('[data-template-key-input]');
        const colorInput = container.querySelector('[data-template-color-input]');
        const colorLabel = container.querySelector('[data-template-color-label]');
        const fontInput = container.querySelector('[data-template-font-input]');
        const nameLabel = container.querySelector('[data-template-name-label]');
        const typeLabel = container.querySelector('[data-template-type-label]');
        const fontLabel = container.querySelector('[data-template-font-label]');

        if (templateKeyInput) {
          templateKeyInput.value = source.dataset.templateKey || source.value || templateInput.value;
          if (markEdited) {
            templateKeyInput.dataset.userEdited = 'true';
          }
        }

        if (colorInput && colorInput.dataset.userEdited !== 'true' && source.dataset.templateDefaultColor) {
          colorInput.value = source.dataset.templateDefaultColor;
        }

        if (colorLabel && colorInput) {
          colorLabel.textContent = colorInput.value;
        }

        if (fontInput && fontInput.dataset.userEdited !== 'true' && source.dataset.templateFont) {
          fontInput.value = source.dataset.templateFont;
        }

        if (nameLabel) {
          nameLabel.textContent = source.dataset.templateLabel || source.value || templateInput.value;
        }

        if (typeLabel) {
          typeLabel.textContent = source.dataset.templateTypeLabel || source.dataset.templateLabel || source.value || templateInput.value;
        }

        if (fontLabel && fontInput) {
          const selectedOption = fontInput.options[fontInput.selectedIndex];
          fontLabel.textContent = selectedOption ? selectedOption.textContent : fontInput.value;
        }
      };

      const filterTemplateOptionsForStoreType = (control) => {
        const source = getControlSource(control);
        if (!source) {
          return;
        }

        const container = control.closest('form') || document;
        const templateSelect = container.querySelector('select[name="template_picker"]');
        if (!templateSelect) {
          return;
        }

        const allowedTemplateKeys = String(source.dataset.templateKeys || source.dataset.recommendedTemplate || '')
          .split(',')
          .map((entry) => entry.trim())
          .filter(Boolean);
        const templateOptions = Array.from(templateSelect.querySelectorAll('[data-template-option]'));

        templateOptions.forEach((option) => {
          const optionKey = option.dataset.templateKey || option.value;
          const relatedStoreTypes = String(option.dataset.templateStoreTypes || '')
            .split(',')
            .map((entry) => entry.trim())
            .filter(Boolean);
          const allowed = !allowedTemplateKeys.length
            || allowedTemplateKeys.includes(optionKey)
            || relatedStoreTypes.includes(source.value);

          option.hidden = !allowed;
          option.disabled = !allowed;
        });

        const activeOption = getControlSource(templateSelect);
        if (!activeOption || activeOption.disabled || activeOption.hidden) {
          const firstAvailableOption = templateOptions.find((option) => !option.disabled && !option.hidden);
          if (firstAvailableOption) {
            templateSelect.value = firstAvailableOption.value;
          }
        }

        syncTemplateSelection(templateSelect);
      };

      const syncStoreTypeSelection = (control) => {
        const source = getControlSource(control);
        if (!source) {
          return;
        }

        const container = control.closest('form') || document;
        const storeTypeLabel = container.querySelector('[data-store-type-label]');
        const recommendationLabel = container.querySelector('[data-store-type-recommendation-label]');
        const templateKeyInput = container.querySelector('[data-template-key-input]');
        const recommendedTemplateKey = source.dataset.recommendedTemplate || '';
        const recommendedTemplateLabel = source.dataset.recommendedTemplateLabel || '';
        const recommendedFontKey = source.dataset.recommendedFont || '';
        const recommendedFontLabel = source.dataset.recommendedFontLabel || '';
        const autoFillFromStoreType = container.dataset.storeTypeAutofill === 'true';
        const canApplyRecommendations = autoFillFromStoreType && (!templateKeyInput || templateKeyInput.dataset.userEdited !== 'true');

        if (storeTypeLabel) {
          storeTypeLabel.textContent = source.dataset.storeTypeLabel || control.value;
        }

        if (recommendationLabel) {
          recommendationLabel.textContent = recommendedTemplateLabel && recommendedFontLabel
            ? `Recommended starter: ${recommendedTemplateLabel} + ${recommendedFontLabel}`
            : 'Recommended starter available after store type selection.';
        }

        filterTemplateOptionsForStoreType(control);

        if (canApplyRecommendations && recommendedTemplateKey) {
          const recommendedTemplateInput = container.querySelector('select[name="template_picker"]');
          if (recommendedTemplateInput) {
            recommendedTemplateInput.value = recommendedTemplateKey;
            syncTemplateSelection(recommendedTemplateInput);
          } else {
            const recommendedRadioInput = container.querySelector(`[data-template-option][data-template-key="${recommendedTemplateKey}"]`);
            if (recommendedRadioInput) {
              recommendedRadioInput.checked = true;
              syncTemplateSelection(recommendedRadioInput);
            }
          }
        }

        if (canApplyRecommendations && recommendedFontKey) {
          const fontInput = container.querySelector('[data-template-font-input]');
          if (fontInput && fontInput.dataset.userEdited !== 'true') {
            fontInput.value = recommendedFontKey;
            const fontLabel = container.querySelector('[data-template-font-label]');
            const selectedOption = fontInput.options[fontInput.selectedIndex];
            if (fontLabel) {
              fontLabel.textContent = selectedOption ? selectedOption.textContent : fontInput.value;
            }
          }
        }
      };

      document.querySelectorAll('[data-auto-slug-source]').forEach((source) => {
        const targetSelector = source.dataset.autoSlugTarget;
        const target = targetSelector ? document.querySelector(targetSelector) : null;

        if (!target) {
          return;
        }

        source.addEventListener('input', () => {
          if (target.dataset.userEdited === 'true') {
            return;
          }

          target.value = window.slugify(source.value);
        });

        target.addEventListener('input', () => {
          target.dataset.userEdited = target.value.trim() ? 'true' : 'false';
        });
      });

      const pricingToggle = document.querySelector('[data-pricing-toggle]');
      if (pricingToggle) {
        const updatePricing = (mode) => {
          document.querySelectorAll('[data-price-card]').forEach((card) => {
            const value = mode === 'yearly' ? card.dataset.priceYearly : card.dataset.priceMonthly;
            const suffix = mode === 'yearly' ? '/year' : '/month';
            const priceNode = card.querySelector('[data-price-value]');
            const suffixNode = card.querySelector('[data-price-suffix]');
            const yearlyMetaNode = card.querySelector('[data-price-yearly-meta]');
            const originalNode = card.querySelector('[data-price-original]');
            const discountNode = card.querySelector('[data-price-discount]');

            if (priceNode) {
              priceNode.textContent = value;
            }

            if (suffixNode) {
              suffixNode.textContent = suffix;
            }

            if (mode === 'yearly') {
              if (originalNode) {
                originalNode.textContent = card.dataset.priceYearlyOriginal || '';
              }

              if (discountNode) {
                discountNode.textContent = card.dataset.priceYearlyDiscount || '';
              }

              if (yearlyMetaNode) {
                yearlyMetaNode.classList.remove('hidden');
                yearlyMetaNode.classList.add('flex');
              }
            } else if (yearlyMetaNode) {
              yearlyMetaNode.classList.add('hidden');
              yearlyMetaNode.classList.remove('flex');
            }
          });

          document.querySelectorAll('[data-billing-copy]').forEach((node) => {
            const yearlyCopy = node.dataset.billingCopyYearly || 'Save 20% with annual billing';
            const monthlyCopy = node.dataset.billingCopyMonthly || 'Switch to annual billing and save 20%';
            node.textContent = mode === 'yearly' ? yearlyCopy : monthlyCopy;
          });
        };

        updatePricing(pricingToggle.checked ? 'yearly' : 'monthly');

        pricingToggle.addEventListener('change', () => {
          updatePricing(pricingToggle.checked ? 'yearly' : 'monthly');
        });
      }

      document.querySelectorAll('input[data-template-option]').forEach((input) => {
        if (input.checked) {
          syncTemplateSelection(input);
        }

        input.addEventListener('change', () => {
          if (input.checked) {
            syncTemplateSelection(input, { markEdited: true });
          }
        });
      });

      document.querySelectorAll('select[name="template_picker"]').forEach((control) => {
        syncTemplateSelection(control);
        control.addEventListener('change', () => {
          syncTemplateSelection(control, { markEdited: true });
        });
      });

      document.querySelectorAll('select[name="store_type"], input[data-store-type-option]').forEach((control) => {
        if (control.matches('select')) {
          syncStoreTypeSelection(control);
          control.addEventListener('change', () => {
            syncStoreTypeSelection(control);
          });
          return;
        }

        if (control.checked) {
          syncStoreTypeSelection(control);
        }

        control.addEventListener('change', () => {
          if (control.checked) {
            syncStoreTypeSelection(control);
          }
        });
      });

      document.querySelectorAll('[data-template-color-input]').forEach((input) => {
        const container = input.closest('form') || document;
        const label = container.querySelector('[data-template-color-label]');

        const syncColorLabel = () => {
          if (label) {
            label.textContent = input.value;
          }
        };

        syncColorLabel();

        input.addEventListener('input', () => {
          input.dataset.userEdited = 'true';
          syncColorLabel();
        });
      });

      document.querySelectorAll('[data-template-font-input]').forEach((input) => {
        const container = input.closest('form') || document;
        const label = container.querySelector('[data-template-font-label]');

        const syncFontLabel = () => {
          if (!label) {
            return;
          }

          const selectedOption = input.options[input.selectedIndex];
          label.textContent = selectedOption ? selectedOption.textContent : input.value;
        };

        syncFontLabel();

        input.addEventListener('change', () => {
          input.dataset.userEdited = 'true';
          syncFontLabel();
        });
      });

    });
  })();
</script>
