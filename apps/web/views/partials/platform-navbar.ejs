<%
  const isSignedIn = Boolean(platformUser && platformUser.id);
  const userName = platformUser && platformUser.name ? platformUser.name : 'Owner';
  const initials = userName
    .split(' ')
    .map((part) => part[0])
    .filter(Boolean)
    .slice(0, 2)
    .join('')
    .toUpperCase();
  const availableCurrencies = Array.isArray(currencyOptions) ? currencyOptions : [];
  const workspaceHref = platformHomeUrl || '/dashboard';
  const workspaceLabel = platformIsAdmin ? 'Platform Dashboard' : 'Owner Workspace';
  const workspaceLabelShort = platformIsAdmin ? 'Platform dashboard' : 'Owner workspace';
%>
<header class="sticky top-0 z-40 border-b border-slate-200/70 bg-white/80 backdrop-blur-xl">
  <nav class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between py-4">
      <a href="/" class="flex items-center gap-3">
        <img src="/brand/aisle-logo.svg" alt="Aisle" class="h-12 w-auto">
        <span>
          <span class="block text-xs font-semibold uppercase tracking-[0.34em] text-slate-500">Commerce Workspace</span>
          <span class="block section-title text-lg font-semibold text-slate-950">Built to feel shipped</span>
        </span>
      </a>

      <div class="hidden items-center gap-8 md:flex">
        <a href="/#features" class="text-sm font-medium text-slate-600 transition hover:text-primary">Platform</a>
        <a href="/#pricing" class="text-sm font-medium text-slate-600 transition hover:text-primary">Pricing</a>
        <a href="/#faq" class="text-sm font-medium text-slate-600 transition hover:text-primary">FAQ</a>
      </div>

      <div class="hidden items-center gap-3 md:flex">
        <% if (availableCurrencies.length > 1) { %>
          <form action="/preferences/currency" method="post" class="flex items-center gap-2 rounded-2xl border border-slate-200 bg-white px-3 py-2 shadow-sm">
            <%- include('./csrf-field') %>
            <input type="hidden" name="returnTo" value="<%= currentUrl || currentPath || '/' %>">
            <label for="platform-currency" class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Currency</label>
            <select id="platform-currency" name="code" data-submit-on-change class="border-0 bg-transparent pr-6 text-sm font-medium text-slate-700 focus:outline-none focus:ring-0">
              <% availableCurrencies.forEach((entry) => { %>
                <option value="<%= entry.code %>" <%= selectedCurrency === entry.code ? 'selected' : '' %>><%= entry.label %></option>
              <% }) %>
            </select>
          </form>
        <% } %>
        <% if (isSignedIn) { %>
          <a href="<%= workspaceHref %>" class="rounded-xl bg-primary px-4 py-2.5 text-sm font-semibold text-white shadow-soft transition hover:bg-primary-dark"><%= workspaceLabel %></a>
          <div class="relative" data-popover>
            <button type="button" data-popover-button aria-expanded="false" class="flex items-center gap-3 rounded-full border border-slate-200 bg-white px-2 py-2 shadow-sm transition hover:border-primary focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2">
              <span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-slate-950 text-sm font-semibold text-white"><%= initials || 'AA' %></span>
              <span class="hidden text-left lg:block">
                <span class="block text-sm font-semibold text-slate-900"><%= userName %></span>
                <span class="block text-xs text-slate-500"><%= platformUser && platformUser.email ? platformUser.email : 'support@aisle.so' %></span>
              </span>
            </button>
            <div data-popover-panel class="absolute right-0 mt-3 hidden w-60 rounded-2xl border border-slate-200 bg-white p-2 shadow-soft">
              <a href="<%= workspaceHref %>" class="block rounded-xl px-4 py-2 text-sm text-slate-700 transition hover:bg-slate-50 hover:text-primary"><%= workspaceLabelShort %></a>
              <form action="/logout" method="post" class="px-2 py-1">
                <%- include('./csrf-field') %>
                <button type="submit" class="block w-full rounded-xl px-4 py-2 text-left text-sm text-slate-700 transition hover:bg-slate-50 hover:text-primary">Sign out</button>
              </form>
            </div>
          </div>
        <% } else { %>
          <a href="/login" class="rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-primary hover:text-primary">Sign In</a>
          <a href="/signup" class="rounded-xl bg-primary px-4 py-2.5 text-sm font-semibold text-white shadow-soft transition hover:bg-primary-dark">Create Account</a>
        <% } %>
      </div>

      <button type="button" data-mobile-nav-button aria-controls="platform-mobile-nav" aria-expanded="false" class="inline-flex h-11 w-11 items-center justify-center rounded-2xl border border-slate-200 text-slate-700 md:hidden" aria-label="Toggle navigation">
        <svg data-mobile-nav-icon="closed" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M3 5a1 1 0 011-1h12a1 1 0 110 2H4A1 1 0 013 5zm0 5a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm1 4a1 1 0 100 2h12a1 1 0 100-2H4z" clip-rule="evenodd"></path>
        </svg>
        <svg data-mobile-nav-icon="open" class="hidden h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path>
        </svg>
      </button>
    </div>

    <div id="platform-mobile-nav" class="hidden space-y-3 border-t border-slate-200 pb-5 pt-4 md:hidden">
      <% if (availableCurrencies.length > 1) { %>
        <form action="/preferences/currency" method="post" class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
          <%- include('./csrf-field') %>
          <input type="hidden" name="returnTo" value="<%= currentUrl || currentPath || '/' %>">
          <label for="platform-currency-mobile" class="mb-2 block text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Currency</label>
          <select id="platform-currency-mobile" name="code" data-submit-on-change class="w-full rounded-xl border border-slate-200 bg-white px-3 py-3 text-sm font-medium text-slate-700 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20">
            <% availableCurrencies.forEach((entry) => { %>
              <option value="<%= entry.code %>" <%= selectedCurrency === entry.code ? 'selected' : '' %>><%= entry.label %></option>
            <% }) %>
          </select>
        </form>
      <% } %>
      <a href="/#features" class="block rounded-xl px-4 py-3 text-sm font-medium text-slate-700 transition hover:bg-slate-50 hover:text-primary">Platform</a>
      <a href="/#pricing" class="block rounded-xl px-4 py-3 text-sm font-medium text-slate-700 transition hover:bg-slate-50 hover:text-primary">Pricing</a>
      <a href="/#faq" class="block rounded-xl px-4 py-3 text-sm font-medium text-slate-700 transition hover:bg-slate-50 hover:text-primary">FAQ</a>
      <div class="flex flex-col gap-3 pt-2">
        <% if (isSignedIn) { %>
          <a href="<%= workspaceHref %>" class="rounded-xl bg-primary px-4 py-3 text-center text-sm font-semibold text-white"><%= workspaceLabel %></a>
          <form action="/logout" method="post">
            <%- include('./csrf-field') %>
            <button type="submit" class="w-full rounded-xl border border-slate-200 px-4 py-3 text-center text-sm font-medium text-slate-700">Sign out</button>
          </form>
        <% } else { %>
          <a href="/signup" class="rounded-xl bg-primary px-4 py-3 text-center text-sm font-semibold text-white">Create Account</a>
          <a href="/login" class="rounded-xl border border-slate-200 px-4 py-3 text-center text-sm font-medium text-slate-700">Sign In</a>
        <% } %>
      </div>
    </div>
  </nav>
</header>
