<%
  const storefrontName = store && store.name ? store.name : 'Aisle';
  const storefrontLogo = store && store.logo ? store.logo : null;
  const cartItems = cart && Array.isArray(cart.items) ? cart.items : [];
  const cartCount = cartItems.length;
  const storeThemeData = typeof storeTheme !== 'undefined'
    ? storeTheme
    : (typeof currentStoreTheme !== 'undefined' ? currentStoreTheme : {});
  const storeTags = Array.isArray(storeThemeData.marketingTags) ? storeThemeData.marketingTags : [];
  const availableCurrencies = Array.isArray(currencyOptions) ? currencyOptions : [];
  const detectedLocation = visitorLocation || null;
%>
<header x-data="{ mobileOpen: false }" class="sticky top-0 z-40 border-b border-slate-200/70 bg-white/85 backdrop-blur-xl">
  <div class="border-b border-slate-100 bg-slate-950 text-slate-100">
    <div class="mx-auto flex max-w-7xl flex-col gap-2 px-4 py-3 text-xs font-medium sm:flex-row sm:items-center sm:justify-between sm:px-6 lg:px-8">
      <p><%= storeThemeData.label || storeThemeData.templateLabel || 'Storefront' %> for <%= storeThemeData.storeTypeLabel || storeThemeData.typeLabel || 'general commerce' %> across <%= store && store.markets ? store.markets.length : 1 %> markets.</p>
      <p><%= detectedLocation && detectedLocation.countryName ? `Showing prices for ${detectedLocation.countryName} in ${selectedCurrency}.` : (selectedCurrency && selectedCurrency !== baseCurrency ? `Prices currently shown in ${selectedCurrency}.` : (storeTags[0] || (store && store.fulfillment_sla ? store.fulfillment_sla : 'Fast fulfillment available.'))) %></p>
    </div>
  </div>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between py-4">
      <a href="/" class="flex min-w-0 items-center gap-3">
        <% if (storefrontLogo) { %>
          <img src="<%= storefrontLogo %>" alt="<%= storefrontName %> logo" class="h-12 w-12 rounded-2xl object-cover shadow-sm">
        <% } else { %>
          <span class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-primary text-lg font-bold text-white shadow-soft"><%= storefrontName.charAt(0).toUpperCase() %></span>
        <% } %>
        <div class="min-w-0">
          <span class="block truncate text-xs font-semibold uppercase tracking-[0.3em] text-slate-500"><%= storeThemeData.label || 'Flagship Store' %></span>
          <span class="block section-title truncate text-xl font-semibold text-slate-950"><%= storefrontName %></span>
        </div>
      </a>

      <nav class="hidden items-center gap-8 md:flex">
        <a href="/" class="text-sm font-medium text-slate-600 transition hover:text-primary">Home</a>
        <a href="/products" class="text-sm font-medium text-slate-600 transition hover:text-primary">Catalog</a>
        <a href="/orders" class="text-sm font-medium text-slate-600 transition hover:text-primary">Orders</a>
      </nav>

      <div class="hidden items-center gap-3 md:flex">
        <% if (availableCurrencies.length > 1) { %>
          <form action="/preferences/currency" method="post" class="flex items-center gap-2 rounded-2xl border border-slate-200 bg-white px-3 py-2 shadow-sm">
            <input type="hidden" name="returnTo" value="<%= currentUrl || currentPath || '/' %>">
            <input type="hidden" name="scope" value="store">
            <label for="desktop-currency" class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Currency</label>
            <select id="desktop-currency" name="code" onchange="this.form.submit()" class="border-0 bg-transparent pr-6 text-sm font-medium text-slate-700 focus:outline-none focus:ring-0">
              <% availableCurrencies.forEach((entry) => { %>
                <option value="<%= entry.code %>" <%= selectedCurrency === entry.code ? 'selected' : '' %>><%= entry.code %></option>
              <% }) %>
            </select>
          </form>
        <% } %>
        <button type="button" data-cart-open class="relative inline-flex h-11 w-11 items-center justify-center rounded-2xl border border-slate-200 bg-white text-slate-700 transition hover:border-primary hover:text-primary focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2" aria-label="Open cart">
          <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path d="M3 3a1 1 0 000 2h1.22l.756 3.026A2 2 0 006.916 9.5h7.168a2 2 0 001.94-1.474L17.78 4H6.28l-.31-1.238A1 1 0 005 2H3z"></path>
            <path d="M6 14a2 2 0 100 4 2 2 0 000-4zm8 0a2 2 0 100 4 2 2 0 000-4z"></path>
          </svg>
          <span data-cart-count class="cart-badge absolute -right-1 -top-1 inline-flex h-6 min-w-[1.5rem] items-center justify-center rounded-full bg-primary px-1.5 text-xs font-semibold text-white"><%= cartCount %></span>
        </button>

        <% if (customer) { %>
          <div x-data="{ open: false }" class="relative">
            <button type="button" @click="open = !open" @click.outside="open = false" class="flex items-center gap-3 rounded-full border border-slate-200 bg-white px-2 py-2 shadow-sm transition hover:border-primary focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2">
              <span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-slate-950 text-sm font-semibold text-white"><%= customer.name ? customer.name.charAt(0).toUpperCase() : 'C' %></span>
              <span class="hidden text-left lg:block">
                <span class="block text-sm font-semibold text-slate-900"><%= customer.name || 'My Account' %></span>
                <span class="block text-xs text-slate-500"><%= customer.email %></span>
              </span>
            </button>
            <div x-cloak x-show="open" x-transition class="absolute right-0 mt-3 w-56 rounded-2xl border border-slate-200 bg-white p-2 shadow-soft">
              <a href="/account" class="block rounded-xl px-4 py-2 text-sm text-slate-700 transition hover:bg-slate-50 hover:text-primary">My account</a>
              <a href="/orders" class="block rounded-xl px-4 py-2 text-sm text-slate-700 transition hover:bg-slate-50 hover:text-primary">Orders</a>
              <a href="/logout" class="block rounded-xl px-4 py-2 text-sm text-slate-700 transition hover:bg-slate-50 hover:text-primary">Sign out</a>
            </div>
          </div>
        <% } else { %>
          <a href="/login" class="rounded-xl px-4 py-2 text-sm font-medium text-slate-700 transition hover:text-primary">Sign in</a>
          <a href="/register" class="rounded-xl bg-primary px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-primary-dark">Create account</a>
        <% } %>
      </div>

      <div class="flex items-center gap-2 md:hidden">
        <button type="button" data-cart-open class="relative inline-flex h-11 w-11 items-center justify-center rounded-2xl border border-slate-200 bg-white text-slate-700" aria-label="Open cart">
          <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path d="M3 3a1 1 0 000 2h1.22l.756 3.026A2 2 0 006.916 9.5h7.168a2 2 0 001.94-1.474L17.78 4H6.28l-.31-1.238A1 1 0 005 2H3z"></path>
            <path d="M6 14a2 2 0 100 4 2 2 0 000-4zm8 0a2 2 0 100 4 2 2 0 000-4z"></path>
          </svg>
          <span data-cart-count class="absolute -right-1 -top-1 inline-flex h-6 min-w-[1.5rem] items-center justify-center rounded-full bg-primary px-1.5 text-xs font-semibold text-white"><%= cartCount %></span>
        </button>
        <button type="button" @click="mobileOpen = !mobileOpen" class="inline-flex h-11 w-11 items-center justify-center rounded-2xl border border-slate-200 text-slate-700" aria-label="Open navigation">
          <svg x-show="!mobileOpen" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M3 5a1 1 0 011-1h12a1 1 0 110 2H4A1 1 0 013 5zm0 5a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm1 4a1 1 0 100 2h12a1 1 0 100-2H4z" clip-rule="evenodd"></path>
          </svg>
          <svg x-cloak x-show="mobileOpen" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path>
          </svg>
        </button>
      </div>
    </div>

    <div x-cloak x-show="mobileOpen" x-transition class="space-y-3 border-t border-slate-100 pb-5 pt-4 md:hidden">
      <% if (availableCurrencies.length > 1) { %>
        <form action="/preferences/currency" method="post" class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
          <input type="hidden" name="returnTo" value="<%= currentUrl || currentPath || '/' %>">
          <input type="hidden" name="scope" value="store">
          <label for="mobile-currency" class="mb-2 block text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Currency</label>
          <select id="mobile-currency" name="code" onchange="this.form.submit()" class="w-full rounded-xl border border-slate-200 bg-white px-3 py-3 text-sm font-medium text-slate-700 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20">
            <% availableCurrencies.forEach((entry) => { %>
              <option value="<%= entry.code %>" <%= selectedCurrency === entry.code ? 'selected' : '' %>><%= entry.label %></option>
            <% }) %>
          </select>
        </form>
      <% } %>
      <a href="/" class="block rounded-xl px-4 py-3 text-sm font-medium text-slate-700 transition hover:bg-slate-50 hover:text-primary">Home</a>
      <a href="/products" class="block rounded-xl px-4 py-3 text-sm font-medium text-slate-700 transition hover:bg-slate-50 hover:text-primary">Catalog</a>
      <a href="/orders" class="block rounded-xl px-4 py-3 text-sm font-medium text-slate-700 transition hover:bg-slate-50 hover:text-primary">Orders</a>
      <% if (customer) { %>
        <a href="/account" class="block rounded-xl px-4 py-3 text-sm font-medium text-slate-700 transition hover:bg-slate-50 hover:text-primary">My account</a>
        <a href="/logout" class="block rounded-xl px-4 py-3 text-sm font-medium text-slate-700 transition hover:bg-slate-50 hover:text-primary">Sign out</a>
      <% } else { %>
        <div class="flex flex-col gap-3 pt-1">
          <a href="/login" class="rounded-xl border border-slate-200 px-4 py-3 text-center text-sm font-medium text-slate-700">Sign in</a>
          <a href="/register" class="rounded-xl bg-primary px-4 py-3 text-center text-sm font-semibold text-white">Create account</a>
        </div>
      <% } %>
    </div>
  </div>
</header>
