<%
  const adminPath = currentPath || '';
  const adminStoreName = store && store.name ? store.name : 'Store Admin';
  const adminInitial = adminStoreName.charAt(0).toUpperCase();
  const navLinkClasses = (matcher) => {
    return matcher()
      ? 'bg-white/10 text-white shadow-sm'
      : 'text-slate-300 hover:bg-white/5 hover:text-white';
  };
%>
<aside data-admin-sidebar class="fixed inset-y-0 left-0 z-50 flex w-72 -translate-x-full flex-col border-r border-white/10 bg-slate-950 px-5 py-6 text-white transition-transform duration-200 lg:translate-x-0">
  <div class="flex items-center justify-between gap-3">
    <a href="/admin" class="flex min-w-0 items-center gap-3">
      <span class="inline-flex h-11 w-11 flex-none items-center justify-center rounded-2xl bg-primary text-lg font-semibold text-white shadow-soft"><%= adminInitial || 'S' %></span>
      <span class="min-w-0">
        <span class="block truncate text-sm uppercase tracking-[0.24em] text-slate-400">Store Admin</span>
        <span class="block truncate text-base font-semibold text-white"><%= adminStoreName %></span>
      </span>
    </a>
    <button type="button" data-admin-sidebar-close class="inline-flex h-10 w-10 items-center justify-center rounded-2xl border border-white/10 text-slate-300 lg:hidden" aria-label="Close sidebar">
      <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path>
      </svg>
    </button>
  </div>

  <div class="mt-8 rounded-3xl border border-white/10 bg-white/5 p-4">
    <p class="text-xs uppercase tracking-[0.24em] text-slate-400">Storefront domain</p>
    <p class="mt-2 text-sm font-semibold text-white"><%= store && store.custom_domain ? store.custom_domain : `${store && store.subdomain ? store.subdomain : 'store'}.localhost` %></p>
    <p class="mt-2 text-sm leading-6 text-slate-300"><%= store && store.tagline ? store.tagline : 'Operate products, orders, and service with confidence.' %></p>
  </div>

  <nav class="mt-8 flex-1 space-y-2">
    <a href="/admin" class="flex items-center gap-3 rounded-2xl px-4 py-3 text-sm font-medium transition <%= navLinkClasses(() => adminPath === '/admin') %>">
      <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M10.707 1.707a1 1 0 00-1.414 0l-7 7A1 1 0 003 10.414V17a2 2 0 002 2h3a1 1 0 001-1v-3h2v3a1 1 0 001 1h3a2 2 0 002-2v-6.586a1 1 0 00.293-.707 1 1 0 00-.293-.707l-7-7z"></path></svg>
      Dashboard
    </a>
    <a href="/admin/products" class="flex items-center gap-3 rounded-2xl px-4 py-3 text-sm font-medium transition <%= navLinkClasses(() => adminPath.startsWith('/admin/products')) %>">
      <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M4 3a2 2 0 00-2 2v1.382a2 2 0 00.553 1.382l5 5.257a2 2 0 002.894 0l5-5.257A2 2 0 0016 6.382V5a2 2 0 00-2-2H4z"></path><path d="M6 8a1.5 1.5 0 100-3 1.5 1.5 0 000 3z"></path></svg>
      Products
    </a>
    <a href="/admin/orders" class="flex items-center gap-3 rounded-2xl px-4 py-3 text-sm font-medium transition <%= navLinkClasses(() => adminPath.startsWith('/admin/orders')) %>">
      <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M4 4a2 2 0 00-2 2v7.5A2.5 2.5 0 004.5 16H6a2 2 0 100 0h8a2 2 0 100 0h1.5A2.5 2.5 0 0018 13.5V9a1 1 0 00-.293-.707l-2-2A1 1 0 0015 6h-1V6a2 2 0 00-2-2H4z"></path></svg>
      Orders
    </a>
    <a href="/admin/settings" class="flex items-center gap-3 rounded-2xl px-4 py-3 text-sm font-medium transition <%= navLinkClasses(() => adminPath === '/admin/settings') %>">
      <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M11.983 1.904a1 1 0 00-1.966 0l-.18 1.083a1 1 0 01-.79.815 6.98 6.98 0 00-1.602.664 1 1 0 01-1.114-.123l-.865-.677a1 1 0 00-1.39.183L2.77 5.32a1 1 0 00.183 1.39l.865.676a1 1 0 01.306 1.079c-.168.52-.285 1.056-.35 1.603a1 1 0 01-.815.79l-1.083.18a1 1 0 000 1.966l1.083.18a1 1 0 01.815.79c.065.547.182 1.083.35 1.603a1 1 0 01-.306 1.079l-.865.676a1 1 0 00-.183 1.39l1.306 1.47a1 1 0 001.39.183l.865-.676a1 1 0 011.114-.123c.507.287 1.042.51 1.602.664a1 1 0 01.79.815l.18 1.083a1 1 0 001.966 0l.18-1.083a1 1 0 01.79-.815 6.98 6.98 0 001.602-.664 1 1 0 011.114.123l.865.676a1 1 0 001.39-.183l1.306-1.47a1 1 0 00-.183-1.39l-.865-.676a1 1 0 01-.306-1.079c.168-.52.285-1.056.35-1.603a1 1 0 01.815-.79l1.083-.18a1 1 0 000-1.966l-1.083-.18a1 1 0 01-.815-.79 6.973 6.973 0 00-.35-1.603 1 1 0 01.306-1.08l.865-.675a1 1 0 00.183-1.39l-1.306-1.47a1 1 0 00-1.39-.183l-.865.677a1 1 0 01-1.114.123 6.98 6.98 0 00-1.602-.664 1 1 0 01-.79-.815l-.18-1.083zM10 13a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd"></path></svg>
      Store Settings
    </a>
    <a href="/admin/domain" class="flex items-center gap-3 rounded-2xl px-4 py-3 text-sm font-medium transition <%= navLinkClasses(() => adminPath === '/admin/domain') %>">
      <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M5.05 4.636a7 7 0 119.9 9.9l-1.414-1.414a5 5 0 10-7.072-7.072L5.05 4.636zm9.9.707a7 7 0 01-9.9 9.9l1.414-1.414a5 5 0 007.072-7.072l1.414-1.414z" clip-rule="evenodd"></path><path d="M7.172 12.828a4 4 0 010-5.656l1.414 1.414a2 2 0 000 2.828l-1.414 1.414zm5.656-5.656a4 4 0 010 5.656l-1.414-1.414a2 2 0 000-2.828l1.414-1.414z"></path></svg>
      Domain Setup
    </a>
  </nav>

  <div class="space-y-4 rounded-3xl border border-white/10 bg-white/5 p-4">
    <div>
      <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Operator</p>
      <p class="mt-2 text-sm font-medium text-white"><%= platformUser && platformUser.email ? platformUser.email : 'support@aisle.so' %></p>
    </div>
    <div class="grid grid-cols-2 gap-3">
      <a href="/stores/<%= store && store.id ? store.id : '' %>/preview" class="inline-flex items-center justify-center rounded-2xl border border-white/10 px-4 py-2.5 text-sm font-medium text-slate-200 transition hover:border-white/20 hover:bg-white/5 hover:text-white">Storefront</a>
      <form action="/logout" method="post">
        <%- include('./csrf-field') %>
        <button type="submit" class="inline-flex w-full items-center justify-center rounded-2xl border border-white/10 px-4 py-2.5 text-sm font-medium text-slate-200 transition hover:border-white/20 hover:bg-white/5 hover:text-white">Sign out</button>
      </form>
    </div>
  </div>
</aside>

<div data-admin-overlay class="fixed inset-0 z-40 hidden bg-slate-950/60 backdrop-blur-sm lg:hidden"></div>
