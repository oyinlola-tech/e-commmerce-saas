<%
  const brandLabel = pageBrandLabel
    || (platformBrand && platformBrand.platformName ? platformBrand.platformName : 'Aisle');
  const resolvedTitle = metaTitle || (pageTitle ? `${pageTitle} | ${brandLabel}` : brandLabel);
  const resolvedDescription = metaDescription || 'Launch, manage, and grow storefronts from one serious commerce workspace.';
  const resolvedKeywords = metaKeywords || '';
  const resolvedCanonicalUrl = canonicalUrl || '';
  const resolvedSocialImage = socialImage || '';
  const resolvedMetaType = metaType || 'website';
  const resolvedMetaRobots = metaRobots || 'index, follow';
  const resolvedCsrfToken = typeof csrfToken !== 'undefined' ? csrfToken : '';
  const resolvedBrandColor = brandColor || '#0F766E';
  const resolvedStoreTheme = typeof storeTheme !== 'undefined' ? storeTheme : null;
  const resolvedBodyFont = resolvedStoreTheme && resolvedStoreTheme.fonts ? resolvedStoreTheme.fonts.bodyFamily : "'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif";
  const resolvedDisplayFont = resolvedStoreTheme && resolvedStoreTheme.fonts ? resolvedStoreTheme.fonts.displayFamily : "'Space Grotesk', 'Plus Jakarta Sans', sans-serif";
%>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= resolvedTitle %></title>
<meta name="description" content="<%= resolvedDescription %>">
<meta name="robots" content="<%= resolvedMetaRobots %>">
<link rel="icon" type="image/svg+xml" href="/brand/favicon.svg">
<link rel="shortcut icon" href="/brand/favicon.svg">
<meta name="theme-color" content="<%= resolvedBrandColor %>">
<% if (resolvedKeywords) { %>
<meta name="keywords" content="<%= resolvedKeywords %>">
<% } %>
<% if (resolvedCanonicalUrl) { %>
<link rel="canonical" href="<%= resolvedCanonicalUrl %>">
<meta property="og:url" content="<%= resolvedCanonicalUrl %>">
<% } %>
<meta property="og:title" content="<%= resolvedTitle %>">
<meta property="og:description" content="<%= resolvedDescription %>">
<meta property="og:type" content="<%= resolvedMetaType %>">
<meta property="og:site_name" content="<%= brandLabel %>">
<meta name="twitter:card" content="<%= resolvedSocialImage ? 'summary_large_image' : 'summary' %>">
<meta name="twitter:title" content="<%= resolvedTitle %>">
<meta name="twitter:description" content="<%= resolvedDescription %>">
<% if (resolvedSocialImage) { %>
<meta property="og:image" content="<%= resolvedSocialImage %>">
<meta name="twitter:image" content="<%= resolvedSocialImage %>">
<% } %>
<meta name="csrf-token" content="<%= resolvedCsrfToken %>">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&family=DM+Sans:wght@400;500;700&family=Cormorant+Garamond:wght@500;600;700&family=Manrope:wght@400;500;600;700;800&family=Fraunces:wght@500;600;700&family=Outfit:wght@400;500;600;700&family=IBM+Plex+Sans:wght@400;500;600;700&family=Syne:wght@500;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/styles/app.css?v=<%= themeAssetVersion %>">
<link rel="stylesheet" href="/styles/theme.css?v=<%= themeAssetVersion %>">
<style nonce="<%= cspNonce %>">
  :root {
    --color-primary: <%= resolvedBrandColor %>;
    --color-primary-dark: color-mix(in srgb, var(--color-primary) 84%, black);
    --color-primary-soft: color-mix(in srgb, var(--color-primary) 12%, white);
    --color-primary-border: color-mix(in srgb, var(--color-primary) 24%, white);
    --font-body: <%= resolvedBodyFont %>;
    --font-display: <%= resolvedDisplayFont %>;
  }

  html {
    font-family: var(--font-body);
    scroll-behavior: smooth;
  }

  [data-cloak] {
    display: none !important;
  }

  .bg-primary {
    background-color: var(--color-primary) !important;
  }

  .text-primary {
    color: var(--color-primary) !important;
  }

  .border-primary {
    border-color: var(--color-primary) !important;
  }

  .ring-primary {
    --tw-ring-color: var(--color-primary) !important;
  }

  .bg-primary-soft {
    background-color: var(--color-primary-soft) !important;
  }

  .border-primary-soft {
    border-color: var(--color-primary-border) !important;
  }

  .hover\:bg-primary-dark:hover {
    background-color: var(--color-primary-dark) !important;
  }

  .hover\:text-primary:hover {
    color: var(--color-primary) !important;
  }

  .from-primary {
    --tw-gradient-from: var(--color-primary) var(--tw-gradient-from-position) !important;
    --tw-gradient-to: color-mix(in srgb, var(--color-primary) 0%, transparent) var(--tw-gradient-to-position) !important;
  }

  .to-primary-light {
    --tw-gradient-to: color-mix(in srgb, var(--color-primary) 42%, white) var(--tw-gradient-to-position) !important;
  }

  .focus\:border-primary:focus {
    border-color: var(--color-primary) !important;
  }

  .focus\:ring-primary:focus {
    --tw-ring-color: var(--color-primary) !important;
  }

  ::selection {
    background: color-mix(in srgb, var(--color-primary) 18%, white);
  }

  .font-display {
    font-family: var(--font-display);
  }

  .section-title {
    font-family: var(--font-display);
  }

  @keyframes toast-in {
    from {
      opacity: 0;
      transform: translate3d(24px, 0, 0);
    }
    to {
      opacity: 1;
      transform: translate3d(0, 0, 0);
    }
  }

  @keyframes toast-out {
    from {
      opacity: 1;
      transform: translate3d(0, 0, 0);
    }
    to {
      opacity: 0;
      transform: translate3d(24px, 0, 0);
    }
  }

  @keyframes badge-bump {
    0%,
    100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.14);
    }
  }

  .toast-enter {
    animation: toast-in 180ms ease-out forwards;
  }

  .toast-exit {
    animation: toast-out 180ms ease-in forwards;
  }

  .cart-badge-bump {
    animation: badge-bump 240ms ease-in-out;
  }
</style>
