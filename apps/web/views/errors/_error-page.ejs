<%
  const state = errorState || {};
  const primaryAction = state.primaryAction || { href: '/', label: 'Go home' };
  const secondaryAction = state.secondaryAction || null;
  const recoverySteps = Array.isArray(state.recoverySteps) ? state.recoverySteps : [];
  const detailItems = Array.isArray(state.detailItems) ? state.detailItems : [];
  const supportContact = store && store.support_email
    ? store.support_email
    : (platformBrand && platformBrand.supportEmail ? platformBrand.supportEmail : 'support@aislecommerce.com');
  const experienceLabel = store && store.name
    ? store.name
    : (platformBrand && platformBrand.platformName ? platformBrand.platformName : 'Aisle Commerce');
%>
<section class="relative overflow-hidden px-4 py-12 sm:px-6 lg:px-8 lg:py-20">
  <div class="pointer-events-none absolute inset-x-0 top-0 -z-10 overflow-hidden">
    <div class="mx-auto h-64 max-w-5xl bg-[radial-gradient(circle_at_top,_rgba(79,70,229,0.18),_transparent_62%)]"></div>
  </div>

  <div class="mx-auto max-w-6xl">
    <div class="grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
      <div class="rounded-[2rem] border border-slate-200 bg-white p-8 shadow-soft sm:p-10">
        <span class="inline-flex items-center rounded-full border border-primary-soft bg-primary-soft px-4 py-2 text-xs font-semibold uppercase tracking-[0.24em] text-primary">
          Error <%= state.statusCode || '500' %>
        </span>
        <h1 class="section-title mt-6 text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl">
          <%= state.title || 'Something went wrong' %>
        </h1>
        <p class="mt-4 max-w-2xl text-lg leading-8 text-slate-600">
          <%= state.message || 'This page could not be completed right now.' %>
        </p>

        <% if (detailItems.length) { %>
          <div class="mt-6 rounded-[1.75rem] border border-amber-200 bg-amber-50 p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-amber-700">Details</p>
            <ul class="mt-3 space-y-2 text-sm leading-6 text-amber-950">
              <% detailItems.forEach((item) => { %>
                <li class="flex items-start gap-3">
                  <span class="mt-2 inline-flex h-2 w-2 rounded-full bg-amber-500"></span>
                  <span><%= item %></span>
                </li>
              <% }) %>
            </ul>
          </div>
        <% } %>

        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <% if (primaryAction && primaryAction.href) { %>
            <a href="<%= primaryAction.href %>" class="inline-flex items-center justify-center rounded-2xl bg-primary px-5 py-3 text-sm font-semibold text-white transition hover:bg-primary-dark">
              <%= primaryAction.label || 'Go home' %>
            </a>
          <% } %>
          <% if (secondaryAction && secondaryAction.href) { %>
            <a href="<%= secondaryAction.href %>" class="inline-flex items-center justify-center rounded-2xl border border-slate-200 bg-white px-5 py-3 text-sm font-medium text-slate-700 transition hover:border-primary hover:text-primary">
              <%= secondaryAction.label || 'Go back' %>
            </a>
          <% } %>
        </div>

        <% if (state.requestId) { %>
          <p class="mt-6 text-xs uppercase tracking-[0.2em] text-slate-400">
            Request ID
            <span class="ml-2 font-medium normal-case tracking-normal text-slate-600"><%= state.requestId %></span>
          </p>
        <% } %>
      </div>

      <aside class="rounded-[2rem] border border-slate-200 bg-slate-50 p-8 shadow-soft sm:p-10">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary">Recovery</p>
        <h2 class="section-title mt-4 text-2xl font-semibold text-slate-950">What you can do next</h2>

        <% if (recoverySteps.length) { %>
          <ul class="mt-6 space-y-3">
            <% recoverySteps.forEach((step) => { %>
              <li class="flex items-start gap-3 text-sm leading-6 text-slate-600">
                <span class="mt-2 inline-flex h-2.5 w-2.5 rounded-full bg-primary"></span>
                <span><%= step %></span>
              </li>
            <% }) %>
          </ul>
        <% } else { %>
          <p class="mt-6 text-sm leading-6 text-slate-600">Retry the action, or return to a stable page and continue from there.</p>
        <% } %>

        <div class="mt-8 rounded-[1.75rem] border border-slate-200 bg-white p-5">
          <p class="text-sm font-semibold text-slate-950">Need a fallback route?</p>
          <p class="mt-2 text-sm leading-6 text-slate-600">
            If this keeps happening, share the request ID with <span class="font-medium text-slate-900"><%= supportContact %></span>.
          </p>
          <p class="mt-4 text-sm font-medium text-slate-900"><%= experienceLabel %></p>
        </div>
      </aside>
    </div>
  </div>
</section>
