<%
  const incidentList = Array.isArray(incidents) ? incidents : [];
  const severityBadge = (severity) => {
    switch ((severity || '').toLowerCase()) {
      case 'critical':
        return 'bg-rose-50 text-rose-700';
      case 'major':
        return 'bg-amber-50 text-amber-700';
      default:
        return 'bg-slate-100 text-slate-700';
    }
  };
%>
<section class="space-y-8">
  <div class="max-w-3xl">
    <span class="eyebrow">Incident Center</span>
    <h1 class="section-title mt-5 text-4xl font-semibold tracking-tight text-slate-950">Close the loop on reliability before customers feel it.</h1>
    <p class="mt-4 text-lg leading-8 text-slate-600">
      Maintain ownership, publish internal notes, and move issues across investigation, monitoring, and resolution.
    </p>
  </div>

  <div class="space-y-5">
    <% incidentList.forEach((incident) => { %>
      <article class="surface-card rounded-[2rem] p-6">
        <div class="grid gap-6 xl:grid-cols-[1.05fr_0.95fr]">
          <div>
            <div class="flex flex-wrap items-center gap-3">
              <h2 class="text-2xl font-semibold text-slate-950"><%= incident.area %></h2>
              <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] <%= severityBadge(incident.severity) %>"><%= incident.severity %></span>
            </div>
            <p class="mt-3 text-base leading-7 text-slate-600"><%= incident.summary %></p>
            <div class="mt-5 rounded-3xl bg-slate-50 p-5">
              <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Impact statement</p>
              <p class="mt-3 text-sm leading-6 text-slate-700"><%= incident.impact %></p>
            </div>
            <div class="mt-5 space-y-3">
              <% (incident.notes || []).slice(0, 3).forEach((note) => { %>
                <div class="rounded-2xl border border-slate-200 bg-white p-4">
                  <p class="text-sm font-semibold text-slate-900"><%= note.author %></p>
                  <p class="mt-2 text-sm leading-6 text-slate-600"><%= note.body %></p>
                </div>
              <% }) %>
            </div>
          </div>

          <form action="/platform-admin/incidents/<%= incident.id %>" method="post" class="rounded-[1.75rem] border border-slate-200 bg-white p-5">
            <p class="text-sm font-semibold text-slate-900">Incident controls</p>
            <div class="mt-4 grid gap-4 sm:grid-cols-2">
              <div>
                <label for="incident-status-<%= incident.id %>" class="mb-1 block text-sm font-medium text-slate-700">Status</label>
                <select id="incident-status-<%= incident.id %>" name="status" class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20">
                  <% ['investigating', 'monitoring', 'resolved'].forEach((entry) => { %>
                    <option value="<%= entry %>" <%= incident.status === entry ? 'selected' : '' %>><%= entry.charAt(0).toUpperCase() + entry.slice(1) %></option>
                  <% }) %>
                </select>
              </div>
              <div>
                <label for="incident-owner-<%= incident.id %>" class="mb-1 block text-sm font-medium text-slate-700">Owner</label>
                <input id="incident-owner-<%= incident.id %>" name="owner" type="text" value="<%= incident.owner || '' %>" class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20">
              </div>
            </div>
            <div class="mt-4">
              <label for="incident-note-<%= incident.id %>" class="mb-1 block text-sm font-medium text-slate-700">Internal note</label>
              <textarea id="incident-note-<%= incident.id %>" name="note" rows="6" class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="Capture mitigations, customer impact updates, or next engineering step."></textarea>
            </div>
            <button type="submit" class="mt-4 inline-flex items-center justify-center rounded-2xl bg-primary px-5 py-3 text-sm font-semibold text-white transition hover:bg-primary-dark">Save incident update</button>
          </form>
        </div>
      </article>
    <% }) %>
  </div>
</section>
