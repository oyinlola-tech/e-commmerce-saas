<%
  const operations = asyncOperations || {};
  const emailFailures = operations.email_failures || { summary: {}, items: [] };
  const eventFailures = operations.event_failures || { summary: {}, queues: [], items: [], transports: {} };
  const emailItems = Array.isArray(emailFailures.items) ? emailFailures.items : [];
  const eventItems = Array.isArray(eventFailures.items) ? eventFailures.items : [];
  const queueItems = Array.isArray(eventFailures.queues) ? eventFailures.queues : [];
  const rabbitmqStatus = eventFailures.transports && eventFailures.transports.rabbitmq
    ? eventFailures.transports.rabbitmq
    : { available: false, error: null };
  const redisStatus = eventFailures.transports && eventFailures.transports.redis
    ? eventFailures.transports.redis
    : { available: false, error: null };
  const formatDate = (value) => {
    if (!value) {
      return 'Not available';
    }

    try {
      return new Intl.DateTimeFormat((currencyContext && currencyContext.locale) || 'en-US', {
        dateStyle: 'medium',
        timeStyle: 'short'
      }).format(new Date(value));
    } catch {
      return value;
    }
  };
  const eventBadgeClasses = (transport) => {
    switch ((transport || '').toLowerCase()) {
      case 'redis':
        return 'bg-amber-50 text-amber-700';
      case 'rabbitmq':
      default:
        return 'bg-sky-50 text-sky-700';
    }
  };
  const emailBadgeClasses = (status) => {
    switch ((status || '').toLowerCase()) {
      case 'dead_lettered':
        return 'bg-rose-50 text-rose-700';
      case 'retrying':
      default:
        return 'bg-amber-50 text-amber-700';
    }
  };
  const transportStatusClasses = (transportStatus) => {
    return transportStatus && transportStatus.available
      ? 'bg-emerald-50 text-emerald-700'
      : 'bg-slate-100 text-slate-700';
  };
%>
<section class="space-y-8">
  <div class="surface-card relative overflow-hidden rounded-[2rem] p-8 sm:p-10">
    <div class="hero-orb hero-orb-primary -left-10 top-0 h-40 w-40"></div>
    <div class="hero-orb hero-orb-sky right-0 top-6 h-44 w-44"></div>
    <div class="relative grid gap-8 xl:grid-cols-[1.05fr_0.95fr] xl:items-center">
      <div class="space-y-6">
        <span class="eyebrow">Incident Center</span>
        <div class="space-y-4">
          <h1 class="section-title max-w-3xl text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl">Replay failed async work only after the root cause is fixed.</h1>
          <p class="max-w-3xl text-lg leading-8 text-slate-600">
            This console shows real event dead letters and outbound email failures from the live service layer. Replays are intentionally explicit because they can duplicate customer-facing side effects if the original failure happened after partial delivery.
          </p>
        </div>
        <div class="rounded-[1.75rem] border border-slate-200 bg-white p-5">
          <p class="text-sm font-semibold text-slate-950">Operator safety rail</p>
          <p class="mt-2 text-sm leading-6 text-slate-600">
            Use replay only when the dependency failure, bad configuration, or downstream outage has already been corrected. Email replays can resend customer mail, and event replays can re-trigger business workflows.
          </p>
        </div>
        <% if (asyncOperationsLoadError) { %>
          <div class="rounded-[1.75rem] border border-rose-200 bg-rose-50 px-5 py-4 text-sm leading-6 text-rose-700">
            <strong class="font-semibold text-rose-900">Async operations data is unavailable.</strong>
            <div class="mt-1"><%= asyncOperationsLoadError %></div>
          </div>
        <% } %>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        <article class="metric-card rounded-3xl p-5">
          <p class="text-sm font-medium text-slate-500">Event dead letters</p>
          <p class="metric-value mt-3 text-3xl font-semibold tracking-tight text-slate-950"><%= Number(eventFailures.summary && eventFailures.summary.total_count || 0) %></p>
          <p class="mt-2 text-sm text-slate-500">Combined backlog across RabbitMQ queues and the Redis durable fallback.</p>
        </article>
        <article class="metric-card rounded-3xl p-5">
          <p class="text-sm font-medium text-slate-500">Email failures</p>
          <p class="metric-value mt-3 text-3xl font-semibold tracking-tight text-slate-950"><%= Number(emailFailures.summary && emailFailures.summary.total_count || 0) %></p>
          <p class="mt-2 text-sm text-slate-500">Retrying and dead-lettered transactional emails waiting for operator review.</p>
        </article>
        <article class="metric-card rounded-3xl p-5">
          <p class="text-sm font-medium text-slate-500">RabbitMQ</p>
          <p class="mt-3 inline-flex rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] <%= transportStatusClasses(rabbitmqStatus) %>"><%= rabbitmqStatus.available ? 'Available' : 'Unavailable' %></p>
          <p class="mt-2 text-sm text-slate-500"><%= rabbitmqStatus.error || 'Dead-letter queue inspection is live.' %></p>
        </article>
        <article class="metric-card rounded-3xl p-5">
          <p class="text-sm font-medium text-slate-500">Redis fallback</p>
          <p class="mt-3 inline-flex rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] <%= transportStatusClasses(redisStatus) %>"><%= redisStatus.available ? 'Available' : 'Unavailable' %></p>
          <p class="mt-2 text-sm text-slate-500"><%= redisStatus.error || 'Durable fallback queue inspection is live.' %></p>
        </article>
      </div>
    </div>
  </div>

  <div class="grid gap-8 xl:grid-cols-[1.02fr_0.98fr]">
    <section class="surface-card rounded-[2rem] p-6">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="text-sm font-medium text-slate-500">Queue backlog</p>
          <h2 class="section-title mt-1 text-2xl font-semibold text-slate-950">Dead-letter queues by service</h2>
        </div>
        <p class="max-w-2xl text-sm leading-6 text-slate-500">
          RabbitMQ counts reflect broker DLQs. Redis counts reflect the durable fallback queue used when RabbitMQ is unavailable.
        </p>
      </div>

      <% if (queueItems.length) { %>
        <div class="mt-6 space-y-4">
          <% queueItems.forEach((queue) => { %>
            <article class="rounded-[1.75rem] border border-slate-200 bg-white p-5">
              <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                <div>
                  <h3 class="text-lg font-semibold text-slate-950"><%= queue.queue_label %></h3>
                  <p class="mt-1 text-sm text-slate-500"><%= queue.service %> · <code class="text-xs text-slate-500"><%= queue.queue_name %></code></p>
                </div>
                <div class="grid gap-3 sm:grid-cols-3">
                  <div class="rounded-2xl bg-slate-50 px-4 py-3">
                    <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Total</p>
                    <p class="mt-1 text-sm font-semibold text-slate-950"><%= Number(queue.total_dead_letter_count || 0) %></p>
                  </div>
                  <div class="rounded-2xl bg-slate-50 px-4 py-3">
                    <p class="text-xs uppercase tracking-[0.18em] text-slate-400">RabbitMQ</p>
                    <p class="mt-1 text-sm font-semibold text-slate-950"><%= Number(queue.rabbitmq_dead_letter_count || 0) %></p>
                  </div>
                  <div class="rounded-2xl bg-slate-50 px-4 py-3">
                    <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Redis</p>
                    <p class="mt-1 text-sm font-semibold text-slate-950"><%= Number(queue.redis_dead_letter_count || 0) %></p>
                  </div>
                </div>
              </div>
            </article>
          <% }) %>
        </div>
      <% } else { %>
        <div class="mt-6 rounded-[1.75rem] border border-slate-200 bg-white p-5">
          <p class="text-sm leading-6 text-slate-600">No known dead-letter queues are carrying backlog right now.</p>
        </div>
      <% } %>
    </section>

    <section class="surface-card rounded-[2rem] p-6">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="text-sm font-medium text-slate-500">Replay candidates</p>
          <h2 class="section-title mt-1 text-2xl font-semibold text-slate-950">Dead-lettered events</h2>
        </div>
        <p class="max-w-2xl text-sm leading-6 text-slate-500">
          Only replay events after the dependency failure is fixed. Large RabbitMQ backlogs stay blocked from UI replay on purpose.
        </p>
      </div>

      <% if (eventItems.length) { %>
        <div class="mt-6 space-y-4">
          <% eventItems.forEach((item) => { %>
            <article class="rounded-[1.75rem] border border-slate-200 bg-white p-5">
              <div class="flex flex-wrap items-start justify-between gap-3">
                <div class="min-w-0">
                  <div class="flex flex-wrap items-center gap-3">
                    <h3 class="text-lg font-semibold text-slate-950"><%= item.queue_label %></h3>
                    <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] <%= eventBadgeClasses(item.transport) %>"><%= item.transport %></span>
                  </div>
                  <p class="mt-1 text-sm text-slate-500"><%= item.service %> · <code class="text-xs text-slate-500"><%= item.event %></code></p>
                </div>
                <form action="/platform-admin/incidents/events/replay" method="post" class="flex-none">
                  <%- include('../partials/csrf-field') %>
                  <input type="hidden" name="transport" value="<%= item.transport %>">
                  <input type="hidden" name="queue_name" value="<%= item.queue_name %>">
                  <input type="hidden" name="message_id" value="<%= item.message_id %>">
                  <button type="submit" class="inline-flex items-center justify-center rounded-2xl bg-primary px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-primary-dark">Replay Event</button>
                </form>
              </div>

              <div class="mt-4 grid gap-4 sm:grid-cols-2">
                <div class="rounded-2xl bg-slate-50 p-4">
                  <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Failure detail</p>
                  <p class="mt-2 text-sm leading-6 text-slate-700"><%= item.last_error || 'Dead-lettered after retries.' %></p>
                </div>
                <div class="rounded-2xl bg-slate-50 p-4">
                  <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Trace</p>
                  <p class="mt-2 text-sm leading-6 text-slate-700">Message ID: <code class="text-xs"><%= item.message_id %></code></p>
                  <p class="mt-1 text-sm leading-6 text-slate-700">Retries: <%= Number(item.retry_count || 0) %></p>
                  <p class="mt-1 text-sm leading-6 text-slate-700">Failed: <%= formatDate(item.last_error_at || item.timestamp) %></p>
                </div>
              </div>

              <% if (item.context_items && item.context_items.length) { %>
                <div class="mt-4 flex flex-wrap gap-2">
                  <% item.context_items.forEach((contextItem) => { %>
                    <span class="inline-flex rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700"><%= contextItem %></span>
                  <% }) %>
                </div>
              <% } %>
            </article>
          <% }) %>
        </div>
      <% } else { %>
        <div class="mt-6 rounded-[1.75rem] border border-slate-200 bg-white p-5">
          <p class="text-sm leading-6 text-slate-600">No replayable dead-lettered events are surfaced in the current broker backlogs.</p>
        </div>
      <% } %>
    </section>
  </div>

  <section class="surface-card rounded-[2rem] p-6">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-sm font-medium text-slate-500">Transactional email</p>
        <h2 class="section-title mt-1 text-2xl font-semibold text-slate-950">Failed or retrying outbound mail</h2>
      </div>
      <p class="max-w-2xl text-sm leading-6 text-slate-500">
        These rows come from the durable `outbound_emails` queue. Replay sends the job back into the normal worker loop without bypassing retries.
      </p>
    </div>

    <% if (emailItems.length) { %>
      <div class="mt-6 space-y-4">
        <% emailItems.forEach((email) => { %>
          <article class="rounded-[1.75rem] border border-slate-200 bg-white p-5">
            <div class="flex flex-wrap items-start justify-between gap-4">
              <div class="min-w-0">
                <div class="flex flex-wrap items-center gap-3">
                  <h3 class="text-lg font-semibold text-slate-950"><%= email.subject %></h3>
                  <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] <%= emailBadgeClasses(email.status) %>"><%= email.status.replace('_', ' ') %></span>
                </div>
                <p class="mt-1 text-sm text-slate-500"><%= email.recipient_email %></p>
                <% if (email.metadata && (email.metadata.template_key || email.metadata.kind)) { %>
                  <p class="mt-2 text-xs uppercase tracking-[0.18em] text-slate-400">
                    <%= email.metadata.template_key || email.metadata.kind %>
                  </p>
                <% } %>
              </div>
              <form action="/platform-admin/incidents/emails/<%= email.id %>/replay" method="post" class="flex-none">
                <%- include('../partials/csrf-field') %>
                <button type="submit" class="inline-flex items-center justify-center rounded-2xl bg-primary px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-primary-dark">Replay Email</button>
              </form>
            </div>

            <div class="mt-4 grid gap-4 lg:grid-cols-[1.05fr_0.95fr]">
              <div class="rounded-2xl bg-slate-50 p-4">
                <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Last error</p>
                <p class="mt-2 text-sm leading-6 text-slate-700"><%= email.last_error || 'No failure message was recorded.' %></p>
              </div>
              <div class="grid gap-3 sm:grid-cols-2">
                <div class="rounded-2xl bg-slate-50 p-4">
                  <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Attempts</p>
                  <p class="mt-2 text-sm font-semibold text-slate-950"><%= Number(email.attempt_count || 0) %></p>
                  <p class="mt-1 text-xs leading-5 text-slate-500">Next attempt: <%= formatDate(email.next_attempt_at) %></p>
                </div>
                <div class="rounded-2xl bg-slate-50 p-4">
                  <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Failure time</p>
                  <p class="mt-2 text-sm font-semibold text-slate-950"><%= formatDate(email.dead_lettered_at || email.failed_at || email.updated_at) %></p>
                  <p class="mt-1 text-xs leading-5 text-slate-500">Queued: <%= formatDate(email.created_at) %></p>
                </div>
              </div>
            </div>
          </article>
        <% }) %>
      </div>
    <% } else { %>
      <div class="mt-6 rounded-[1.75rem] border border-slate-200 bg-white p-5">
        <p class="text-sm leading-6 text-slate-600">No retrying or dead-lettered transactional emails need operator action right now.</p>
      </div>
    <% } %>
  </section>
</section>
