<%
  const overview = metrics || {};
  const tenantList = Array.isArray(stores) ? stores : [];
  const planList = Array.isArray(billingPlans) ? billingPlans : [];
  const canEditPricing = Boolean(editablePricing);
  const baseCurrency = planList[0] && planList[0].currency ? planList[0].currency : 'USD';
  const trialDays = Number(overview.trialDays || 7);
  const trialAuthorizationAmount = Number(overview.trialAuthorizationAmount || 1);
  const trialAuthorizationCurrency = overview.trialAuthorizationCurrency || 'USD';
  const locale = (currencyContext && currencyContext.locale) || 'en-US';
  const formatCurrency = (amount, currency, targetLocale = locale) => {
    return new Intl.NumberFormat(targetLocale || 'en-US', {
      style: 'currency',
      currency: currency || 'USD'
    }).format(Number(amount || 0));
  };
%>
<section class="space-y-8">
  <div class="surface-card relative overflow-hidden rounded-[2rem] p-8 sm:p-10">
    <div class="hero-orb hero-orb-primary -left-10 top-0 h-40 w-40"></div>
    <div class="hero-orb hero-orb-sky right-0 top-4 h-44 w-44"></div>
    <div class="relative grid gap-8 xl:grid-cols-[1.05fr_0.95fr] xl:items-center">
      <div class="space-y-6">
        <span class="eyebrow">Platform Operations</span>
        <div class="space-y-4">
          <h1 class="section-title max-w-3xl text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl">Set subscription fees from the main control layer.</h1>
          <p class="max-w-2xl text-lg leading-8 text-slate-600">
            Adjust Launch, Scale, and Enterprise pricing here, keep the 7-day trial policy visible, and let the storefront pricing surfaces follow the saved values automatically.
          </p>
        </div>
        <div class="rounded-[1.75rem] border border-slate-200 bg-white p-5">
          <p class="text-sm font-semibold text-slate-950">Billing policy</p>
          <p class="mt-2 text-sm leading-6 text-slate-600">
            New subscriptions still start with a <%= trialDays %>-day trial. Paystack verifies the card with <%= formatCurrency(trialAuthorizationAmount, trialAuthorizationCurrency, 'en-US') %>, refunds it after success, then bills the selected plan when the trial ends.
          </p>
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        <article class="metric-card rounded-3xl p-5">
          <p class="text-sm font-medium text-slate-500">Plans managed</p>
          <p class="metric-value mt-3 text-3xl font-semibold tracking-tight text-slate-950"><%= overview.planCount || planList.length || 0 %></p>
          <p class="mt-2 text-sm text-slate-500">The three subscription plans share one pricing control surface.</p>
        </article>
        <article class="metric-card rounded-3xl p-5">
          <p class="text-sm font-medium text-slate-500">Base billing currency</p>
          <p class="metric-value mt-3 text-3xl font-semibold tracking-tight text-slate-950"><%= baseCurrency %></p>
          <p class="mt-2 text-sm text-slate-500">Saved fees are stored in base currency and converted for supported regions.</p>
        </article>
        <article class="metric-card rounded-3xl p-5">
          <p class="text-sm font-medium text-slate-500">Live stores</p>
          <p class="metric-value mt-3 text-3xl font-semibold tracking-tight text-slate-950"><%= overview.liveStores || 0 %>/<%= overview.storesCount || tenantList.length || 0 %></p>
          <p class="mt-2 text-sm text-slate-500">Real tenant stores currently available across the platform.</p>
        </article>
        <article class="metric-card rounded-3xl p-5">
          <p class="text-sm font-medium text-slate-500">Current preview currency</p>
          <p class="metric-value mt-3 text-3xl font-semibold tracking-tight text-slate-950"><%= selectedCurrency || baseCurrency %></p>
          <p class="mt-2 text-sm text-slate-500">The cards below also show what customers see in this selected currency.</p>
        </article>
      </div>
    </div>
  </div>

  <div class="grid gap-8 xl:grid-cols-[1.06fr_0.94fr]">
    <section class="surface-card rounded-[2rem] p-6">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="text-sm font-medium text-slate-500">Subscription pricing</p>
          <h2 class="section-title mt-1 text-2xl font-semibold text-slate-950">Fee controls</h2>
        </div>
        <p class="max-w-xl text-sm leading-6 text-slate-500">
          Save prices in <%= baseCurrency %>. The public pricing page, owner billing flow, and future recurring charges will use the updated values.
        </p>
      </div>

      <div class="mt-6 space-y-4">
        <% planList.forEach((plan) => { %>
          <% const previewPlan = plan.preview || null; %>
          <% const previewCurrency = previewPlan && previewPlan.currency ? previewPlan.currency : (selectedCurrency || baseCurrency); %>
          <form action="/platform-admin/billing/plans" method="post" class="rounded-[1.75rem] border border-slate-200 bg-white p-5">
            <%- include('../partials/csrf-field') %>
            <input type="hidden" name="plan" value="<%= plan.code %>">

            <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
              <div class="min-w-0">
                <div class="flex flex-wrap items-center gap-3">
                  <h3 class="text-xl font-semibold text-slate-950"><%= plan.name %></h3>
                  <span class="inline-flex rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-slate-700">
                    <%= plan.updated_from_default ? 'Custom Fee Active' : 'Default Fee Active' %>
                  </span>
                </div>
                <p class="mt-2 text-sm leading-6 text-slate-600"><%= plan.description %></p>
                <p class="mt-3 text-sm text-slate-500">
                  Customer preview in <%= previewCurrency %>:
                  <strong class="text-slate-900"><%= formatCurrency(previewPlan ? previewPlan.monthly_amount : plan.monthly_amount, previewCurrency) %> / month</strong>
                  and
                  <strong class="text-slate-900"><%= formatCurrency(previewPlan ? previewPlan.yearly_amount : plan.yearly_amount, previewCurrency) %> / year</strong>
                </p>
              </div>

              <div class="grid w-full gap-4 sm:grid-cols-2 lg:max-w-xl">
                <div>
                  <label for="monthly-<%= plan.code %>" class="mb-1 block text-sm font-medium text-slate-700">Monthly fee (<%= baseCurrency %>)</label>
                  <input
                    id="monthly-<%= plan.code %>"
                    name="monthly_amount"
                    type="number"
                    min="0.01"
                    step="0.01"
                    value="<%= Number(plan.monthly_amount || 0).toFixed(2) %>"
                    class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
                    <%= canEditPricing ? '' : 'disabled' %>>
                </div>
                <div>
                  <label for="yearly-<%= plan.code %>" class="mb-1 block text-sm font-medium text-slate-700">Yearly fee (<%= baseCurrency %>)</label>
                  <input
                    id="yearly-<%= plan.code %>"
                    name="yearly_amount"
                    type="number"
                    min="0.01"
                    step="0.01"
                    value="<%= Number(plan.yearly_amount || 0).toFixed(2) %>"
                    class="w-full rounded-2xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
                    <%= canEditPricing ? '' : 'disabled' %>>
                </div>
              </div>
            </div>

            <div class="mt-5 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
              <div class="text-sm leading-6 text-slate-500">
                Current base pricing: <strong class="text-slate-900"><%= formatCurrency(plan.monthly_amount, baseCurrency, 'en-US') %></strong> monthly and <strong class="text-slate-900"><%= formatCurrency(plan.yearly_amount, baseCurrency, 'en-US') %></strong> yearly.
              </div>
              <% if (canEditPricing) { %>
                <button type="submit" class="inline-flex items-center justify-center rounded-2xl bg-primary px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-primary-dark">
                  Save Fees
                </button>
              <% } else { %>
                <p class="text-sm font-medium text-slate-500">Only the platform owner account can save price changes.</p>
              <% } %>
            </div>
          </form>
        <% }) %>
      </div>
    </section>

    <div class="space-y-8">
      <section class="surface-card rounded-[2rem] p-6">
        <div class="flex items-center justify-between gap-4">
          <div>
            <p class="text-sm font-medium text-slate-500">Tenant snapshot</p>
            <h2 class="section-title mt-1 text-2xl font-semibold text-slate-950">Real stores on the platform</h2>
          </div>
          <a href="/platform-admin/stores" class="text-sm font-semibold text-primary transition hover:underline">Open directory</a>
        </div>

        <% if (tenantList.length) { %>
          <div class="mt-6 space-y-4">
            <% tenantList.slice(0, 5).forEach((store) => { %>
              <article class="rounded-3xl border border-slate-200 bg-white p-4">
                <div class="flex items-start justify-between gap-4">
                  <div class="min-w-0">
                    <p class="text-sm font-semibold text-slate-950"><%= store.name %></p>
                    <p class="mt-1 truncate text-sm text-slate-500"><%= store.custom_domain || `${store.subdomain}.${platformBrand && platformBrand.website ? platformBrand.website : 'aisle.so'}` %></p>
                  </div>
                  <span class="inline-flex rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-slate-700"><%= store.is_active ? 'Live' : 'Paused' %></span>
                </div>
                <div class="mt-3 grid gap-3 sm:grid-cols-3">
                  <div class="rounded-2xl bg-slate-50 p-3">
                    <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Type</p>
                    <p class="mt-1 text-sm font-medium text-slate-900"><%= store.store_type || 'General' %></p>
                  </div>
                  <div class="rounded-2xl bg-slate-50 p-3">
                    <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Template</p>
                    <p class="mt-1 text-sm font-medium text-slate-900"><%= store.template_key || 'Default' %></p>
                  </div>
                  <div class="rounded-2xl bg-slate-50 p-3">
                    <p class="text-xs uppercase tracking-[0.18em] text-slate-400">SSL</p>
                    <p class="mt-1 text-sm font-medium text-slate-900"><%= store.ssl_status || 'Pending' %></p>
                  </div>
                </div>
              </article>
            <% }) %>
          </div>
        <% } else { %>
          <div class="mt-6 rounded-[1.75rem] border border-slate-200 bg-white p-5">
            <p class="text-sm leading-6 text-slate-600">No stores have been created yet. Pricing controls are still live, so you can set fees before the first tenant launches.</p>
          </div>
        <% } %>
      </section>

      <section class="surface-card rounded-[2rem] p-6">
        <p class="text-sm font-medium text-slate-500">Platform notes</p>
        <h2 class="section-title mt-1 text-2xl font-semibold text-slate-950">What this dashboard controls today</h2>
        <div class="mt-6 space-y-3">
          <div class="rounded-[1.5rem] border border-slate-200 bg-white px-4 py-4">
            <p class="text-sm font-semibold text-slate-950">Live pricing source</p>
            <p class="mt-2 text-sm leading-6 text-slate-600">The prices saved here feed the public pricing page, owner dashboard billing cards, and subscription charges generated by the billing service.</p>
          </div>
          <div class="rounded-[1.5rem] border border-slate-200 bg-white px-4 py-4">
            <p class="text-sm font-semibold text-slate-950">Geo and currency conversion</p>
            <p class="mt-2 text-sm leading-6 text-slate-600">Saved prices stay in <%= baseCurrency %>, then the platform converts them for supported currencies such as NGN and the visitor-selected top-bar currency.</p>
          </div>
          <div class="rounded-[1.5rem] border border-slate-200 bg-white px-4 py-4">
            <p class="text-sm font-semibold text-slate-950">Remaining platform-wide ops</p>
            <p class="mt-2 text-sm leading-6 text-slate-600">Cross-tenant support and incident tooling are still staged separately, but subscription fee management on this overview page is now live.</p>
          </div>
        </div>
      </section>
    </div>
  </div>
</section>
