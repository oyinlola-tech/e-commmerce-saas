<%
  const eyebrow = placeholderEyebrow || 'Operations preview';
  const title = placeholderTitle || 'This workspace is not enabled in this build.';
  const body = placeholderBody || 'Aisle keeps unfinished platform operations tooling behind an honest placeholder instead of filling it with fabricated demo data.';
  const highlights = Array.isArray(placeholderHighlights) ? placeholderHighlights : [];
  const workspaceHref = platformHomeUrl || '/dashboard';
  const workspaceLabel = platformIsAdmin ? 'Return to platform dashboard' : 'Return to owner workspace';
%>
<section class="space-y-8">
  <div class="surface-card relative overflow-hidden rounded-[2rem] p-8 sm:p-10">
    <div class="hero-orb hero-orb-primary -left-8 top-0 h-36 w-36"></div>
    <div class="hero-orb hero-orb-sky right-0 top-6 h-40 w-40"></div>
    <div class="relative max-w-4xl">
      <span class="eyebrow"><%= eyebrow %></span>
      <h1 class="section-title mt-5 text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl"><%= title %></h1>
      <p class="mt-4 max-w-3xl text-lg leading-8 text-slate-600"><%= body %></p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a href="<%= workspaceHref %>" class="inline-flex items-center justify-center rounded-2xl bg-primary px-5 py-3 text-sm font-semibold text-white shadow-soft transition hover:bg-primary-dark">
          <%= workspaceLabel %>
        </a>
        <a href="/" class="inline-flex items-center justify-center rounded-2xl border border-slate-200 bg-white px-5 py-3 text-sm font-medium text-slate-700 transition hover:border-primary hover:text-primary">
          Back to Aisle home
        </a>
      </div>
    </div>
  </div>

  <div class="grid gap-6 xl:grid-cols-[1.1fr_0.9fr]">
    <section class="surface-card rounded-[2rem] p-6">
      <p class="text-sm font-medium text-slate-500">Why this page is empty</p>
      <h2 class="section-title mt-2 text-2xl font-semibold text-slate-950">No staged data dressed up as production</h2>
      <div class="mt-6 space-y-3">
        <% highlights.forEach((item) => { %>
          <div class="rounded-[1.5rem] border border-slate-200 bg-white px-4 py-4">
            <p class="text-sm leading-6 text-slate-600"><%= item %></p>
          </div>
        <% }) %>
      </div>
    </section>

    <aside class="surface-card rounded-[2rem] p-6">
      <p class="text-sm font-medium text-slate-500">What is live today</p>
      <h2 class="section-title mt-2 text-2xl font-semibold text-slate-950">The real product surface</h2>
      <div class="mt-6 space-y-4">
        <div class="rounded-[1.5rem] bg-slate-50 p-4">
          <p class="text-sm font-semibold text-slate-950">Owner accounts and store creation</p>
          <p class="mt-2 text-sm leading-6 text-slate-600">Authentication, onboarding, and store setup are backed by real services.</p>
        </div>
        <div class="rounded-[1.5rem] bg-slate-50 p-4">
          <p class="text-sm font-semibold text-slate-950">Store admin</p>
          <p class="mt-2 text-sm leading-6 text-slate-600">Products, orders, settings, and domain setup are connected to live service data.</p>
        </div>
        <div class="rounded-[1.5rem] bg-slate-50 p-4">
          <p class="text-sm font-semibold text-slate-950">Storefront experience</p>
          <p class="mt-2 text-sm leading-6 text-slate-600">Catalog, account, wishlist, cart, and checkout all reflect the actual store that is active.</p>
        </div>
      </div>
    </aside>
  </div>
</section>
