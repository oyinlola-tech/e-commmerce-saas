<%
  const pricingTiers = [
    {
      name: 'Launch',
      description: 'For teams opening a single flagship store with clean operations from day one.',
      monthly: '$79',
      yearly: '$759',
      features: ['1 live storefront', 'International checkout setup', 'Domain management', 'Email support'],
      featured: false
    },
    {
      name: 'Scale',
      description: 'For growing operators who need deeper tooling, better service workflows, and multi-region confidence.',
      monthly: '$249',
      yearly: '$2,390',
      features: ['Up to 5 storefronts', 'Support operations console', 'Cross-team workflows', 'Priority service'],
      featured: true
    },
    {
      name: 'Enterprise',
      description: 'For multi-brand organizations that require centralized governance, reliability, and hands-on enablement.',
      monthly: '$799',
      yearly: '$7,670',
      features: ['Unlimited storefronts', 'Dedicated onboarding', 'Incident management', 'Custom integrations'],
      featured: false
    }
  ];
  const overview = metrics || {};
  const featuredStores = Array.isArray(stores) ? stores : [];
  const money = typeof formatMoney === 'function' ? formatMoney : ((value) => value);
  const proofItems = [
    {
      label: 'Live stores',
      value: overview.liveStores || 0,
      note: `${overview.storesCount || 0} total tenants tracked`
    },
    {
      label: 'GMV in 30 days',
      value: money(overview.gmv30d || 0),
      note: 'Platform-wide commercial activity'
    },
    {
      label: 'Markets served',
      value: overview.activeMarkets || 0,
      note: 'Regions currently supported in the mix'
    },
    {
      label: 'Open tickets',
      value: overview.openTickets || 0,
      note: 'Support items still awaiting closure'
    }
  ];
  const platformLayers = [
    {
      title: 'Storefronts with presence',
      body: 'Launch premium storefronts with stronger visual identity, better mobile rhythm, and content that feels ready for international audiences.',
      icon: 'storefront'
    },
    {
      title: 'Operations that stay clear',
      body: 'Product, order, settings, and domain workflows stay fast for teams that need clean execution instead of scattered admin tooling.',
      icon: 'operations'
    },
    {
      title: 'Control above the store',
      body: 'Platform admins can manage tenants, respond as support, and track incidents from a dedicated control center built for real operations.',
      icon: 'control'
    }
  ];
  const faqItems = [
    {
      question: 'Can I manage multiple brands from one platform?',
      answer: 'Yes. The owner workspace manages brand-level stores, while the control center watches the wider platform across tenants.'
    },
    {
      question: 'Is there a dedicated support and incident layer?',
      answer: 'Yes. Support conversations and incident workflows are surfaced in platform admin so teams can respond and coordinate from one place.'
    },
    {
      question: 'Does the storefront support international operations?',
      answer: 'The data model, content, and page structure are prepared for multi-market selling, domain management, and region-aware service messaging.'
    }
  ];
%>
<section class="platform-section-shell relative overflow-hidden pt-6 sm:pt-8 lg:pt-10">
  <div class="hero-orb hero-orb-primary left-0 top-10 h-72 w-72"></div>
  <div class="hero-orb hero-orb-sky right-0 top-16 h-72 w-72"></div>
  <div class="platform-hero-panel surface-card relative overflow-hidden rounded-[2.5rem] p-6 sm:p-8 lg:p-10">
    <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/80 to-transparent"></div>
    <div class="relative grid gap-8 xl:grid-cols-[minmax(0,1.08fr)_minmax(340px,0.92fr)] xl:items-stretch">
      <div class="flex h-full flex-col justify-between gap-8">
        <div class="space-y-6">
          <div class="flex flex-wrap items-center gap-3">
            <span class="eyebrow">Enterprise Commerce Operating System</span>
            <span class="signal-chip">
              <span class="signal-dot"></span>
              Built for active retail teams
            </span>
          </div>

          <div class="space-y-5">
            <h1 class="section-title max-w-4xl text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl lg:text-6xl">
              Launch faster, operate tighter, and grow stores globally with <span class="gradient-text">Aisle</span>.
            </h1>
            <p class="max-w-2xl text-lg leading-8 text-slate-600 sm:text-xl">
              Aisle Commerce Cloud gives modern retail teams a polished storefront, dependable admin workflows, and a real platform control layer for support and reliability.
            </p>
          </div>

          <ul class="grid gap-3 sm:grid-cols-2">
            <li class="platform-proof-card rounded-[1.6rem] px-4 py-4">
              <p class="text-sm font-semibold text-slate-900">Design-led storefront delivery</p>
              <p class="mt-1 text-sm leading-6 text-slate-600">A premium homepage, strong catalog pacing, and cleaner mobile presentation from day one.</p>
            </li>
            <li class="platform-proof-card rounded-[1.6rem] px-4 py-4">
              <p class="text-sm font-semibold text-slate-900">Operations and governance in one stack</p>
              <p class="mt-1 text-sm leading-6 text-slate-600">Store owners get everyday admin tools while platform admins keep support and incident control.</p>
            </li>
          </ul>
        </div>

        <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
          <a href="/dashboard" class="inline-flex items-center justify-center rounded-2xl bg-primary px-6 py-3.5 text-base font-semibold text-white shadow-soft transition hover:bg-primary-dark">
            Enter owner dashboard
          </a>
          <a href="/platform-admin" class="inline-flex items-center justify-center rounded-2xl border border-slate-200 bg-white px-6 py-3.5 text-base font-semibold text-slate-700 transition hover:border-primary hover:text-primary">
            Explore control center
          </a>
        </div>
      </div>

      <div class="grid gap-4">
        <div class="surface-card-dark flex h-full flex-col rounded-[2rem] p-6 text-white sm:p-7">
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="text-sm font-medium text-slate-300">Operations snapshot</p>
              <h2 class="section-title mt-2 text-3xl font-semibold">Platform pulse</h2>
              <p class="mt-2 max-w-md text-sm leading-6 text-slate-300">
                Watch tenant health, incident pressure, and revenue concentration from a single control plane.
              </p>
            </div>
            <span class="signal-chip border-white/10 bg-white/10 text-white">
              <span class="signal-dot"></span>
              Stable
            </span>
          </div>

          <div class="mt-6 grid gap-4 sm:grid-cols-2">
            <div class="platform-mini-stat rounded-[1.5rem] bg-white/5 p-5">
              <p class="text-sm text-slate-300">Tenant health</p>
              <p class="metric-value mt-3 text-3xl font-semibold"><%= overview.liveStores || 0 %>/<%= overview.storesCount || 0 %></p>
              <p class="mt-2 text-sm text-emerald-300">Live stores operating across active markets</p>
            </div>
            <div class="platform-mini-stat rounded-[1.5rem] bg-white/5 p-5">
              <p class="text-sm text-slate-300">Reliability watch</p>
              <p class="metric-value mt-3 text-3xl font-semibold"><%= overview.unresolvedIncidents || 0 %></p>
              <p class="mt-2 text-sm text-slate-300">Issues still requiring coordinated attention</p>
            </div>
          </div>

          <div class="mt-6 rounded-[1.7rem] bg-white p-5 text-slate-900">
            <div class="flex items-center justify-between gap-3">
              <p class="text-sm font-medium text-slate-500">Featured tenants</p>
              <span class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-400">Live sample</span>
            </div>

            <div class="mt-4 space-y-3">
              <% if (featuredStores.length) { %>
                <% featuredStores.forEach((store) => { %>
                  <div class="flex items-center justify-between gap-4 rounded-2xl bg-slate-50 px-4 py-3">
                    <div class="min-w-0">
                      <p class="truncate text-sm font-semibold text-slate-950"><%= store.name %></p>
                      <p class="truncate text-xs text-slate-500"><%= store.markets ? store.markets.join(', ') : 'Global' %></p>
                    </div>
                    <span class="text-sm font-semibold text-primary"><%= money(store.monthly_revenue || 0) %></span>
                  </div>
                <% }) %>
              <% } else { %>
                <div class="rounded-2xl border border-dashed border-slate-200 px-4 py-5 text-sm leading-6 text-slate-500">
                  Launch a store to start surfacing live tenant highlights here.
                </div>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-6 grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
    <% proofItems.forEach((item) => { %>
      <article class="platform-proof-card h-full rounded-[1.6rem] p-5">
        <p class="text-sm font-medium text-slate-500"><%= item.label %></p>
        <p class="metric-value mt-3 text-3xl font-semibold text-slate-950"><%= item.value %></p>
        <p class="mt-2 text-sm leading-6 text-slate-600"><%= item.note %></p>
      </article>
    <% }) %>
  </div>
</section>

<section id="features" class="platform-section-shell py-12 sm:py-14 lg:py-20">
  <div class="grid gap-8 lg:grid-cols-[0.88fr_1.12fr] lg:items-start">
    <div class="space-y-5">
      <span class="eyebrow">Why Aisle</span>
      <h2 class="section-title text-4xl font-semibold tracking-tight text-slate-950">Everything a serious commerce team expects, without the operational drag.</h2>
      <p class="max-w-xl text-lg leading-8 text-slate-600">
        Built for operators who care about design, conversion, support responsiveness, and platform control in equal measure.
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-3">
      <% platformLayers.forEach((layer) => { %>
        <article class="surface-card lift-on-hover flex h-full flex-col rounded-[2rem] p-8">
          <span class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-primary-soft text-primary">
            <% if (layer.icon === 'storefront') { %>
              <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                <path d="M4 4h16v16H4z" stroke-width="1.5"></path>
                <path d="M8 8h8v8H8z" stroke-width="1.5"></path>
              </svg>
            <% } %>
            <% if (layer.icon === 'operations') { %>
              <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                <path d="M4 7h16" stroke-width="1.5"></path>
                <path d="M6 12h12" stroke-width="1.5"></path>
                <path d="M8 17h8" stroke-width="1.5"></path>
                <rect x="3.25" y="4.25" width="17.5" height="15.5" rx="2.75" stroke-width="1.5"></rect>
              </svg>
            <% } %>
            <% if (layer.icon === 'control') { %>
              <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                <path d="M7 10V8a5 5 0 0110 0v2" stroke-width="1.5"></path>
                <rect x="5" y="10" width="14" height="10" rx="2" stroke-width="1.5"></rect>
                <path d="M12 14v2" stroke-width="1.5"></path>
              </svg>
            <% } %>
          </span>
          <h3 class="section-title mt-6 text-2xl font-semibold text-slate-950"><%= layer.title %></h3>
          <p class="mt-3 flex-1 text-base leading-7 text-slate-600"><%= layer.body %></p>
        </article>
      <% }) %>
    </div>
  </div>
</section>

<section id="pricing" class="platform-band border-y border-slate-200/80">
  <div class="platform-section-shell py-12 sm:py-14 lg:py-20">
    <div class="mx-auto max-w-2xl text-center">
      <span class="eyebrow">Pricing</span>
      <h2 class="section-title mt-5 text-4xl font-semibold tracking-tight text-slate-950">Plans designed for teams with ambition, not hobby overhead.</h2>
      <p data-billing-copy class="mt-4 text-lg text-slate-600">Switch to annual billing and save 20%</p>
    </div>

    <div class="mt-8 flex items-center justify-center gap-4">
      <span class="text-sm font-medium text-slate-600">Monthly</span>
      <label class="relative inline-flex cursor-pointer items-center">
        <input type="checkbox" data-pricing-toggle class="peer sr-only">
        <span class="h-7 w-14 rounded-full bg-slate-200 transition peer-checked:bg-primary"></span>
        <span class="absolute left-1 top-1 h-5 w-5 rounded-full bg-white transition peer-checked:translate-x-7"></span>
      </label>
      <span class="text-sm font-medium text-slate-600">Yearly</span>
    </div>

    <div class="mt-12 grid gap-6 lg:grid-cols-3">
      <% pricingTiers.forEach((tier) => { %>
        <article
          data-price-card
          data-price-monthly="<%= tier.monthly %>"
          data-price-yearly="<%= tier.yearly %>"
          class="platform-pricing-card flex h-full flex-col rounded-[2rem] border p-8 shadow-sm <%= tier.featured ? 'border-primary bg-slate-950 text-white shadow-glow' : 'border-slate-200 bg-white text-slate-900' %>">
          <div class="min-h-[1.75rem]">
            <% if (tier.featured) { %>
              <span class="inline-flex rounded-full bg-white/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.24em] text-emerald-200">Best for growing teams</span>
            <% } else { %>
              <span class="invisible inline-flex rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-[0.24em]">Best for growing teams</span>
            <% } %>
          </div>
          <h3 class="section-title mt-4 text-3xl font-semibold"><%= tier.name %></h3>
          <p class="mt-3 text-sm leading-6 <%= tier.featured ? 'text-slate-300' : 'text-slate-600' %>"><%= tier.description %></p>
          <div class="mt-8 flex items-end gap-2">
            <span data-price-value class="section-title text-4xl font-semibold tracking-tight"><%= tier.monthly %></span>
            <span data-price-suffix class="pb-1 text-sm <%= tier.featured ? 'text-slate-300' : 'text-slate-500' %>">/month</span>
          </div>
          <ul class="mt-8 flex-1 space-y-3">
            <% tier.features.forEach((feature) => { %>
              <li class="flex items-start gap-3 text-sm <%= tier.featured ? 'text-slate-200' : 'text-slate-600' %>">
                <svg class="mt-0.5 h-5 w-5 flex-none <%= tier.featured ? 'text-emerald-200' : 'text-primary' %>" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.704 5.29a1 1 0 010 1.42l-7.2 7.2a1 1 0 01-1.415 0l-3-3a1 1 0 111.414-1.42l2.293 2.294 6.493-6.494a1 1 0 011.415 0z" clip-rule="evenodd"></path>
                </svg>
                <span><%= feature %></span>
              </li>
            <% }) %>
          </ul>
          <a href="/dashboard" class="mt-8 inline-flex w-full items-center justify-center rounded-2xl px-4 py-3 text-sm font-semibold transition <%= tier.featured ? 'bg-primary text-white hover:bg-primary-dark' : 'border border-slate-200 bg-white text-slate-700 hover:border-primary hover:text-primary' %>">
            Choose <%= tier.name %>
          </a>
        </article>
      <% }) %>
    </div>
  </div>
</section>

<section id="faq" class="platform-section-shell py-12 sm:py-14 lg:py-20">
  <div class="grid gap-8 lg:grid-cols-[0.82fr_1.18fr] lg:items-start">
    <div class="space-y-5">
      <span class="eyebrow">FAQ</span>
      <h2 class="section-title text-4xl font-semibold tracking-tight text-slate-950">Answers for operators building beyond one market.</h2>
      <p class="text-lg leading-8 text-slate-600">
        Aisle is designed for teams that need strong storefront UX and serious day-two operations in the same system.
      </p>
      <div class="surface-card rounded-[2rem] p-6">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary">Need a closer look?</p>
        <p class="mt-3 text-base leading-7 text-slate-600">
          Open the owner workspace for storefront operations or step into the control center to review support and reliability tooling.
        </p>
        <div class="mt-5 flex flex-col gap-3 sm:flex-row">
          <a href="/dashboard" class="inline-flex items-center justify-center rounded-2xl bg-primary px-5 py-3 text-sm font-semibold text-white transition hover:bg-primary-dark">Open owner workspace</a>
          <a href="/platform-admin" class="inline-flex items-center justify-center rounded-2xl border border-slate-200 bg-white px-5 py-3 text-sm font-semibold text-slate-700 transition hover:border-primary hover:text-primary">Visit control center</a>
        </div>
      </div>
    </div>

    <div class="space-y-4">
      <% faqItems.forEach((item) => { %>
        <article class="surface-card rounded-[2rem] p-6">
          <h3 class="text-lg font-semibold text-slate-950"><%= item.question %></h3>
          <p class="mt-3 text-base leading-7 text-slate-600"><%= item.answer %></p>
        </article>
      <% }) %>
    </div>
  </div>
</section>
