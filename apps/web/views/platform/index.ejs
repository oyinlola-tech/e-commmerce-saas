<%
  const signedIn = Boolean(platformUser && platformUser.id);
  const primaryCtaHref = signedIn ? '/dashboard' : '/signup';
  const primaryCtaLabel = signedIn ? 'Open owner workspace' : 'Create your account';
  const secondaryCtaHref = signedIn ? '/#pricing' : '/login';
  const secondaryCtaLabel = signedIn ? 'View plans' : 'Sign in';
  const availableBillingPlans = Array.isArray(billingPlans) && billingPlans.length
    ? billingPlans
    : [
        {
          code: 'launch',
          name: 'Launch',
          description: 'For teams opening one serious storefront with real admin tools from day one.',
          monthly_amount: 10,
          yearly_amount: 96,
          features: ['1 live storefront', 'Owner workspace', 'Domain management', 'Email support'],
          currency: selectedCurrency || 'USD',
          trial_days: 7,
          trial_authorization_amount: 1
        },
        {
          code: 'scale',
          name: 'Scale',
          description: 'For operators managing multiple stores who want clean workflows and room to expand.',
          monthly_amount: 40,
          yearly_amount: 384,
          features: ['Up to 5 storefronts', 'Priority support', 'Advanced analytics', 'Operational flexibility'],
          currency: selectedCurrency || 'USD',
          trial_days: 7,
          trial_authorization_amount: 1
        },
        {
          code: 'enterprise',
          name: 'Enterprise',
          description: 'For multi-brand teams planning custom workflows, governance, and white-glove rollout.',
          monthly_amount: 100,
          yearly_amount: 960,
          features: ['Unlimited storefronts', 'Custom onboarding', 'Dedicated support lane', 'Implementation planning'],
          currency: selectedCurrency || 'USD',
          trial_days: 7,
          trial_authorization_amount: 1
        }
      ];
  const pricingFormatter = new Intl.NumberFormat((currencyContext && currencyContext.locale) || 'en-US', {
    style: 'currency',
    currency: availableBillingPlans[0] && availableBillingPlans[0].currency ? availableBillingPlans[0].currency : ((selectedCurrency || 'USD'))
  });
  const trialAuthorizationDisplay = pricingFormatter.format(Number((availableBillingPlans[0] && availableBillingPlans[0].trial_authorization_amount) || 1));
  const pricingTiers = availableBillingPlans.map((plan) => ({
    code: plan.code,
    name: plan.name,
    description: plan.description,
    monthly: pricingFormatter.format(Number(plan.monthly_amount || 0)),
    yearly: pricingFormatter.format(Number(plan.yearly_amount || 0)),
    features: Array.isArray(plan.features) ? plan.features : [],
    featured: plan.code === 'scale'
  }));
  const buildStatusCards = [
    {
      label: 'Owner auth',
      value: 'Live',
      note: 'Sign-up, sign-in, and store access are backed by real services.'
    },
    {
      label: 'Store admin',
      value: 'Live',
      note: 'Products, orders, settings, and domains use live service data.'
    },
    {
      label: 'Storefront',
      value: 'Live',
      note: 'Catalog, account, cart, wishlist, and checkout reflect the active store.'
    },
    {
      label: 'Platform ops',
      value: 'Preview',
      note: 'Multi-tenant support and incident tooling stay honestly disabled for now.'
    }
  ];
  const capabilityCards = [
    {
      title: 'Storefronts with intention',
      body: 'Aisle is built to help stores feel calm, premium, and real instead of looking like a theme preview wrapped in filler copy.'
    },
    {
      title: 'Operations that stay clear',
      body: 'Merchandising, orders, settings, and domain setup live in one owner workspace with the depth and clarity serious teams expect.'
    },
    {
      title: 'Honest product boundaries',
      body: 'When a platform-wide surface is not ready yet, Aisle says so plainly instead of inventing tenants, incidents, or support data.'
    }
  ];
  const faqItems = [
    {
      question: 'Can I create and manage real stores from this build?',
      answer: 'Yes. Owner accounts, store creation, store admin, storefront auth, and customer checkout flows are all wired to services.'
    },
    {
      question: 'Why is the platform operations area a placeholder?',
      answer: 'Because platform-wide support, incident handling, and staff operations will only appear once they are backed by real permissions and workflows.'
    },
    {
      question: 'Does this support custom storefront identity?',
      answer: 'Yes. Each store can carry its own theme color, typography, content, catalog, domain, and support details.'
    }
  ];
%>
<section class="platform-section-shell relative overflow-hidden pt-6 sm:pt-8 lg:pt-10">
  <div class="hero-orb hero-orb-primary left-0 top-10 h-72 w-72"></div>
  <div class="hero-orb hero-orb-sky right-0 top-16 h-72 w-72"></div>
  <div class="platform-hero-panel surface-card relative overflow-hidden rounded-[2.5rem] p-6 sm:p-8 lg:p-10">
    <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/80 to-transparent"></div>
    <div class="relative grid gap-8 xl:grid-cols-[minmax(0,1.05fr)_minmax(340px,0.95fr)] xl:items-stretch">
      <div class="flex h-full flex-col justify-between gap-8">
        <div class="space-y-6">
          <div class="flex flex-wrap items-center gap-3">
            <span class="eyebrow">Aisle</span>
            <span class="signal-chip">
              <span class="signal-dot"></span>
              Real auth and store workflows
            </span>
          </div>

          <div class="space-y-5">
            <h1 class="section-title max-w-4xl text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl lg:text-6xl">
              Commerce software that feels built, not staged.
            </h1>
            <p class="max-w-2xl text-lg leading-8 text-slate-600 sm:text-xl">
              Aisle gives retail teams a sharper storefront, a real owner workspace, and an honest product surface that refuses to fake platform tooling before it exists.
            </p>
          </div>

          <ul class="grid gap-3 sm:grid-cols-2">
            <li class="platform-proof-card rounded-[1.6rem] px-4 py-4">
              <p class="text-sm font-semibold text-slate-900">No fabricated tenant dashboards</p>
              <p class="mt-1 text-sm leading-6 text-slate-600">Aisle now reserves unfinished platform features instead of filling them with made-up data.</p>
            </li>
            <li class="platform-proof-card rounded-[1.6rem] px-4 py-4">
              <p class="text-sm font-semibold text-slate-900">Store operations on live services</p>
              <p class="mt-1 text-sm leading-6 text-slate-600">Products, orders, settings, auth, and customer journeys reflect the real store in context.</p>
            </li>
          </ul>
        </div>

        <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
          <a href="<%= primaryCtaHref %>" class="inline-flex items-center justify-center rounded-2xl bg-primary px-6 py-3.5 text-base font-semibold text-white shadow-soft transition hover:bg-primary-dark">
            <%= primaryCtaLabel %>
          </a>
          <a href="<%= secondaryCtaHref %>" class="inline-flex items-center justify-center rounded-2xl border border-slate-200 bg-white px-6 py-3.5 text-base font-semibold text-slate-700 transition hover:border-primary hover:text-primary">
            <%= secondaryCtaLabel %>
          </a>
        </div>
      </div>

      <div class="grid gap-4">
        <div class="surface-card-dark flex h-full flex-col rounded-[2rem] p-6 text-white sm:p-7">
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="text-sm font-medium text-slate-300">What ships today</p>
              <h2 class="section-title mt-2 text-3xl font-semibold">A product surface you can trust</h2>
              <p class="mt-2 max-w-md text-sm leading-6 text-slate-300">
                The public product, owner workspace, and storefront experience are real. The platform-wide operations area stays in preview until it deserves to be trusted.
              </p>
            </div>
            <span class="signal-chip border-white/10 bg-white/10 text-white">
              <span class="signal-dot"></span>
              Honest by default
            </span>
          </div>

          <div class="mt-6 grid gap-4">
            <div class="platform-mini-stat rounded-[1.5rem] bg-white/5 p-5">
              <p class="text-sm text-slate-300">Owner workspace</p>
              <p class="metric-value mt-3 text-3xl font-semibold">Stores, products, orders, settings</p>
              <p class="mt-2 text-sm text-slate-300">The day-to-day retail workspace is live and grounded in service data.</p>
            </div>
            <div class="platform-mini-stat rounded-[1.5rem] bg-white/5 p-5">
              <p class="text-sm text-slate-300">Platform operations</p>
              <p class="metric-value mt-3 text-3xl font-semibold">Preview only</p>
              <p class="mt-2 text-sm text-slate-300">No fake incidents, support queues, or tenant analytics masquerading as production.</p>
            </div>
          </div>

          <div class="mt-6 rounded-[1.7rem] bg-white p-5 text-slate-900">
            <div class="flex items-center justify-between gap-3">
              <p class="text-sm font-medium text-slate-500">Current product boundaries</p>
              <span class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-400">Transparent</span>
            </div>

            <div class="mt-4 space-y-3">
              <div class="rounded-2xl bg-slate-50 px-4 py-3">
                <p class="text-sm font-semibold text-slate-950">Customer auth and checkout are real</p>
                <p class="mt-1 text-xs leading-5 text-slate-500">Customers create store-specific accounts and place real orders tied to the active store.</p>
              </div>
              <div class="rounded-2xl bg-slate-50 px-4 py-3">
                <p class="text-sm font-semibold text-slate-950">Store admin is real</p>
                <p class="mt-1 text-xs leading-5 text-slate-500">Catalog, orders, settings, and domain management are no longer backed by seeded state.</p>
              </div>
              <div class="rounded-2xl bg-slate-50 px-4 py-3">
                <p class="text-sm font-semibold text-slate-950">Platform-wide ops are reserved</p>
                <p class="mt-1 text-xs leading-5 text-slate-500">You see a placeholder until the cross-tenant layer is implemented properly.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-6 grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
    <% buildStatusCards.forEach((item) => { %>
      <article class="platform-proof-card h-full rounded-[1.6rem] p-5">
        <p class="text-sm font-medium text-slate-500"><%= item.label %></p>
        <p class="metric-value mt-3 text-3xl font-semibold text-slate-950"><%= item.value %></p>
        <p class="mt-2 text-sm leading-6 text-slate-600"><%= item.note %></p>
      </article>
    <% }) %>
  </div>
</section>

<section id="features" class="platform-section-shell py-12 sm:py-14 lg:py-20">
  <div class="grid gap-8 lg:grid-cols-[0.88fr_1.12fr] lg:items-start">
    <div class="space-y-5">
      <span class="eyebrow">Why Aisle</span>
      <h2 class="section-title text-4xl font-semibold tracking-tight text-slate-950">The frontend should earn trust before it asks for it.</h2>
      <p class="max-w-xl text-lg leading-8 text-slate-600">
        Aisle is being shaped around a simple rule: if a workflow looks real, it should be real.
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-3">
      <% capabilityCards.forEach((card) => { %>
        <article class="surface-card lift-on-hover flex h-full flex-col rounded-[2rem] p-8">
          <span class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-primary-soft text-primary">
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
              <path d="M5 12h14" stroke-width="1.5" stroke-linecap="round"></path>
              <path d="M12 5v14" stroke-width="1.5" stroke-linecap="round"></path>
              <rect x="3.25" y="3.25" width="17.5" height="17.5" rx="3.75" stroke-width="1.5"></rect>
            </svg>
          </span>
          <h3 class="section-title mt-6 text-2xl font-semibold text-slate-950"><%= card.title %></h3>
          <p class="mt-3 flex-1 text-base leading-7 text-slate-600"><%= card.body %></p>
        </article>
      <% }) %>
    </div>
  </div>
</section>

<section id="pricing" class="platform-band border-y border-slate-200/80">
  <div class="platform-section-shell py-12 sm:py-14 lg:py-20">
    <div class="mx-auto max-w-2xl text-center">
      <span class="eyebrow">Pricing</span>
      <h2 class="section-title mt-5 text-4xl font-semibold tracking-tight text-slate-950">Plans for teams who want the product to feel as serious as the price tag.</h2>
      <p
        data-billing-copy
        data-billing-copy-monthly="Start with a 7-day trial. Paystack charges <%= trialAuthorizationDisplay %> to verify the card, refunds it after success, then charges the plan in 7 days."
        data-billing-copy-yearly="Annual billing still starts with the same 7-day card verification flow, then charges the discounted yearly amount after the trial."
        class="mt-4 text-lg text-slate-600">
        Start with a 7-day trial. Paystack charges <%= trialAuthorizationDisplay %> to verify the card, refunds it after success, then charges the plan in 7 days.
      </p>
    </div>

    <div class="mt-8 flex items-center justify-center gap-4">
      <span class="text-sm font-medium text-slate-600">Monthly</span>
      <label class="relative inline-flex cursor-pointer items-center">
        <input type="checkbox" data-pricing-toggle class="peer sr-only">
        <span class="h-7 w-14 rounded-full bg-slate-200 transition peer-checked:bg-primary"></span>
        <span class="absolute left-1 top-1 h-5 w-5 rounded-full bg-white transition peer-checked:translate-x-7"></span>
      </label>
      <span class="text-sm font-medium text-slate-600">Yearly</span>
    </div>

    <div class="mt-12 grid gap-6 lg:grid-cols-3">
      <% pricingTiers.forEach((tier) => { %>
        <article
          data-price-card
          data-price-monthly="<%= tier.monthly %>"
          data-price-yearly="<%= tier.yearly %>"
          class="platform-pricing-card flex h-full flex-col rounded-[2rem] border p-8 shadow-sm <%= tier.featured ? 'border-primary bg-slate-950 text-white shadow-glow' : 'border-slate-200 bg-white text-slate-900' %>">
          <div class="min-h-[1.75rem]">
            <% if (tier.featured) { %>
              <span class="inline-flex rounded-full bg-white/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.24em] text-emerald-200">Best for growing teams</span>
            <% } else { %>
              <span class="invisible inline-flex rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-[0.24em]">Best for growing teams</span>
            <% } %>
          </div>
          <h3 class="section-title mt-4 text-3xl font-semibold"><%= tier.name %></h3>
          <p class="mt-3 text-sm leading-6 <%= tier.featured ? 'text-slate-300' : 'text-slate-600' %>"><%= tier.description %></p>
          <div class="mt-8 flex items-end gap-2">
            <span data-price-value class="section-title text-4xl font-semibold tracking-tight"><%= tier.monthly %></span>
            <span data-price-suffix class="pb-1 text-sm <%= tier.featured ? 'text-slate-300' : 'text-slate-500' %>">/month</span>
          </div>
          <ul class="mt-8 flex-1 space-y-3">
            <% tier.features.forEach((feature) => { %>
              <li class="flex items-start gap-3 text-sm <%= tier.featured ? 'text-slate-200' : 'text-slate-600' %>">
                <svg class="mt-0.5 h-5 w-5 flex-none <%= tier.featured ? 'text-emerald-200' : 'text-primary' %>" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.704 5.29a1 1 0 010 1.42l-7.2 7.2a1 1 0 01-1.415 0l-3-3a1 1 0 111.414-1.42l2.293 2.294 6.493-6.494a1 1 0 011.415 0z" clip-rule="evenodd"></path>
                </svg>
                <span><%= feature %></span>
              </li>
            <% }) %>
          </ul>
          <a href="<%= primaryCtaHref %>" class="mt-8 inline-flex w-full items-center justify-center rounded-2xl px-4 py-3 text-sm font-semibold transition <%= tier.featured ? 'bg-primary text-white hover:bg-primary-dark' : 'border border-slate-200 bg-white text-slate-700 hover:border-primary hover:text-primary' %>">
            <%= signedIn ? 'Open workspace' : `Choose ${tier.name}` %>
          </a>
        </article>
      <% }) %>
    </div>
  </div>
</section>

<section id="faq" class="platform-section-shell py-12 sm:py-14 lg:py-20">
  <div class="grid gap-8 lg:grid-cols-[0.82fr_1.18fr] lg:items-start">
    <div class="space-y-5">
      <span class="eyebrow">FAQ</span>
      <h2 class="section-title text-4xl font-semibold tracking-tight text-slate-950">What matters most right now</h2>
      <p class="text-lg leading-8 text-slate-600">
        Aisle is focusing on the product surfaces that should already feel trustworthy: auth, storefronts, and owner operations.
      </p>
      <div class="surface-card rounded-[2rem] p-6">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary">Next step</p>
        <p class="mt-3 text-base leading-7 text-slate-600">
          <%= signedIn
            ? 'Return to your owner workspace to manage stores, products, and orders.'
            : 'Create an account to start your first store with real workflows from day one.' %>
        </p>
        <div class="mt-5 flex flex-col gap-3 sm:flex-row">
          <a href="<%= primaryCtaHref %>" class="inline-flex items-center justify-center rounded-2xl bg-primary px-5 py-3 text-sm font-semibold text-white transition hover:bg-primary-dark"><%= primaryCtaLabel %></a>
          <a href="<%= secondaryCtaHref %>" class="inline-flex items-center justify-center rounded-2xl border border-slate-200 bg-white px-5 py-3 text-sm font-semibold text-slate-700 transition hover:border-primary hover:text-primary"><%= secondaryCtaLabel %></a>
        </div>
      </div>
    </div>

    <div class="space-y-4">
      <% faqItems.forEach((item) => { %>
        <article class="surface-card rounded-[2rem] p-6">
          <h3 class="text-lg font-semibold text-slate-950"><%= item.question %></h3>
          <p class="mt-3 text-base leading-7 text-slate-600"><%= item.answer %></p>
        </article>
      <% }) %>
    </div>
  </div>
</section>
