{
  "name": "aisle-commerce-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Proprietary multi-tenant e-commerce SaaS monorepo by Oluwayemi Oyinlola Michael. Not free to use.",
  "author": {
    "name": "Oluwayemi Oyinlola Michael",
    "url": "https://www.oyinlola.site/"
  },
  "homepage": "https://www.oyinlola.site/",
  "license": "UNLICENSED",
  "workspaces": [
    "apps/web",
    "apps/gateway",
    "apps/services/*",
    "packages/*"
  ],
  "scripts": {
    "build:styles": "tailwindcss -c tailwind.config.js -i apps/web/src/styles/tailwind.css -o apps/web/public/styles/app.css --minify",
    "prestart": "npm run build:styles",
    "prestart:once": "npm run build:styles",
    "prestart:browser": "npm run build:styles",
    "prestart:frontend": "npm run build:styles",
    "predev": "npm run build:styles",
    "predev:browser": "npm run build:styles",
    "predev:frontend": "npm run build:styles",
    "predev:web": "npm run build:styles",
    "prestart:web": "npm run build:styles",
    "start": "nodemon --config nodemon.json --exec \"node scripts/run-stack.js\"",
    "start:once": "node scripts/run-stack.js",
    "start:browser": "node scripts/run-stack.js --browser-only",
    "start:services": "node scripts/run-stack.js --services-only",
    "dev": "nodemon --config nodemon.json --exec \"node scripts/run-stack.js\"",
    "dev:browser": "nodemon --config nodemon.json --exec \"node scripts/run-stack.js --browser-only\"",
    "dev:services": "nodemon --config nodemon.json --exec \"node scripts/run-stack.js --services-only\"",
    "dev:frontend": "nodemon --config nodemon.json --exec \"node scripts/run-stack.js --frontend-only\"",
    "dev:backend": "nodemon --config nodemon.json --exec \"node scripts/run-stack.js --backend-only\"",
    "start:frontend": "node scripts/run-stack.js --frontend-only",
    "start:backend": "node scripts/run-stack.js --backend-only",
    "start:web": "node apps/web/app.js",
    "dev:web": "nodemon --watch apps/web --watch packages/shared --watch scripts --ext js,json,ejs --exec \"node apps/web/app.js\"",
    "start:gateway": "node apps/gateway/server.js",
    "dev:gateway": "nodemon --watch apps/gateway --watch packages/shared --watch scripts --ext js,json,ejs --exec \"node apps/gateway/server.js\"",
    "start:user-service": "node apps/services/user-service/server.js",
    "dev:user-service": "nodemon --watch apps/services/user-service --watch packages/shared --ext js,json --exec \"node apps/services/user-service/server.js\"",
    "start:store-service": "node apps/services/store-service/server.js",
    "dev:store-service": "nodemon --watch apps/services/store-service --watch packages/shared --ext js,json --exec \"node apps/services/store-service/server.js\"",
    "start:compliance-service": "node apps/services/compliance-service/server.js",
    "dev:compliance-service": "nodemon --watch apps/services/compliance-service --watch packages/shared --ext js,json --exec \"node apps/services/compliance-service/server.js\"",
    "start:customer-service": "node apps/services/customer-service/server.js",
    "dev:customer-service": "nodemon --watch apps/services/customer-service --watch packages/shared --ext js,json --exec \"node apps/services/customer-service/server.js\"",
    "start:product-service": "node apps/services/product-service/server.js",
    "dev:product-service": "nodemon --watch apps/services/product-service --watch packages/shared --ext js,json --exec \"node apps/services/product-service/server.js\"",
    "start:cart-service": "node apps/services/cart-service/server.js",
    "dev:cart-service": "nodemon --watch apps/services/cart-service --watch packages/shared --ext js,json --exec \"node apps/services/cart-service/server.js\"",
    "start:order-service": "node apps/services/order-service/server.js",
    "dev:order-service": "nodemon --watch apps/services/order-service --watch packages/shared --ext js,json --exec \"node apps/services/order-service/server.js\"",
    "start:payment-service": "node apps/services/payment-service/server.js",
    "dev:payment-service": "nodemon --watch apps/services/payment-service --watch packages/shared --ext js,json --exec \"node apps/services/payment-service/server.js\"",
    "start:billing-service": "node apps/services/billing-service/server.js",
    "dev:billing-service": "nodemon --watch apps/services/billing-service --watch packages/shared --ext js,json --exec \"node apps/services/billing-service/server.js\"",
    "start:support-service": "node apps/services/support-service/server.js",
    "start:chat-service": "node apps/services/chat-service/server.js",
    "start:notification-service": "node apps/services/notification-service/server.js",
    "dev:notification-service": "nodemon --watch apps/services/notification-service --watch packages/shared --ext js,json --exec \"node apps/services/notification-service/server.js\"",
    "swagger": "node scripts/swagger.js",
    "swagger:export": "node scripts/swagger.js --export-only",
    "api:request": "node scripts/internal-request.js",
    "lint": "eslint ."
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "amqplib": "^1.0.3",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "csrf-csrf": "^4.0.3",
    "dotenv": "^17.4.2",
    "ejs": "^5.0.2",
    "express": "^5.2.1",
    "express-ejs-layouts": "^2.5.1",
    "express-rate-limit": "^8.4.1",
    "express-validator": "^7.3.2",
    "file-type": "^22.0.1",
    "helmet": "^8.1.0",
    "http-proxy-middleware": "^3.0.5",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "mysql2": "^3.22.3",
    "nodemailer": "^8.0.7",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "sanitize-html": "^2.17.3",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "clean-css-cli": "^5.6.3",
    "eslint": "^10.3.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.19",
    "uglify-js": "^3.19.3"
  }
}
